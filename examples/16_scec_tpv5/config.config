# SCEC TPV5: Vertical strike-slip fault with linear slip-weakening friction
#
# Reference: SCEC CVWS (Community Verification for Wave Propagation Simulations)
#   https://strike.scec.org/cvws/cgi-bin/cvws.cgi
#
# This is a full-resolution version for production runs.
# For CI, use config/examples/scec_tpv5.config (coarse mesh, short time).
#
# Material: homogeneous elastic
#   density = 2670 kg/m^3, Vs = 3464 m/s, Vp = 6000 m/s
#   G = rho * Vs^2 = 32.04 GPa
#   E = 2*G*(1+nu) = 80.33 GPa  (nu = 0.25)
#
# Fault: vertical, strike = 90 (YZ plane), dip = 90
#   Static friction mu_s = 0.677
#   Dynamic friction mu_d = 0.525
#   Critical slip distance Dc = 0.40 m
#   Initial normal stress = -120 MPa (compressive)
#   Background shear stress = 70 MPa
#   Nucleation patch: center at (0, 7500, -7500), radius 1500 m
#     with overstressed shear = 81.6 MPa

[SIMULATION]
name = scec_tpv5
start_time = 0.0
end_time = 12.0
dt_initial = 0.002
dt_min = 0.0005
dt_max = 0.01
max_timesteps = 10000
output_frequency = 50
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = false
enable_elastodynamics = true
enable_faults = true

[GRID]
nx = 64
ny = 1
nz = 32
Lx = 32000.0
Ly = 100.0
Lz = 17000.0

[ROCK]
density = 2670.0
youngs_modulus = 80.3328e9
poissons_ratio = 0.25

[FAULT]
strike = 90.0
dip = 90.0
center_x = 16000.0
center_y = 50.0
center_z = 8500.0
length = 200000.0
width = 200000.0
mode = slipping
friction_model = slip_weakening
static_friction = 0.677
dynamic_friction = 0.525
critical_slip_distance = 0.40
friction_coefficient = 0.677
initial_normal_stress = -120.0e6
initial_shear_stress = 70.0e6
nucleation_center_x = 0.0
nucleation_center_z = 8500.0
nucleation_radius = 1500.0
nucleation_shear_stress = 81.6e6

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[ABSORBING_BC]
enabled = false
