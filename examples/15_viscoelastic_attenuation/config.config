# Viscoelastic Attenuation Example
#
# Explosion source in a homogeneous medium with seismic attenuation.
# Uses a 3-mechanism generalized Maxwell body to approximate constant Q.
#
# The quality factor Q describes amplitude decay: after traveling one
# wavelength, amplitude decreases by exp(-pi/Q). For Earth's crust,
# Q_p is typically 100-1000 and Q_s is 50-500.
#
# Physics:
#   sigma(t) = C_relaxed : eps(t) + sum_i R_i(t)
#   dR_i/dt = -R_i / tau_i + delta_mu_i * deps/dt

[SIMULATION]
name = viscoelastic_attenuation
start_time = 0.0
end_time = 2.0
dt_initial = 0.005
dt_min = 0.001
dt_max = 0.01
max_timesteps = 400
output_frequency = 50
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_elastodynamics = true
enable_faults = false
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 30000.0
Ly = 30000.0
Lz = 10000.0

[ROCK]
density = 2650.0
youngs_modulus = 50.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
assignment = depth

[LAYER_1]
z_top = 10000.0
z_bottom = 0.0
lambda = 2.97e10
mu = 2.97e10
rho = 2650.0

[VISCOELASTIC]
enabled = true
num_mechanisms = 3
q_p = 200.0
q_s = 100.0
f_min = 0.1
f_max = 10.0

[EXPLOSION]
enabled = true
yield_kt = 10.0
depth = 5000.0
source_x = 15000.0
source_y = 15000.0
source_z = 5000.0
source_time = 0.0

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = false
z_max = false

[SEISMOMETERS]
enabled = true
format = SAC
station_0 = 17000.0, 15000.0, 10000.0, STA01
station_1 = 23000.0, 15000.0, 10000.0, STA02
