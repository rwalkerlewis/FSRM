# Thermal Expansion Example
#
# Demonstrates thermo-mechanical coupling: a uniform temperature increase
# causes free thermal expansion of a 3D box with fixed bottom.
#
# Material: E=10 GPa, nu=0.25, rho=2650 kg/m^3
# Thermal: kappa=3 W/(m*K), Cp=800 J/(kg*K), alpha_T=1e-5 1/K
# Heating: uniform dT = 100 K above T_ref = 293 K
# Expected: uz_top = alpha_T * dT * Lz = 1e-5 * 100 * 1 = 1e-3 m

[SIMULATION]
name = thermal_expansion_example
start_time = 0.0
end_time = 1.0
dt_initial = 1.0
dt_min = 0.1
dt_max = 1.0
max_timesteps = 1
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_elastodynamics = false
enable_thermal = true

[GRID]
nx = 8
ny = 8
nz = 8
Lx = 1.0
Ly = 1.0
Lz = 1.0

[ROCK]
density = 2650.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25
thermal_conductivity = 3.0
heat_capacity = 800.0
thermal_expansion = 1.0e-5

[THERMAL]
reference_temperature = 293.0

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free
