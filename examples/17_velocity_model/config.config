# Per-Cell Material from Binary Velocity Model
#
# Demonstrates reading a 3D structured binary velocity model file
# and assigning per-cell material properties (lambda, mu, rho) to
# the unstructured FEM mesh via trilinear interpolation.
#
# The velocity model is a two-layer structure:
#   Top half:    Vp=3000, Vs=1732, rho=2200 (soft sediment)
#   Bottom half: Vp=6000, Vs=3464, rho=2700 (hard basement)
#
# Generate the velocity model binary with:
#   python3 ../../scripts/generate_velocity_model.py velocity_model.bin \
#     --nx 10 --ny 10 --nz 10 --xmax 5000 --ymax 5000 --zmax 5000

[SIMULATION]
name = velocity_model_example
start_time = 0.0
end_time = 0.5
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 500
output_frequency = 50
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = false
enable_elastodynamics = true

[GRID]
nx = 10
ny = 10
nz = 10
Lx = 5000.0
Ly = 5000.0
Lz = 5000.0

[ROCK]
density = 2650.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
assignment = velocity_model
velocity_model_file = velocity_model.bin

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 1.0e-6
depth_of_burial = 2500.0
location_x = 2500.0
location_y = 2500.0
location_z = 2500.0
onset_time = 0.0
rise_time = 0.01
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[ABSORBING_BC]
enabled = false
