# Single-Phase Pressure Diffusion Example
#
# 1D pressure diffusion in a porous medium (100m x 1m x 1m).
# Dirichlet BCs: P(x=0) = 20 MPa, P(x=100) = 10 MPa.
# All other boundaries: no-flow (natural Neumann).
#
# At steady state, pressure is linear: P(x) = 20e6 - 1e5 * x
#
# Physics: single-phase Darcy flow
#   phi * ct * dP/dt = div( (k/mu) * grad(P) )
#
# Parameters:
#   phi = 0.20 (porosity)
#   k   = 100 mD (permeability)
#   mu  = 0.001 Pa*s (water viscosity)
#   ct  = 1e-9 1/Pa (total compressibility)

[SIMULATION]
name = single_phase_flow
start_time = 0.0
end_time = 200.0
dt_initial = 1.0
dt_min = 0.1
dt_max = 10.0
max_timesteps = 200
output_frequency = 50
fluid_model = SINGLE_COMPONENT
solid_model = ELASTIC
enable_geomechanics = false
enable_elastodynamics = false
enable_faults = false
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 40
ny = 1
nz = 1
Lx = 100.0
Ly = 1.0
Lz = 1.0

[ROCK]
density = 2500.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25
porosity = 0.20
permeability_x = 100.0
permeability_y = 100.0
permeability_z = 100.0

[FLUID]
water_compressibility = 1.0e-9
water_viscosity = 0.001

[BOUNDARY_CONDITIONS]
x_min = dirichlet_pressure
x_min_pressure = 20.0e6
x_max = dirichlet_pressure
x_max_pressure = 10.0e6

[ABSORBING_BC]
enabled = false
