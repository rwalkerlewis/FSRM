# ==============================================================================
# DPRK 2017-09-03 — Coupled Underground Nuclear Test at Punggye-ri
# ==============================================================================
#
# Purpose:
#   Model the 6th and largest DPRK nuclear test (2017-09-03) at the Punggye-ri
#   Nuclear Test Site under Mt. Mantap. This was a fully coupled detonation in
#   Korean Peninsula granite/syenite host rock, resulting in significant
#   mountain collapse and cavity closure.
#
# Event summary (public sources):
#   Date/time : 2017-09-03 03:30:01 UTC
#   Location  : 41.300°N, 129.076°E  (Punggye-ri Nuclear Test Site, DPRK)
#   Depth     : 760 m under Mt. Mantap
#   Yield     : ~250 kt (fully coupled, no decoupling)
#   Character : mb 6.1–6.3, Mw 5.8–6.1; strong isotropic + CLVD from collapse
#   Collapse  : InSAR/optical observations of Mt. Mantap surface collapse
#
# Coupled-test characteristics:
#   • Device fired in tunnel at 760 m depth; full coupling to host rock
#   • Cavity radius ~280 m (empirical: 55 × W^0.295 × (ρ/2650)^(-1/3.4))
#   • Mountain collapse and cavity asymmetry → significant CLVD component
#   • Spall layer at shallow depth from strong upward P-wave
#   • Tectonic release from pre-existing stress → small DC component
#
# Geology (Kim & Richards 2007; Wei 2017):
#   Mesozoic granite and syenite of the Korean Peninsula
#   Mt. Mantap: ~2200 m peak; test tunnel in competent crystalline rock
#   Regional crustal Vp = 5.6–7.0 km/s;  dense, low-porosity host
#   Post-test InSAR revealed ~0.5 m subsidence over collapse zone
#
# References:
#   Mueller & Murphy (1971) — Seismic source model for underground explosions
#   Patton (1988)           — Corner frequency scaling for nuclear tests
#   Zhao et al. (2017)      — DPRK test yield estimation from body waves
#   Kim & Richards (2007)   — Punggye-ri test site characterization
#   Yao et al. (2018)       — Source characteristics of DPRK nuclear tests
#   Wei (2017)              — InSAR observations of Mt. Mantap collapse
# ==============================================================================

[SIMULATION]
name = dprk_2017_punggye_ri_coupled_granite
description = Coupled 250 kt underground nuclear test at Punggye-ri (2017-09-03)

start_time = 0.0
end_time = 60.0                      # 60 s — captures regional phases to ~500 km

dt_initial = 2.0e-6
dt_min = 1.0e-8
dt_max = 0.02
max_timesteps = 600000

adaptive_dt = true
cfl_number = 0.4

output_frequency = 200
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 20000

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = true
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = true
gpu_mode = CPU_FALLBACK
gpu_device_id = 0
gpu_verbose = true

# ==============================================================================
# Explosion Source (coupled in granite under Mt. Mantap)
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

# Yield from Zhao et al. (2017) and subsequent body-wave analyses
yield_kt = 250.0

# Depth of burial — tunnel under Mt. Mantap (Wei 2017 InSAR)
depth_of_burial = 760.0              # m
location_x = 40000.0                  # centre of domain (80 km × 80 km)
location_y = 40000.0
location_z = -760.0

# ── Cavity radius (empirical scaling) ──
# R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)  for coupled shot in hard rock
# For 250 kt, ρ=2700:  R_c ≈ 280 m
cavity_radius = 280.0
cavity_radius_scaling = OVERRIDE      # explicit from empirical formula

# Damage zones — coupled shot: full energy couples to rock
crushed_zone_radius = 700.0           # ~2.5× cavity
fractured_zone_radius = 1400.0        # ~5× cavity
damaged_zone_radius = 2800.0          # ~10× cavity

# ── Mueller-Murphy seismic source ──
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
# Corner frequency: fc ≈ 2.5 × W^(-1/3) ≈ 0.40 Hz for 250 kt
rise_time = 0.08                      # 80 ms — appropriate for 250 kt
overshoot_factor = 1.2                # strong overshoot from coupled shot

# ── Moment tensor ──
# Coupled shot with mountain collapse: significant non-isotropic components
# Isotropic from explosion; CLVD from cavity asymmetry/collapse; DC from tectonic
isotropic_fraction = 0.70             # explosion component
clvd_fraction = 0.20                  # mountain collapse / cavity asymmetry
double_couple_fraction = 0.10         # tectonic release (Yao et al. 2018)

# Scalar moment: 10^(17 + log10(250)) ≈ 2.5×10^19 N·m for coupled 250 kt
scalar_moment = 2.5e19

# Spall from strong upward P-wave at shallow depth (Wei 2017)
enable_spall = true
spall_depth = 200.0                   # m
spall_velocity = 5.0                  # m/s

# ==============================================================================
# Grid
# ==============================================================================
[GRID]
nx = 200
ny = 200
nz = 100

Lx = 80000.0                         # 80 km × 80 km × 30 km domain
Ly = 80000.0
Lz = 30000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# ── Geographic context (for coordinate-aware post-processing) ──
input_crs = EPSG:4326
model_crs = EPSG:32652               # UTM Zone 52N (covers Punggye-ri)
use_local_coordinates = true
local_origin_x = 129.076              # Event longitude (°E)
local_origin_y = 41.300                # Event latitude  (°N)
local_origin_z = 0.0

# ── Adaptive mesh refinement around source ──
[amr]
enabled = true
method = plex_refine

[amr.criterion]
type = feature
feature_type = explosion_source

[amr.limits]
max_refinement_level = 3
max_cells = 4000000
min_cell_size = 15.0                  # fine cells near source

[amr.features.explosion_source]
x = 40000.0
y = 40000.0
z = 760.0
radius = 3500.0
level = 3

# ==============================================================================
# Material Properties — Korean Peninsula Granite/Syenite
# ==============================================================================
# Values from Kim & Richards (2007) and regional crustal studies.
# Mesozoic granite/syenite: dense, low porosity, competent host rock.

[ROCK]
name = PUNGGYE_RI_GRANITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 52.0e9               # 52 GPa  (typical Korean Peninsula granite)
poisson_ratio = 0.25
density = 2700.0                      # kg/m³

p_wave_velocity = 5600.0              # m/s  (granite/syenite, measured)
s_wave_velocity = 3250.0              # m/s

# Attenuation — moderate Q for crystalline basement
quality_factor_p = 350.0
quality_factor_s = 175.0

# Drucker-Prager plasticity for near-source damage
failure_criterion = DRUCKER_PRAGER
cohesion = 28.0e6                     # 28 MPa  (competent granite)
friction_angle = 34.0
dilation_angle = 10.0
tensile_strength = 10.0e6             # 10 MPa

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.01                       # low
compressibility = 4.0e-11

permeability_x = 1.0e-18              # m²  (tight intact granite)
permeability_y = 1.0e-18
permeability_z = 1.0e-18

thermal_conductivity = 2.8            # W/m·K  (granite)
specific_heat = 790.0                 # J/kg·K
thermal_expansion = 7.5e-6            # 1/K

# ==============================================================================
# Additional Crustal Layers
# ==============================================================================
# These provide context for the regional velocity model used in post-processing
# synthetic-seismogram generation.  The FSRM near-field solver uses the primary
# [ROCK] section; layers here are for reference / future multi-layer runs.

[ROCK_UPPER_CRUST]
name = Upper_Crust
constitutive_model = ELASTIC
youngs_modulus = 58.0e9
poisson_ratio = 0.26
density = 2800.0
p_wave_velocity = 6100.0
s_wave_velocity = 3550.0
quality_factor_p = 500.0
quality_factor_s = 250.0

[ROCK_MIDDLE_CRUST]
name = Middle_Crust
constitutive_model = ELASTIC
youngs_modulus = 76.0e9
poisson_ratio = 0.26
density = 2900.0
p_wave_velocity = 6500.0
s_wave_velocity = 3750.0
quality_factor_p = 600.0
quality_factor_s = 300.0

[ROCK_LOWER_CRUST]
name = Lower_Crust
constitutive_model = ELASTIC
youngs_modulus = 105.0e9
poisson_ratio = 0.27
density = 3100.0
p_wave_velocity = 7000.0
s_wave_velocity = 4050.0
quality_factor_p = 700.0
quality_factor_s = 350.0

[ROCK_UPPER_MANTLE]
name = Upper_Mantle
constitutive_model = ELASTIC
youngs_modulus = 185.0e9
poisson_ratio = 0.28
density = 3350.0
p_wave_velocity = 8050.0
s_wave_velocity = 4550.0
quality_factor_p = 1000.0
quality_factor_s = 500.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

[IC3]
field = STRESS
distribution = LITHOSTATIC
surface_stress = 0.0
density = 2700.0
gravity = 9.81

[IC4]
field = TEMPERATURE
distribution = GRADIENT
value = 288.15                        # 15 °C surface (temperate)
gradient = 0.0, 0.0, 0.025            # 25 K/km — typical continental geotherm

# ==============================================================================
# Boundary Conditions
# ==============================================================================
[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN, XMAX, YMIN, YMAX, ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 16
pml_strength = 90.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Placed at azimuths / scaled distances matching real IMS / IRIS stations.
# The near-field domain (80 km) cannot hold the true 370–1130 km offsets,
# so stations are placed at model-edge distances preserving azimuth.

[SEISMOMETERS]
enabled = true
output_dir = output/dprk_2017_punggye_ri_coupled_granite/seismograms
formats = SAC,MSEED
start_time_utc = 2017-09-03T03:30:01Z
default_sample_rate_hz = 100.0
default_quantity = VELOCITY

# IC.MDJ — Mudanjiang, China (~370 km, az ~350° N)
[SEISMOMETER_MDJ]
net = IC
sta = MDJ
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 40000.0, 77000.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# KS.KSRS — KSRS Array, S. Korea (~520 km, az ~180° S)
[SEISMOMETER_KSRS]
net = KS
sta = KSRS
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 40000.0, 3000.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# KG.INCN — Incheon, S. Korea (~460 km, az ~230° SW)
[SEISMOMETER_INCN]
net = KG
sta = INCN
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 23000.0, 21000.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# IC.BJT — Baijiatuan, China (~1130 km, az ~270° W)
[SEISMOMETER_BJT]
net = IC
sta = BJT
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 3000.0, 40000.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# ==============================================================================
# Receivers (radial line for near-field analysis)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 200.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 40000.0, 40000.0, 0.0
end = 79000.0, 40000.0, 0.0
num_stations = 20
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/dprk_2017_punggye_ri_coupled_granite

save_displacement = true
save_velocity = true
save_stress = true
save_damage = true
save_temperature = true

volume_output_frequency = 1000
surface_output = true
surface_output_frequency = 200

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
compute_damage_volume = true
damage_threshold = 0.1
