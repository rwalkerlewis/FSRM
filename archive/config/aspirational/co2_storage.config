# CO2 Geological Storage Configuration
# Deep saline aquifer with CO2 injection

[SIMULATION]
start_time = 0.0
end_time = 946080000.0                # 30 years (injection + monitoring)
dt_initial = 86400.0                  # 1 day
dt_min = 3600.0
dt_max = 2592000.0                    # 30 days
max_timesteps = 10000

output_frequency = 50
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 100

rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 80
max_linear_iterations = 3000

fluid_model = COMPOSITIONAL           # CO2-brine system
solid_model = POROELASTIC

enable_geomechanics = true            # Pressure buildup effects
enable_thermal = true                 # Joule-Thomson cooling
enable_fractures = false
enable_particle_transport = false
enable_faults = false                 # Ensure no leakage paths
enable_tidal_forces = false
adaptive_timestepping = true

[GRID]
nx = 50
ny = 50
nz = 20

# Storage formation: 5 km x 5 km x 200 m
Lx = 5000.0
Ly = 5000.0
Lz = 200.0

use_unstructured = false

[ROCK]
# Deep saline aquifer - sandstone
porosity = 0.15                       # Good porosity (15%)
permeability_x = 200.0                # 200 mD (good permeability)
permeability_y = 200.0
permeability_z = 100.0                # Some anisotropy

compressibility = 4.0e-10             # 1/Pa

# Mechanical properties - sandstone
youngs_modulus = 15.0e9               # 15 GPa
poisson_ratio = 0.20
density = 2400.0                      # kg/m³
biot_coefficient = 0.9                # High coupling

# No viscoelasticity for sandstone
relaxation_time = 1.0e10
viscosity = 1.0e25

# Thermal properties
thermal_conductivity = 2.0            # W/(m·K)
heat_capacity = 850.0                 # J/(kg·K)
thermal_expansion = 1.2e-5            # 1/K

# Fracture properties (avoid fracturing)
fracture_toughness = 1.2e6            # Pa·m^0.5
fracture_energy = 120.0               # J/m²

[FLUID]
# Brine properties (resident fluid)
density = 1100.0                      # kg/m³ (saline water)
viscosity = 0.0008                    # Pa·s (0.8 cP at depth/temp)
compressibility = 4.0e-10             # 1/Pa

# Not using standard black oil
oil_density_std = 1100.0
gas_density_std = 700.0               # CO2 at supercritical conditions
water_density_std = 1100.0

oil_viscosity = 0.0008
gas_viscosity = 0.00005               # Supercritical CO2 less viscous
water_viscosity = 0.0008

solution_GOR = 50.0                   # CO2 solubility in brine

# Compositional properties: H2O, CO2, NaCl
component_mw = 18.015, 44.01, 58.44   # g/mol
component_Tc = 647.1, 304.2, 3400.0   # K (NaCl approx)
component_Pc = 22.06e6, 7.38e6, 25.0e6 # Pa
component_omega = 0.344, 0.225, 0.0   # Acentric factor

# Relative permeability (Corey model for CO2-brine)
water_residual_saturation = 0.20      # Swc/Swr
co2_residual_saturation = 0.05        # Sgr (critical gas saturation)
corey_exponent_water = 4.0            # Water Corey exponent
corey_exponent_co2 = 2.0              # CO2 Corey exponent
kr_max_water = 1.0                    # Max water relative permeability
kr_max_co2 = 1.0                      # Max CO2 relative permeability

# Brine salinity
salinity = 0.035                      # NaCl mass fraction (3.5 wt%)

[CO2]
# CO2 equation of state configuration
eos_model = SPAN_WAGNER               # Span-Wagner (1996) EOS for density
viscosity_model = FENGHOUR            # Fenghour et al. (1998) viscosity
conductivity_model = VESOVIC          # Vesovic et al. (1990) thermal conductivity
solubility_model = DUAN_SUN           # Duan-Sun (2003) CO2 solubility in brine
mutual_solubility_model = SPYCHER_PRUESS  # Spycher-Pruess (2005) mutual solubility
flash_model = RACHFORD_RICE           # Rachford-Rice iteration for phase split

# CO2 injection parameters
injection_rate = 1.0e6                # kg/year (1 Mt/year)
injection_temperature = 313.15        # K (40°C)
injection_well_x = 2500.0             # m (center of domain)
injection_well_y = 2500.0             # m (center of domain)
injection_depth = 100.0               # m (middle of formation)

[TRAPPING]
# CO2 trapping mechanism configuration
enable_structural_trapping = true     # Via flow solver + BCs
enable_residual_trapping = true       # Land (1968) model
enable_solubility_trapping = true     # CO2 dissolution in brine
enable_mineral_trapping = true        # Geochemical reactions

# Residual trapping parameters
land_coefficient = 2.0                # Land trapping coefficient C
enable_hysteretic_relperm = true      # Killough (1976) scanning curves

# Mineral trapping parameters (operator-split)
mineral_trapping_timestep = 31536000.0  # Operator splitting dt: 1 year [s]
initial_calcite_fraction = 0.02       # Volume fraction
initial_feldspar_fraction = 0.15      # Volume fraction
initial_chlorite_fraction = 0.05      # Volume fraction
initial_pH = 6.5                      # Initial brine pH

[CAPROCK]
# Caprock integrity assessment
caprock_permeability = 1.0e-20        # m² (very low - shale seal)
permeability_sensitivity = 1.0e-7     # γ coefficient [1/Pa]
failure_enhancement = 1000.0          # Permeability multiplier at failure
cohesion = 5.0e6                      # Pa (caprock shale)
friction_angle = 30.0                 # degrees
enable_fault_reactivation = true      # Monitor Coulomb failure stress
max_injection_pressure_fraction = 0.9 # Fraction of fracture pressure

[SOLVER]
# Solver configuration for CCS multiphase flow
formulation = FULLY_IMPLICIT          # Newton on all primary variables
preconditioner = CPR                  # Constrained Pressure Residual
cpr_first_stage = GAMG                # AMG on pressure block
cpr_second_stage = ILU                # ILU on full system
time_integration = BACKWARD_EULER     # TSBEULER (robust for multiphase)
