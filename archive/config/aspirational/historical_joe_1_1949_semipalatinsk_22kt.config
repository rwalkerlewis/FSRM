# ==============================================================================
# Historical: Joe-1 / RDS-1 (1949) -- First Soviet Nuclear Test
# ==============================================================================
#
# Purpose:
#   Model the first Soviet nuclear test, known in the West as "Joe-1" and
#   designated RDS-1 (Reaktivnyi Dvigatel Spetsialnyi) by the Soviet program.
#   This was a surface burst at the Semipalatinsk Test Site (Polygon) in
#   Kazakhstan on August 29, 1949. The device was a near-copy of the US
#   Fat Man implosion design.
#
# Event summary (public sources):
#   Date/time : 1949-08-29 06:00:00 UTC (approximately)
#   Location  : 50.07N, 78.43E (Semipalatinsk-21, Kazakhstan)
#   Yield     : approximately 22 kt (tower shot at 30 m height)
#   Character : surface burst from 30 m steel tower; implosion device;
#               plutonium core (Pu-239)
#
# Historical significance:
#   RDS-1 ended the US nuclear monopoly and began the nuclear arms race.
#   It was detected by a US Air Force WB-29 sampling aircraft on September 3,
#   1949, confirming the detonation through radiochemical analysis of air
#   samples collected over the North Pacific. President Truman announced the
#   Soviet test on September 23, 1949. The test site at Semipalatinsk
#   (Polygon) was used for 456 nuclear tests from 1949 to 1989, causing
#   severe environmental contamination and health effects in the surrounding
#   population.
#
# Geology:
#   The test site is in the semi-arid steppe of northeastern Kazakhstan, on
#   the left bank of the Irtysh River. The surface geology consists of
#   Quaternary alluvial and aeolian deposits overlying Paleozoic
#   metasediments and granitic basement. The test tower was erected on
#   relatively flat terrain at approximately 200 m elevation.
#
# Physics exercised:
#   This is a SURFACE BURST configuration. Unlike underground tests, it
#   exercises:
#   - Atmospheric fireball formation and thermal radiation
#   - Blast wave propagation through the atmosphere
#   - Ground shock coupling from a surface burst
#   - Crater formation from ground-coupled airblast
#   - Early fallout generation and transport
#   - Thermal pulse effects on the surface
#
# References:
#   Holloway (1994) -- "Stalin and the Bomb"
#   Cochran et al. (1989) -- "Soviet Nuclear Weapons" (NRDC)
#   Glasstone & Dolan (1977) -- "The Effects of Nuclear Weapons" (3rd ed.)
#   Mikhailov (1999) -- "Catalog of Worldwide Nuclear Testing"
# ==============================================================================

[SIMULATION]
name = historical_joe1_1949_semipalatinsk_22kt
description = First Soviet nuclear test, Semipalatinsk surface burst (1949-08-29)

start_time = 0.0
end_time = 600.0                      # 10 min for blast + early fallout

dt_initial = 1.0e-6
dt_min = 1.0e-8
dt_max = 0.1
max_timesteps = 5000000

adaptive_dt = true
cfl_number = 0.3

output_frequency = 500
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 50000

# Surface burst physics -- atmospheric + ground coupling
fluid_model = COMPRESSIBLE_EULER
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = true
enable_fractures = false
enable_plasticity = true

# Atmospheric blast modeling
enable_atmospheric = true
enable_fireball = true
enable_fallout = true
enable_radiation_transport = false    # simplified; no full rad transport

use_discontinuous_galerkin = true
dg_order = 2                          # lower order for multi-physics stability
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source -- Surface Burst (30 m tower)
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_ATMOSPHERIC

yield_kt = 22.0                      # approximately 22 kt

# Tower shot at 30 m height of burst (HOB)
height_of_burst = 30.0               # m above ground surface
depth_of_burial = 0.0                # surface burst, not underground
location_x = 15000.0                 # centre of 30 km x 30 km domain
location_y = 15000.0
location_z = 30.0                    # 30 m above ground (tower height)

# Source model
source_model = POINT_SOURCE
source_time_function = NUCLEAR_ATMOSPHERIC

# Rise time for atmospheric detonation
rise_time = 0.001                    # 1 ms (very fast for atmospheric)

# No cavity in the underground sense; crater is formed by ground coupling
enable_crater = true

# ==============================================================================
# Fireball
# ==============================================================================
[FIREBALL]
enabled = true

# Fireball parameters for 22 kt surface burst (Glasstone & Dolan scaling)
# Maximum fireball radius: R_max ~ 70 * W^0.4 m for W in kt
# 70 * 22^0.4 ~ 70 * 3.53 ~ 247 m
max_radius = 250.0                   # m
initial_temperature = 3.0e7          # K (approximately 30 million K peak)
rise_velocity = 30.0                 # m/s initial buoyant rise

# Surface burst fireball touches ground -- enhanced local fallout
ground_contact = true
ground_contact_duration = 5.0        # s

# ==============================================================================
# Atmospheric Blast Wave
# ==============================================================================
[ATMOSPHERIC_BLAST]
enabled = true
model = BRODE                        # Brode (1959) blast wave model

# Ambient conditions (Semipalatinsk steppe, late August, early morning)
ambient_pressure = 101325.0          # Pa
ambient_temperature = 288.0          # K (~15 C at 0600 local)
ambient_density = 1.225              # kg/m3

# Peak overpressure at 1 km: approximately 35 kPa for 22 kt surface burst
# Blast wave Mach number initially >> 1

# Reflection factor for surface burst (enhanced by ground reflection)
surface_reflection_factor = 1.8

# ==============================================================================
# Ground Coupling and Crater Formation
# ==============================================================================
[GROUND_COUPLING]
enabled = true
model = SURFACE_BURST

# Crater scaling for 22 kt surface burst (Glasstone & Dolan)
# Apparent crater radius: R ~ 18 * W^(1/3) m for W in kt at optimum HOB
# 18 * 22^(1/3) ~ 18 * 2.80 ~ 50 m
# Apparent crater depth: D ~ 6 * W^(1/3) m
# 6 * 2.80 ~ 17 m
# 30 m HOB is below optimum for cratering so expect a modest crater
estimated_crater_radius = 50.0       # m
estimated_crater_depth = 17.0        # m

# Ground shock coupling efficiency for surface burst is low (~5-10%)
ground_coupling_efficiency = 0.07    # 7% of yield couples into ground

# Equivalent ground-coupled yield: 22 * 0.07 ~ 1.5 kt
# This drives the seismic signal

# ==============================================================================
# Fallout (Early/Local)
# ==============================================================================
[FALLOUT]
enabled = true
model = SIMPLIFIED_GAUSSIAN

# Surface burst produces heavy local fallout (fireball contacts ground,
# entrains soil into the rising cloud, forms large radioactive particles)
# Total activity: fission products from ~22 kt of fission yield

# Wind conditions (approximate for Semipalatinsk in late August)
wind_speed_surface = 5.0             # m/s
wind_direction_surface = 270.0       # degrees (blowing eastward)
wind_speed_upper = 15.0              # m/s (upper-level winds)
wind_direction_upper = 250.0         # degrees

# Cloud parameters (Glasstone & Dolan scaling for 22 kt)
# Stabilized cloud top: H ~ 3000 * W^0.2 m for W in kt
# 3000 * 22^0.2 ~ 3000 * 1.82 ~ 5460 m
cloud_top_height = 5500.0            # m
cloud_bottom_height = 2500.0         # m
cloud_radius = 1500.0                # m (stabilized)

# Fallout particle size distribution
# Surface bursts produce large particles that fall out quickly
median_particle_diameter = 200.0e-6  # 200 micrometres
particle_density = 2600.0            # kg/m3 (entrained soil)

# ==============================================================================
# Grid
# ==============================================================================
[GRID]
nx = 100
ny = 100
nz = 80                              # extra vertical resolution for atmosphere

Lx = 30000.0                        # 30 km x 30 km x 15 km domain
Ly = 30000.0
Lz = 15000.0                        # includes atmospheric layer

origin_x = 0.0
origin_y = 0.0
origin_z = -5000.0                   # 5 km below surface + 10 km atmosphere

use_unstructured = false

# Geographic context (Semipalatinsk Test Site, Kazakhstan)
input_crs = EPSG:4326
model_crs = EPSG:32643              # UTM Zone 43N (Kazakhstan)
use_local_coordinates = true
local_origin_x = 78.43              # Approximate longitude
local_origin_y = 50.07              # Approximate latitude
local_origin_z = 200.0              # Approximate site elevation (m ASL)

# Adaptive mesh refinement
[amr]
enabled = true
method = plex_refine

[amr.criterion]
type = feature
feature_type = explosion_source

[amr.limits]
max_refinement_level = 3
max_cells = 3000000
min_cell_size = 10.0

[amr.features.explosion_source]
x = 15000.0
y = 15000.0
z = 30.0
radius = 2000.0                      # refine around blast centre
level = 3

# ==============================================================================
# Atmosphere (required for surface burst)
# ==============================================================================
[ATMOSPHERE]
model = STANDARD_ATMOSPHERE
ground_elevation = 200.0             # m ASL (Semipalatinsk steppe)
max_altitude = 10000.0               # m above ground

# Layers (simplified standard atmosphere adapted for continental Kazakhstan)
[ATMOSPHERE.SURFACE]
height = 0.0
temperature = 288.0                  # K
pressure = 101325.0                  # Pa
density = 1.225                      # kg/m3

[ATMOSPHERE.TROPOPAUSE]
height = 10000.0
temperature = 220.0                  # K
pressure = 26500.0                   # Pa
density = 0.414                      # kg/m3

# ==============================================================================
# Material Properties -- Semipalatinsk Surface Geology
# ==============================================================================
# Surface layer: Quaternary alluvium and aeolian deposits overlying
# Paleozoic metasedimentary and granitic basement. Values typical of
# semi-consolidated steppe sediments.

[ROCK]
name = SEMIPALATINSK_ALLUVIUM
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 2.0e9               # 2 GPa (weak alluvium/loess)
poisson_ratio = 0.35
density = 1800.0                     # kg/m3 (loose alluvial/aeolian)

p_wave_velocity = 1500.0             # m/s (near-surface sediment)
s_wave_velocity = 400.0              # m/s

quality_factor_p = 30.0
quality_factor_s = 15.0

# Drucker-Prager plasticity (weak surface material -- easily cratered)
failure_criterion = DRUCKER_PRAGER
cohesion = 0.5e6                     # 0.5 MPa (loose sediment)
friction_angle = 28.0
dilation_angle = 5.0
tensile_strength = 0.1e6             # 0.1 MPa

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.30                      # high porosity alluvium
compressibility = 1.0e-9

permeability_x = 1.0e-13             # m2 (permeable alluvium)
permeability_y = 1.0e-13
permeability_z = 1.0e-13

thermal_conductivity = 1.2           # W/m*K (dry sediment)
specific_heat = 850.0                # J/kg*K
thermal_expansion = 10.0e-6          # 1/K

# ==============================================================================
# Underlying Basement (below alluvium, approximately 50 m depth)
# ==============================================================================
[ROCK_BASEMENT]
name = SEMIPALATINSK_Paleozoic_Basement
constitutive_model = ELASTIC
youngs_modulus = 45.0e9              # 45 GPa (metasediment/granite)
poisson_ratio = 0.25
density = 2650.0                     # kg/m3
p_wave_velocity = 5500.0             # m/s
s_wave_velocity = 3200.0             # m/s
quality_factor_p = 250.0
quality_factor_s = 120.0

# ==============================================================================
# Thermal
# ==============================================================================
[THERMAL]
initial_temperature_surface = 288.0  # K
geothermal_gradient = 0.025          # 25 deg C/km

enable_thermal_stress = true

# Surface thermal pulse from fireball
# 22 kt at 1 km: thermal fluence ~ 42 cal/cm2 (Glasstone & Dolan)
surface_thermal_fluence = 1.76e6     # J/m2 at 1 km (converted from cal/cm2)
thermal_pulse_duration = 3.0         # s (total thermal pulse)

# ==============================================================================
# Fluid (atmosphere is the primary fluid domain)
# ==============================================================================
[FLUID]
type = COMPRESSIBLE_IDEAL_GAS
gamma = 1.4                          # ratio of specific heats for air
molecular_weight = 0.029             # kg/mol (air)
gas_constant = 287.0                 # J/kg*K (specific gas constant for air)

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/historical_joe1_1949
frequency = 500
pressure = true
displacement = true
velocity = true
stress = true
damage = true
temperature = true
density = true

# Overpressure recording stations (radial from ground zero)
[OUTPUT.BLAST_GAUGES]
enabled = true
format = CSV

# Radial distances from ground zero
gauge_1 = GZ_500m   15500.0  15000.0  200.0   # 500 m from GZ
gauge_2 = GZ_1km    16000.0  15000.0  200.0   # 1 km
gauge_3 = GZ_2km    17000.0  15000.0  200.0   # 2 km
gauge_4 = GZ_5km    20000.0  15000.0  200.0   # 5 km
gauge_5 = GZ_10km   25000.0  15000.0  200.0   # 10 km
