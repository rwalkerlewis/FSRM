# ==============================================================================
# Historical: Operation Julin -- Divider (1992) -- Last US Underground Nuclear Test
# ==============================================================================
#
# Purpose:
#   Model the last underground nuclear test conducted by the United States.
#   Operation Julin, shot "Divider", was fired on September 23, 1992 at the
#   Nevada Test Site (NTS), Area 7, Yucca Flat. This was a tunnel shot in
#   Paleozoic dolomite and quartzite host rock.
#
# Event summary (public sources):
#   Date/time : 1992-09-23 15:04:00 UTC
#   Location  : 37.07N, 116.02W (NTS Area 7, Yucca Flat, Nevada)
#   Depth     : approximately 250 m (tunnel shot)
#   Yield     : less than 20 kt (exact yield classified; 10 kt used as nominal)
#   Character : weapons effects test; last event in US nuclear testing program
#
# Historical significance:
#   Divider was the final US underground nuclear test. It was followed by the
#   US moratorium on nuclear testing announced by President George H.W. Bush
#   in October 1992, which led to the Comprehensive Nuclear-Test-Ban Treaty
#   (CTBT) opened for signature in 1996. The US conducted a total of 1,032
#   nuclear tests from 1945 to 1992.
#
# Geology:
#   NTS Area 7 lies in the southern Yucca Flat basin. The test was conducted
#   in Paleozoic dolomite and quartzite formations overlain by Tertiary volcanic
#   tuff and alluvium. These carbonate rocks are dense, competent, and
#   relatively uniform -- providing good coupling for seismic waves.
#
# Physics exercised:
#   - Elastoplastic wave propagation in dolomite/quartzite host rock
#   - Mueller-Murphy source model for a moderate-yield tunnel shot
#   - Cavity formation and damage zone evolution
#   - Spall from upward P-wave reflection at the free surface
#
# References:
#   DOE/NV-209 (Rev. 16) -- United States Nuclear Tests, 1945-1992
#   Springer et al. (2002) -- Seismic source characteristics of NTS explosions
#   Mueller & Murphy (1971) -- Seismic characteristics of underground detonations
# ==============================================================================

[SIMULATION]
name = historical_divider_1992_tunnel_coupled
description = Last US underground nuclear test, NTS Area 7 Yucca Flat (1992-09-23)

start_time = 0.0
end_time = 30.0                      # 30 s for near-field + initial regional phases

dt_initial = 1.0e-5
dt_min = 1.0e-7
dt_max = 0.01
max_timesteps = 500000

adaptive_dt = true
cfl_number = 0.4

output_frequency = 100
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 10000

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = false
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

# Yield classified as "less than 20 kt"; 10 kt used as nominal estimate
yield_kt = 10.0

# Tunnel shot at approximately 250 m depth in Area 7
depth_of_burial = 250.0              # m
location_x = 20000.0                 # centre of 40 km x 40 km domain
location_y = 20000.0
location_z = -250.0

# Cavity radius (empirical scaling)
# R_c = 55 * W^0.295 * (rho/2650)^(-1/3.4) for 10 kt, rho=2700: ~86 m
cavity_radius = 86.0
cavity_radius_scaling = OVERRIDE

# Damage zones
crushed_zone_radius = 215.0          # ~2.5x cavity
fractured_zone_radius = 430.0        # ~5x cavity
damaged_zone_radius = 860.0          # ~10x cavity

# Mueller-Murphy source model
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
# Corner frequency: fc ~ 2.5 * 10^(-1/3) ~ 1.16 Hz
rise_time = 0.03                     # 30 ms for 10 kt
overshoot_factor = 1.1

# Moment tensor -- clean coupled explosion with minimal tectonic release
isotropic_fraction = 0.90
clvd_fraction = 0.05
double_couple_fraction = 0.05

# Scalar moment: 10^(17 + log10(10)) = 10^18 N*m
scalar_moment = 1.0e18

# Spall
enable_spall = true
spall_depth = 100.0                  # m
spall_velocity = 2.0                 # m/s

# ==============================================================================
# Grid
# ==============================================================================
[GRID]
nx = 100
ny = 100
nz = 60

Lx = 40000.0                        # 40 km x 40 km x 15 km domain
Ly = 40000.0
Lz = 15000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic context
input_crs = EPSG:4326
model_crs = EPSG:32611              # UTM Zone 11N (Nevada)
use_local_coordinates = true
local_origin_x = -116.02            # Approximate longitude
local_origin_y = 37.07              # Approximate latitude
local_origin_z = 0.0

# Adaptive mesh refinement around source
[amr]
enabled = true
method = plex_refine

[amr.criterion]
type = feature
feature_type = explosion_source

[amr.limits]
max_refinement_level = 2
max_cells = 2000000
min_cell_size = 20.0

[amr.features.explosion_source]
x = 20000.0
y = 20000.0
z = 250.0
radius = 1500.0
level = 2

# ==============================================================================
# Material Properties -- Paleozoic Dolomite/Quartzite (NTS Area 7)
# ==============================================================================
# NTS Area 7 host rock is primarily Paleozoic dolomite and quartzite. These
# are dense, competent carbonate and siliciite formations with moderate to
# high seismic velocities. Values from Springer et al. (2002) and regional
# NTS characterization studies.

[ROCK]
name = NTS_DOLOMITE_QUARTZITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 60.0e9              # 60 GPa (competent carbonate/quartzite)
poisson_ratio = 0.26
density = 2700.0                     # kg/m3

p_wave_velocity = 5800.0             # m/s
s_wave_velocity = 3300.0             # m/s

quality_factor_p = 300.0
quality_factor_s = 150.0

# Drucker-Prager plasticity
failure_criterion = DRUCKER_PRAGER
cohesion = 25.0e6                    # 25 MPa (dolomite)
friction_angle = 35.0
dilation_angle = 10.0
tensile_strength = 8.0e6             # 8 MPa

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.03
compressibility = 3.0e-11

permeability_x = 5.0e-18             # m2 (tight carbonate)
permeability_y = 5.0e-18
permeability_z = 5.0e-18

thermal_conductivity = 3.5           # W/m*K (dolomite)
specific_heat = 880.0                # J/kg*K
thermal_expansion = 8.0e-6           # 1/K

# ==============================================================================
# Overlying Tertiary Tuff (encountered in Area 7 above dolomite)
# ==============================================================================
[ROCK_TUFF_OVERBURDEN]
name = NTS_Tertiary_Tuff
constitutive_model = ELASTIC
youngs_modulus = 8.0e9               # 8 GPa (welded tuff)
poisson_ratio = 0.30
density = 2100.0                     # kg/m3
p_wave_velocity = 3800.0             # m/s
s_wave_velocity = 2100.0             # m/s
quality_factor_p = 100.0
quality_factor_s = 50.0

# ==============================================================================
# Fluid -- not primary for this configuration
# ==============================================================================
[FLUID]
type = SINGLE_PHASE
density = 1000.0                     # kg/m3
viscosity = 1.0                      # cP
compressibility = 4.5e-10            # 1/Pa

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/historical_divider_1992
frequency = 100
pressure = true
displacement = true
velocity = true
stress = true
damage = true
