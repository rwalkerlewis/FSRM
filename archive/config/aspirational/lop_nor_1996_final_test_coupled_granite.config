# ==============================================================================
# Lop Nor 1996-07-29 — Last Confirmed Chinese Underground Nuclear Test
# ==============================================================================
#
# Purpose:
#   Model the final Chinese underground nuclear test at the Lop Nor test site
#   using FSRM's ADER-DG wave propagation solver. This config uses
#   COUPLED_ANALYTIC mode: the Mueller-Murphy Reduced Displacement Potential
#   is applied as the source time function and the wavefield is numerically
#   propagated through a 1-D layered Kuruktag / Tarim Basin crustal model.
#
# Why use a far-field linear-elastic approach?
#   All recording stations (KNDC archive) are at regional distances (761–1531 km).
#   At these ranges the wavefield is linear-elastic, so a near-field nonlinear
#   config with damage zones is unnecessary.  The COUPLED_ANALYTIC mode injects
#   the analytical Mueller-Murphy RDP as equivalent body forces, avoiding the
#   expensive near-source plasticity computation.
#
# Yield estimation:
#   mb = 4.90 (ISC).  Using the Lop Nor network mb-yield relation
#   mb = 4.262 + 0.973 * log10(Y_kt)  (Ringdal et al. 1992; Murphy 1996):
#   Y ≈ 10^((4.90 - 4.262)/0.973) ≈ 4.3 kt
#   Conservative estimate: 3–8 kt range (fully coupled in granite tunnel)
#   Best estimate used here: 5 kt
#
# Depth of burial:
#   Chinese tests at Lop Nor used horizontal tunnels in the Kuruktag mountains.
#   For a ~5 kt test, typical DOB ≈ 400 m (Zhenbang & Shangyi 1986).
#
# Event summary (public sources):
#   Date/time : 1996-07-29  01:48:57.170 UTC
#   Location  : 41.7163°N, 88.3748°E  (Lop Nor underground tunnel area)
#   Depth     : ~400 m (horizontal tunnel in Paleozoic granite)
#   Yield     : ~5 kt (fully coupled, estimated from mb 4.90)
#   Character : Impulsive P arrivals at 26 regional KNDC stations
#
# Frequency content:
#   500 m cell spacing with DG order 4 → effective ~125 m resolution per DOF
#   At Vp=5.8 km/s → max freq ~5.8 Hz; at Vs=3.4 km/s → max freq ~3.4 Hz
#   Adequate for regional seismology (0.5–4 Hz analysis band)
#
# References:
#   Mueller & Murphy (1971)  — Seismic source model for underground explosions
#   Patton (1988)            — Corner frequency scaling
#   Charlie & Veyera (1994)  — Geology of the Lop Nor test site
#   Zhenbang & Shangyi (1986)— Chinese nuclear testing practice
#   Xia et al. (2017)        — NCCrust crustal velocity model
#   Ringdal et al. (1992)    — mb-yield calibration for Lop Nor
#   Murphy (1996)            — Lop Nor yield estimation from body waves
#
# Run:
#   mpirun -np 16 fsrm -c config/lop_nor_1996_final_test_coupled_granite.config
# ==============================================================================

[SIMULATION]
name = lop_nor_1996_final_test
description = Far-field wave propagation from 1996-07-29 Lop Nor final Chinese nuclear test (~5 kt coupled)

start_time = 0.0
end_time = 60.0                      # 60 s — captures regional P+S at domain edge

# Timestep control:
#   dt_initial = 5e-5 s resolves the Mueller-Murphy source pulse (rise_time 20 ms)
#   dt_max = 0.005 s keeps CFL < 0.45 for 500 m cells at Vp = 7.9 km/s
dt_initial = 5.0e-5
dt_min = 1.0e-6
dt_max = 0.005
max_timesteps = 200000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 500
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 50000

# COUPLED_ANALYTIC mode:
#   Mueller-Murphy RDP is used as the analytical source time function.
#   Near-source nonlinear physics captured entirely by the RDP.
explosion_solve_mode = COUPLED_ANALYTIC

# Physics: pure linear elastodynamics
fluid_model = NONE
solid_model = ELASTIC
enable_elastodynamics = true
enable_geomechanics = false
enable_thermal = false
enable_fractures = false
enable_plasticity = false

# High-order DG with ADER time integration and local time stepping
use_discontinuous_galerkin = true
dg_order = 4
use_ader_time_integration = true
enable_local_time_stepping = true
lts_rate = 2

use_gpu = true
gpu_mode = CPU_FALLBACK
gpu_device_id = 0
gpu_verbose = true

# ==============================================================================
# Explosion Source — Lop Nor 1996-07-29 (Coupled ~5 kt)
# ==============================================================================

[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 5.0                       # ~5 kt (from mb 4.90, Ringdal relation)
depth_of_burial = 400.0               # m (horizontal tunnel, Kuruktag mountains)

# Source placed at center of the 200 km × 200 km domain
location_x = 100000.0
location_y = 100000.0
location_z = -400.0

# Cavity radius from empirical scaling:
#   R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)
#   For W=5 kt, ρ=2650 kg/m³ → R_c ≈ 55 × 5^0.295 ≈ 55 × 1.62 ≈ 89 m
cavity_radius = 89.0
cavity_radius_scaling = OVERRIDE

# Damage zones (for RDP parameterization only in COUPLED_ANALYTIC mode)
crushed_zone_radius = 222.0           # ~2.5× cavity
fractured_zone_radius = 445.0         # ~5× cavity
damaged_zone_radius = 890.0           # ~10× cavity

# Mueller-Murphy source model with Patton corner-frequency scaling
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION

# Rise time and overshoot:
#   For 5 kt coupled shot: rise_time ≈ 20 ms, moderate overshoot
rise_time = 0.02
overshoot_factor = 1.15

# Moment tensor — coupled shot in granite with tunnel geometry
# Some tectonic release but dominantly isotropic
isotropic_fraction = 0.85
clvd_fraction = 0.10
double_couple_fraction = 0.05

# Scalar seismic moment: M0 for coupled 5 kt
# M0 ≈ 7.0 × 10^16 N·m  (Murphy 1996 empirical)
scalar_moment = 7.0e16

# Spall parameters
enable_spall = true
spall_depth = 100.0                   # m (shallow for ~5 kt in hard granite)
spall_velocity = 2.5                  # m/s

# ==============================================================================
# Grid — Large structured domain for regional wave propagation
# ==============================================================================
# 200 km × 200 km × 60 km domain with 500 m base cell spacing.
# Source at center (100 km, 100 km), receivers at up to 100 km radial.
#
# Grid dimensions:
#   400 × 400 × 120 = 19.2 M cells
#   With DG order 4: ~2.4 billion DOFs (3-component displacement)

[GRID]
nx = 400
ny = 400
nz = 120

Lx = 200000.0                        # 200 km
Ly = 200000.0                        # 200 km
Lz = 60000.0                         # 60 km

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic reference for post-processing (Lop Nor 1996)
input_crs = EPSG:4326
model_crs = EPSG:32646               # UTM Zone 46N (covers Lop Nor)
use_local_coordinates = true
local_origin_x = 88.3748             # Event longitude (°E)
local_origin_y = 41.7163             # Event latitude  (°N)
local_origin_z = 0.0

# ==============================================================================
# Material Properties — Lop Nor 1-D Layered Crustal Model
# ==============================================================================
# Horizontally-layered 1-D velocity model for the Lop Nor / Kuruktag region.
# Derived from Xia et al. (2017) NCCrust model, Charlie & Veyera (1994), and
# regional deep seismic sounding profiles.
#
# The Lop Nor test site sits at the edge of the Kuruktag mountains, with
# Paleozoic granite / metasediments at surface.  The thick Tarim Basin crust
# (Moho at ~48 km) results in a relatively low Pn velocity (~7.9 km/s).
#
# Layer structure:
#   Layer 1:  0–3 km    Weathered granite / Paleozoic surface  Vp=5.8 Vs=3.4
#   Layer 2:  3–15 km   Upper crust (granite, metasediments)   Vp=6.1 Vs=3.55
#   Layer 3:  15–30 km  Middle crust (high-grade metamorphic)  Vp=6.45 Vs=3.70
#   Layer 4:  30–48 km  Lower crust (mafic granulite)          Vp=6.95 Vs=4.00
#   Layer 5:  48–60 km  Upper mantle (peridotite)              Vp=7.90 Vs=4.50

[ROCK_LAYER1]
name = Upper_Granite_Kuruktag
constitutive_model = ELASTIC
depth_top = 0.0
depth_bottom = 3000.0
density = 2650.0
p_wave_velocity = 5800.0
s_wave_velocity = 3400.0
youngs_modulus = 50.0e9
poisson_ratio = 0.24
quality_factor_p = 400.0
quality_factor_s = 200.0

[ROCK_LAYER2]
name = Upper_Crust_Metasediments
constitutive_model = ELASTIC
depth_top = 3000.0
depth_bottom = 15000.0
density = 2750.0
p_wave_velocity = 6100.0
s_wave_velocity = 3550.0
youngs_modulus = 56.0e9
poisson_ratio = 0.26
quality_factor_p = 500.0
quality_factor_s = 250.0

[ROCK_LAYER3]
name = Middle_Crust_Metamorphic
constitutive_model = ELASTIC
depth_top = 15000.0
depth_bottom = 30000.0
density = 2850.0
p_wave_velocity = 6450.0
s_wave_velocity = 3700.0
youngs_modulus = 72.0e9
poisson_ratio = 0.26
quality_factor_p = 600.0
quality_factor_s = 300.0

[ROCK_LAYER4]
name = Lower_Crust_Mafic_Granulite
constitutive_model = ELASTIC
depth_top = 30000.0
depth_bottom = 48000.0
density = 3050.0
p_wave_velocity = 6950.0
s_wave_velocity = 4000.0
youngs_modulus = 98.0e9
poisson_ratio = 0.27
quality_factor_p = 700.0
quality_factor_s = 350.0

[ROCK_LAYER5]
name = Upper_Mantle_Peridotite
constitutive_model = ELASTIC
depth_top = 48000.0
depth_bottom = 60000.0
density = 3300.0
p_wave_velocity = 7900.0
s_wave_velocity = 4500.0
youngs_modulus = 170.0e9
poisson_ratio = 0.28
quality_factor_p = 1000.0
quality_factor_s = 500.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

# ==============================================================================
# Boundary Conditions
# ==============================================================================
[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC3]
type = ABSORBING
location = XMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC4]
type = ABSORBING
location = YMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC5]
type = ABSORBING
location = YMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC6]
type = ABSORBING
location = ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Two arrays:
#
# (A) RADIAL ARRAY — 5 stations along +x axis at 10, 25, 50, 75, 100 km
#     for distance-dependent amplitude decay and waveform development.
#
# (B) AZIMUTHAL ARRAY — 4 stations at 75 km radial distance at azimuths
#     matching key KNDC stations that recorded the 1996 event.
#
#     Key station azimuths from Lop Nor:
#       DZHR — az ≈ 315° (NW, nearest at 761 km)
#       PRZ  — az ≈ 285° (WNW, 829 km)
#       KUR  — az ≈ 350° (NNW, 1060 km)
#       TK   — az ≈ 305° (NW, 1100 km)
#
# Source at (100000, 100000, -400).  Surface seismometers at z=0.

[SEISMOMETERS]
enabled = true
output_dir = output/lop_nor_1996_final_test/seismograms
formats = SAC,MSEED
start_time_utc = 1996-07-29T01:48:57Z
default_sample_rate_hz = 50.0
default_quantity = VELOCITY

# ── Radial Array (along +x from source, i.e. due east, az=90°) ──────────────

[SEISMOMETER_R010]
net = SY
sta = R010
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 110000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R025]
net = SY
sta = R025
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 125000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R050]
net = SY
sta = R050
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 150000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R075]
net = SY
sta = R075
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 175000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R100]
net = SY
sta = R100
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 200000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ── Azimuthal Array (at 75 km radial distance, matching KNDC stations) ──────

[SEISMOMETER_DZHR]
net = SY
sta = DZHR
loc = 00
channels = BHN,BHE,BHZ
# az=315°: dx=75*sin(315°)=-53.03 km, dy=75*cos(315°)=+53.03 km
location_xyz = 46966.0, 153033.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_PRZ]
net = SY
sta = PRZ
loc = 00
channels = BHN,BHE,BHZ
# az=285°: dx=75*sin(285°)=-72.44 km, dy=75*cos(285°)=+19.41 km
location_xyz = 27559.0, 119411.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_KUR]
net = SY
sta = KUR
loc = 00
channels = BHN,BHE,BHZ
# az=350°: dx=75*sin(350°)=-13.02 km, dy=75*cos(350°)=+73.86 km
location_xyz = 86978.0, 173862.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_TK]
net = SY
sta = TK
loc = 00
channels = BHN,BHE,BHZ
# az=305°: dx=75*sin(305°)=-61.44 km, dy=75*cos(305°)=+43.01 km
location_xyz = 38560.0, 143014.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ==============================================================================
# Receivers (radial line for near-field wavefield analysis)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 200.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 100000.0, 100000.0, 0.0
end = 200000.0, 100000.0, 0.0
num_stations = 20
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/lop_nor_1996_final_test

save_displacement = true
save_velocity = true
save_stress = true
save_damage = false
save_temperature = false

volume_output_frequency = 1000
surface_output = true
surface_output_frequency = 200

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
