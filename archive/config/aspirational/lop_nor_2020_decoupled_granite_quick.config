# ==============================================================================
# Lop Nor 2020-06-22 — Quick-Run Variant for Full-Wavefield Synthetics
# ==============================================================================
# Reduced-resolution version of lop_nor_2020_decoupled_granite.config
# designed to run on a workstation (4 cores, 16 GB RAM) in ~10 minutes.
#
# Changes from full config:
#   - Grid:     100×100×50  (500K cells vs 4M)
#   - Domain:   20 km × 20 km × 10 km  (captures near-field + ~15 km)
#   - End time: 10 s  (near-field wavefield evolution)
#   - dt_max:   0.005 s  (coarser timestep)
#   - DG order: 2  (from 3)
#   - AMR:      disabled  (save memory)
#   - Receivers: radial line only
# ==============================================================================

[SIMULATION]
name = lop_nor_2020_decoupled_granite_quick
description = Quick-run: decoupled 1 kt nuclear test, Lop Nor granite, near-field wavefield

start_time = 0.0
end_time = 5.0

# CFL-stable dt ≈ 0.45 * 200m / 5800 m/s ≈ 0.015 s
# Start near CFL limit
dt_initial = 0.005
dt_min = 1.0e-5
dt_max = 0.015
max_timesteps = 5000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 100
output_format = HDF5
enable_checkpointing = false

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = false
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 2
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 1.0
depth_of_burial = 300.0
location_x = 10000.0
location_y = 10000.0
location_z = -300.0

cavity_radius = 25.0
cavity_radius_scaling = OVERRIDE

crushed_zone_radius = 50.0
fractured_zone_radius = 120.0
damaged_zone_radius = 250.0

source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
rise_time = 0.01
overshoot_factor = 1.08

isotropic_fraction = 0.92
clvd_fraction = 0.06
double_couple_fraction = 0.02

scalar_moment = 1.4e14

enable_spall = false

# ==============================================================================
# Grid (reduced)
# ==============================================================================
[GRID]
nx = 100
ny = 100
nz = 50

Lx = 20000.0
Ly = 20000.0
Lz = 10000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

[amr]
enabled = false

# ==============================================================================
# Material — Lop Nor Granite
# ==============================================================================
[ROCK]
name = LOP_NOR_GRANITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 50.0e9
poisson_ratio = 0.25
density = 2650.0

p_wave_velocity = 5800.0
s_wave_velocity = 3400.0

quality_factor_p = 400.0
quality_factor_s = 200.0

failure_criterion = DRUCKER_PRAGER
cohesion = 30.0e6
friction_angle = 35.0
dilation_angle = 10.0
tensile_strength = 12.0e6

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.008
compressibility = 4.0e-11

permeability_x = 1.0e-19
permeability_y = 1.0e-19
permeability_z = 1.0e-19

thermal_conductivity = 2.8
specific_heat = 790.0
thermal_expansion = 7.5e-6

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

[IC3]
field = STRESS
distribution = LITHOSTATIC
surface_stress = 0.0
density = 2650.0
gravity = 9.81

# ==============================================================================
# Boundary Conditions
# ==============================================================================
[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN, XMAX, YMIN, YMAX, ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 10
pml_strength = 80.0

# ==============================================================================
# Receivers (radial line from source to domain edge)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 200.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 10000.0, 10000.0, 0.0
end = 19500.0, 10000.0, 0.0
num_stations = 20
fields = displacement, velocity, acceleration

# Second radial line at 45°
[RECEIVER_ARRAY_DIAGONAL]
type = LINE
start = 10000.0, 10000.0, 0.0
end = 16718.0, 16718.0, 0.0
num_stations = 10
fields = displacement, velocity

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/lop_nor_2020_quick

save_displacement = true
save_velocity = true
save_stress = true
save_damage = true

volume_output_frequency = 200
surface_output = true
surface_output_frequency = 100

save_cross_sections = true
cross_section_planes = XZ_Y10000, YZ_X10000
cross_section_frequency = 100

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_damage_volume = true
damage_threshold = 0.1
