# ==============================================================================
# Lop Nor 1996-07-29 — Numerical Elastic Wave Propagation
# ==============================================================================
#
# Purpose:
#   Solve the elastic wave equation numerically using FSRM's ADER-DG solver
#   to propagate seismic waves from the 1996 Chinese nuclear test source to
#   regional distances (up to 200 km), producing 3-component synthetic
#   seismograms at virtual seismometer positions.
#
#   Domain: 400 km × 400 km × 60 km  (source at center)
#   Grid:   800 × 800 × 120 cells  (Δx = Δy = Δz = 500 m)
#   Solver: ADER-DG order 4, local time stepping, PML absorbing boundaries
#
#   This config uses COUPLED_ANALYTIC mode: the Mueller-Murphy Reduced
#   Displacement Potential (RDP) is injected as equivalent body forces at the
#   source point; the resulting wavefield is then propagated numerically
#   through a 1-D layered Kuruktag/Tarim crustal model.  No nonlinear
#   damage or plasticity is computed — the near-source nonlinear physics
#   is captured entirely by the analytical RDP.
#
#   The numerical solver resolves:
#     • Crustal layering effects (Moho reflections, PmP, SmS)
#     • Head waves along velocity interfaces (Pn at 48 km, Pg at 3 km)
#     • Free-surface reflections (pP, sP, depth phases)
#     • Geometric spreading in 3-D
#     • Surface waves (Rg, Lg) — partially, depending on duration
#
#   At 200 km domain radius the solver captures Pn, Pg, Sn, and the onset
#   of Lg.  For comparison with real KNDC stations at 761–1531 km, the
#   post-processing script extrapolates using Q-corrected geometric spreading.
#
# Frequency content:
#   500 m cells, DG order 4 → 5 DOFs per direction → ~100 m resolution
#   Minimum wavelength resolved: ~500 m (5 pts/λ for DG4)
#   At Vp=5.8 km/s → f_max ≈ 5.8/0.5 ≈ 11.6 Hz (conservative: ~5 Hz)
#   At Vs=3.4 km/s → f_max ≈ 3.4/0.5 ≈ 6.8 Hz  (conservative: ~3 Hz)
#   Analysis band: 0.5–4 Hz (well within resolved range)
#
# Travel-time estimates at domain edge (200 km):
#   Pn:  200/7.9 = 25.3 s        Pg:  200/5.8 = 34.5 s
#   Sn:  200/4.5 = 44.4 s        Lg:  200/3.5 = 57.1 s
#   → 90 s end_time captures all body waves + Lg onset at 200 km
#
# Memory estimate:
#   800 × 800 × 120 = 76.8 M cells
#   With DG4 (125 DOFs/cell × 9 fields × 8 bytes) ≈ 69 GB (fields only)
#   With ghost layers + MPI buffers: ~170 GB total
#   Recommend: 32–64 MPI ranks, each with 4–8 GB
#
# Event summary:
#   Date/time : 1996-07-29  01:48:57.170 UTC
#   Location  : 41.7163°N, 88.3748°E  (Lop Nor test site, Kuruktag)
#   Depth     : ~400 m  (horizontal tunnel)
#   Yield     : ~5 kt   (fully coupled in Paleozoic granite)
#   mb        : 4.90 (ISC)
#
# Run:
#   mpirun -np 32 build/fsrm -c config/lop_nor_1996_numerical_wave_propagation.config
#
# Post-processing:
#   python scripts/run_lop_nor_1996_numerical.py
# ==============================================================================

[SIMULATION]
name = lop_nor_1996_numerical_wave_propagation
description = Numerical elastic wave propagation — 1996-07-29 Lop Nor final Chinese nuclear test (~5 kt coupled)

start_time = 0.0
end_time = 90.0                      # Captures Lg at 200 km (~57 s) with margin

# Timestep control
#   dt_max: CFL < 0.45 for 500 m cells at Vp_max = 7900 m/s
#   dt_max_cfl = 0.45 × 500 / 7900 ≈ 0.0285 s
#   Use dt_max = 0.02 s for safety margin
#   dt_initial = 5e-5 s resolves the Mueller-Murphy source pulse (rise_time 20 ms)
dt_initial = 5.0e-5
dt_min = 1.0e-6
dt_max = 0.02
max_timesteps = 500000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 1000
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 50000

# COUPLED_ANALYTIC mode: Mueller-Murphy RDP → equivalent body forces
# → numerical propagation through layered model
explosion_solve_mode = COUPLED_ANALYTIC

# Physics: pure linear elastodynamics (no plasticity, fracture, or thermal)
fluid_model = NONE
solid_model = ELASTIC
enable_elastodynamics = true
enable_geomechanics = false
enable_thermal = false
enable_fractures = false
enable_plasticity = false

# High-order DG with ADER time integration and local time stepping
use_discontinuous_galerkin = true
dg_order = 4
use_ader_time_integration = true
enable_local_time_stepping = true
lts_rate = 2

# GPU with CPU fallback
use_gpu = true
gpu_mode = CPU_FALLBACK
gpu_device_id = 0
gpu_verbose = true

# ==============================================================================
# Explosion Source — Lop Nor 1996-07-29 (Coupled ~5 kt)
# ==============================================================================

[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 5.0                       # ~5 kt from mb-yield scaling (Ringdal 1992)
depth_of_burial = 400.0               # m (horizontal tunnel, Kuruktag mountains)

# Source at center of 400 km × 400 km domain
location_x = 200000.0                # m (center)
location_y = 200000.0                # m (center)
location_z = -400.0                  # m (below free surface)

# Cavity radius: R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)
# For W=5 kt, ρ=2650 → R_c ≈ 89 m
cavity_radius = 89.0
cavity_radius_scaling = OVERRIDE

# Damage zones (RDP parameterization only)
crushed_zone_radius = 222.0
fractured_zone_radius = 445.0
damaged_zone_radius = 890.0

# Mueller-Murphy source
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION

# Rise time for 5 kt: ~20 ms
rise_time = 0.02
overshoot_factor = 1.15

# Moment tensor — coupled granite, dominantly isotropic
isotropic_fraction = 0.85
clvd_fraction = 0.10
double_couple_fraction = 0.05

# Scalar seismic moment: M0 ≈ 7.0 × 10^16 N·m (Murphy 1996)
scalar_moment = 7.0e16

# Spall parameters
enable_spall = true
spall_depth = 100.0
spall_velocity = 2.5

# ==============================================================================
# Grid — 400 km × 400 km × 60 km structured domain
# ==============================================================================
# Double the domain of the original config to place receivers at up to 200 km.
# 800 × 800 × 120 = 76.8 M cells
# With DG order 4 → ~9.6 billion DOFs (3-component displacement)

[GRID]
nx = 800
ny = 800
nz = 120

Lx = 400000.0                        # 400 km
Ly = 400000.0                        # 400 km
Lz = 60000.0                         # 60 km

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic reference (Lop Nor 1996)
input_crs = EPSG:4326
model_crs = EPSG:32646               # UTM Zone 46N
use_local_coordinates = true
local_origin_x = 88.3748             # Event longitude (°E)
local_origin_y = 41.7163             # Event latitude  (°N)
local_origin_z = 0.0

# ==============================================================================
# Material Properties — Lop Nor 1-D Layered Crustal Model
# ==============================================================================
# Kuruktag / Tarim Basin velocity model from Xia et al. (2017) NCCrust,
# Charlie & Veyera (1994), and regional deep seismic sounding profiles.
# Moho at 48 km depth; Pn = 7.9 km/s.

[ROCK_LAYER1]
name = Upper_Granite_Kuruktag
constitutive_model = ELASTIC
depth_top = 0.0
depth_bottom = 3000.0
density = 2650.0
p_wave_velocity = 5800.0
s_wave_velocity = 3400.0
youngs_modulus = 50.0e9
poisson_ratio = 0.24
quality_factor_p = 400.0
quality_factor_s = 200.0

[ROCK_LAYER2]
name = Upper_Crust_Metasediments
constitutive_model = ELASTIC
depth_top = 3000.0
depth_bottom = 15000.0
density = 2750.0
p_wave_velocity = 6100.0
s_wave_velocity = 3550.0
youngs_modulus = 56.0e9
poisson_ratio = 0.26
quality_factor_p = 500.0
quality_factor_s = 250.0

[ROCK_LAYER3]
name = Middle_Crust_Metamorphic
constitutive_model = ELASTIC
depth_top = 15000.0
depth_bottom = 30000.0
density = 2850.0
p_wave_velocity = 6450.0
s_wave_velocity = 3700.0
youngs_modulus = 72.0e9
poisson_ratio = 0.26
quality_factor_p = 600.0
quality_factor_s = 300.0

[ROCK_LAYER4]
name = Lower_Crust_Mafic_Granulite
constitutive_model = ELASTIC
depth_top = 30000.0
depth_bottom = 48000.0
density = 3050.0
p_wave_velocity = 6950.0
s_wave_velocity = 4000.0
youngs_modulus = 98.0e9
poisson_ratio = 0.27
quality_factor_p = 700.0
quality_factor_s = 350.0

[ROCK_LAYER5]
name = Upper_Mantle_Peridotite
constitutive_model = ELASTIC
depth_top = 48000.0
depth_bottom = 60000.0
density = 3300.0
p_wave_velocity = 7900.0
s_wave_velocity = 4500.0
youngs_modulus = 170.0e9
poisson_ratio = 0.28
quality_factor_p = 1000.0
quality_factor_s = 500.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

# ==============================================================================
# Boundary Conditions
# ==============================================================================
# Free surface at z=0 (top), PML absorbing on all other faces.

[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC3]
type = ABSORBING
location = XMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC4]
type = ABSORBING
location = YMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC5]
type = ABSORBING
location = YMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC6]
type = ABSORBING
location = ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Three arrays designed for robust extrapolation to real KNDC distances:
#
# (A) RADIAL ARRAY — 8 stations along +x at 25, 50, 75, 100, 125, 150, 175,
#     200 km for distance-dependent amplitude calibration and Q estimation.
#
# (B) AZIMUTHAL ARRAY — 8 stations at 150 km matching the azimuths of key
#     KNDC stations from the 1996 event (from .site file coordinates):
#       DZHR  — az ≈ 315°  (NW, real dist 761 km)
#       UZB   — az ≈ 308°  (WNW, 785 km)
#       PRZ   — az ≈ 285°  (WNW, 829 km)
#       KURM  — az ≈ 316°  (NW, 860 km)
#       TRG   — az ≈ 307°  (WNW, 899 km)
#       KUU   — az ≈ 323°  (NW, 1013 km)
#       BRD   — az ≈ 291°  (WNW, 1531 km)
#       YUZH  — az ≈ 280°  (W, 1519 km)
#
# (C) DENSE RADIAL — 4 stations at 50 km in orthogonal directions (N,E,S,W)
#     for azimuthal radiation pattern characterization.
#
# Source at (200000, 200000, -400).  All receivers at z=0 (surface).

[SEISMOMETERS]
enabled = true
output_dir = output/lop_nor_1996_numerical/seismograms
formats = SAC,MSEED
start_time_utc = 1996-07-29T01:48:57Z
default_sample_rate_hz = 50.0
default_quantity = VELOCITY

# ── Radial Array (along +x from source, due east, az=90°) ───────────────────

[SEISMOMETER_R025]
net = SY
sta = R025
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 225000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R050]
net = SY
sta = R050
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 250000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R075]
net = SY
sta = R075
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 275000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R100]
net = SY
sta = R100
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 300000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R125]
net = SY
sta = R125
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 325000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R150]
net = SY
sta = R150
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 350000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R175]
net = SY
sta = R175
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 375000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R200]
net = SY
sta = R200
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 400000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ── Azimuthal Array (150 km radius, matching KNDC station azimuths) ──────────
# Source at (200000, 200000).  r = 150 km = 150000 m.
# x = 200000 + 150000*sin(az),  y = 200000 + 150000*cos(az)

[SEISMOMETER_AZ_DZHR]
net = SY
sta = DZHR
loc = 00
channels = BHN,BHE,BHZ
# az = 315°: dx = 150*sin(315°) = -106.07 km, dy = 150*cos(315°) = +106.07 km
location_xyz = 93934.0, 306066.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_UZB]
net = SY
sta = UZB
loc = 00
channels = BHN,BHE,BHZ
# az = 308°: dx = 150*sin(308°) = -118.17 km, dy = 150*cos(308°) = +92.31 km
location_xyz = 81832.0, 292311.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_PRZ]
net = SY
sta = PRZ
loc = 00
channels = BHN,BHE,BHZ
# az = 285°: dx = 150*sin(285°) = -144.89 km, dy = 150*cos(285°) = +38.82 km
location_xyz = 55107.0, 238823.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_KURM]
net = SY
sta = KURM
loc = 00
channels = BHN,BHE,BHZ
# az = 316°: dx = 150*sin(316°) = -104.21 km, dy = 150*cos(316°) = +107.91 km
location_xyz = 95790.0, 307905.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_TRG]
net = SY
sta = TRG
loc = 00
channels = BHN,BHE,BHZ
# az = 307°: dx = 150*sin(307°) = -119.79 km, dy = 150*cos(307°) = +90.27 km
location_xyz = 80210.0, 290271.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_KUU]
net = SY
sta = KUU
loc = 00
channels = BHN,BHE,BHZ
# az = 323°: dx = 150*sin(323°) = -90.27 km, dy = 150*cos(323°) = +119.79 km
location_xyz = 109730.0, 319793.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_BRD]
net = SY
sta = BRD
loc = 00
channels = BHN,BHE,BHZ
# az = 291°: dx = 150*sin(291°) = -140.01 km, dy = 150*cos(291°) = +53.80 km
location_xyz = 59994.0, 253800.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_AZ_YUZH]
net = SY
sta = YUZH
loc = 00
channels = BHN,BHE,BHZ
# az = 280°: dx = 150*sin(280°) = -147.72 km, dy = 150*cos(280°) = +26.05 km
location_xyz = 52279.0, 226047.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ── Cross Array (50 km radius in 4 cardinal directions) ─────────────────────

[SEISMOMETER_N050]
net = SY
sta = N050
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 200000.0, 250000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_E050]
net = SY
sta = E050
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 250000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_S050]
net = SY
sta = S050
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 200000.0, 150000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_W050]
net = SY
sta = W050
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 150000.0, 200000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ==============================================================================
# Receiver Line (for wavefield snapshot analysis)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 200.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 200000.0, 200000.0, 0.0
end = 400000.0, 200000.0, 0.0
num_stations = 40
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/lop_nor_1996_numerical

save_displacement = true
save_velocity = true
save_stress = true
save_damage = false
save_temperature = false

volume_output_frequency = 2000
surface_output = true
surface_output_frequency = 500

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
