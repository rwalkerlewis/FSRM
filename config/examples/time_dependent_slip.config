# Time-dependent Prescribed Slip Example
# Applies a prescribed strike-slip displacement on a vertical fault
# with a linear ramp from t=0.1 to t=0.6 (rise_time=0.5).
# Verifies time-dependent slip via PetscDS BdResidual on cohesive cells.

[SIMULATION]
name = time_dependent_slip
start_time = 0.0
end_time = 1.0
dt_initial = 0.1
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_elastodynamics = false
enable_faults = true
rtol = 1.0e-10
atol = 1.0e-12
max_nonlinear_iterations = 10

[GRID]
nx = 8
ny = 8
nz = 4
Lx = 1000.0
Ly = 1000.0
Lz = 500.0

[ROCK]
density = 2500.0
youngs_modulus = 30.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = false
gravity = 0.0

[FAULT]
mode = prescribed_slip
strike = 0.0
dip = 90.0
center_x = 500.0
center_y = 500.0
center_z = 250.0
slip_strike = 1.0
slip_dip = 0.0
slip_opening = 0.0
friction_coefficient = 0.6
slip_onset_time = 0.1
slip_rise_time = 0.5

[BOUNDARY_CONDITIONS]
z_min = fixed
x_min = roller
x_max = roller
y_min = roller
y_max = roller
z_max = free

[OUTPUT]
directory = output
format = HDF5
