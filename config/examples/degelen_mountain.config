# Degelen Mountain, Semipalatinsk Test Site (Kazakhstan) -- Layered Geology Model
# Typical tunnel test configuration (50 kt, 300m depth)
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 300m depth = z=4700 (within fractured granite layer)
#
# Layer structure:
#   Weathered granite:       0-100m depth   (z=4900 to z=5000)
#   Fractured granite:     100-500m depth   (z=4500 to z=4900)
#   Competent granite/gneiss: 500-5000m depth (z=0 to z=4500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Weathered granite:   vp=3000, vs=1732, rho=2200 -> lambda=6.60e9,  mu=6.60e9
#   Fractured granite:   vp=4800, vs=2771, rho=2550 -> lambda=1.96e10, mu=1.96e10
#   Competent granite:   vp=6000, vs=3464, rho=2700 -> lambda=3.24e10, mu=3.24e10

[SIMULATION]
name = degelen_mountain
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 30000.0
Ly = 30000.0
Lz = 5000.0

[ROCK]
# Fallback for homogeneous case (competent granite)
density = 2700.0
youngs_modulus = 80.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Weathered granite: surface to 100m depth
z_top = 5000.0
z_bottom = 4900.0
lambda = 6.60e9
mu = 6.60e9
rho = 2200.0

[LAYER_2]
# Fractured granite: 100m to 500m depth
z_top = 4900.0
z_bottom = 4500.0
lambda = 1.96e10
mu = 1.96e10
rho = 2550.0

[LAYER_3]
# Competent granite/gneiss: 500m to 5000m depth
z_top = 4500.0
z_bottom = 0.0
lambda = 3.24e10
mu = 3.24e10
rho = 2700.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 50.0
depth_of_burial = 300.0
location_x = 15000.0
location_y = 15000.0
location_z = 4700.0
onset_time = 0.0
rise_time = 0.03
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/degelen_mountain
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 15000.0,15000.0,5000.0

[SEISMOMETER_2]
# 5 km to the east at surface
sta = STA05
location_xyz = 20000.0,15000.0,5000.0

[SEISMOMETER_3]
# 10 km to the east at surface
sta = STA10
location_xyz = 25000.0,15000.0,5000.0
