# Pokhran-I (Smiling Buddha), Pokhran Test Range, IN (1974-05-18)
# 8 kt declared yield, detonated at ~107 m depth in Vindhyan sandstone
# Site: Pokhran, Rajasthan, IN (~27.10 N, 71.75 E)
#
# Purpose: First Indian nuclear test ("peaceful nuclear explosion"),
# conducted in the Trans-Aravalli Vindhyan sandstone-shale sequence
# of the Pokhran Test Range. Documented in Sikka et al. 2000.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 107 m depth = z=1893 (within Vindhyan sandstone)
#
# Layer structure (Sikka et al. 2000; Trans-Aravalli geology):
#   Aeolian sand / surface dunes: 0-30m   (z=1970 to z=2000)
#   Vindhyan sandstone:           30-200m (z=1800 to z=1970; emplacement)
#   Trans-Aravalli granite/gneiss: 200-2000m (z=0 to z=1800)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Aeolian sand:        vp=1500, vs=700,  rho=1800 -> lambda=2.29e9,  mu=8.82e8
#   Vindhyan sandstone:  vp=3500, vs=1900, rho=2400 -> lambda=1.21e10, mu=8.66e9
#   Trans-Aravalli base: vp=5500, vs=3100, rho=2700 -> lambda=2.98e10, mu=2.59e10

[SIMULATION]
name = pokhran_i_1974
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (Trans-Aravalli granite/gneiss)
density = 2700.0
youngs_modulus = 70.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Aeolian sand / surface dunes: 0-30m depth
z_top = 2000.0
z_bottom = 1970.0
lambda = 2.29e9
mu = 8.82e8
rho = 1800.0

[LAYER_2]
# Vindhyan sandstone: 30-200m depth (emplacement formation)
z_top = 1970.0
z_bottom = 1800.0
lambda = 1.21e10
mu = 8.66e9
rho = 2400.0

[LAYER_3]
# Trans-Aravalli granite/gneiss base: 200-2000m depth
z_top = 1800.0
z_bottom = 0.0
lambda = 2.98e10
mu = 2.59e10
rho = 2700.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 8.0
depth_of_burial = 107.0
location_x = 2000.0
location_y = 2000.0
location_z = 1893.0
onset_time = 0.0
rise_time = 0.10
cavity_overpressure = 1.0e10
medium_type = SHALE

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/pokhran_i_1974
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
