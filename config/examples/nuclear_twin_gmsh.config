# Compact Gmsh-based nuclear twin example
# Uses physical labels in meshes/test_two_material.msh

[SIMULATION]
name = nuclear_twin_gmsh
start_time = 0.0
end_time = 0.5
dt_initial = 0.005
dt_min = 0.001
dt_max = 0.01
max_timesteps = 200
output_frequency = 50
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8

[GRID]
mesh_type = GMSH
mesh_file = ../meshes/test_two_material.msh

[ROCK]
density = 2500.0
youngs_modulus = 40.0e9
poisson_ratio = 0.25

[MATERIAL]
heterogeneous = true
assignment = gmsh_label

[MATERIAL_REGION_1]
gmsh_label = soft_rock
youngs_modulus = 12.0e9
poissons_ratio = 0.25
density = 2200.0

[MATERIAL_REGION_2]
gmsh_label = hard_rock
youngs_modulus = 75.0e9
poissons_ratio = 0.25
density = 2800.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 5.0
depth_of_burial = 500.0
location_x = 500.0
location_y = 500.0
location_z = -500.0
onset_time = 0.0
rise_time = 0.01
cavity_overpressure = 1.0e10
apply_damage_zone = true

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[OUTPUT]
output_directory = output/nuclear_twin_gmsh
