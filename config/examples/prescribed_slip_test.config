# Prescribed Slip Test Configuration
# A 10x10x100m box with a vertical fault at x=5m.
# Prescribes 1m of strike-slip (along-fault displacement jump = 1m in y).

[SIMULATION]
start_time = 0.0
end_time = 1.0
dt_initial = 1.0
fluid_model = NONE
solid_model = LINEAR_ELASTIC
enable_geomechanics = true
enable_faults = true

[GRID]
nx = 4
ny = 4
nz = 20
Lx = 10.0
Ly = 10.0
Lz = 100.0
grid_type = STRUCTURED

[ROCK]
porosity = 0.20
permeability_x = 100.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25
density = 2700.0

[FRACTURE_PLANE]
enabled = true
strike = 0.0
dip = 90.0
center_x = 5.0
center_y = 5.0
center_z = 50.0
length = 200.0
width = 200.0
tensile_strength = 5.0e6

[FAULT]
mode = prescribed_slip
slip_strike = 1.0
slip_dip = 0.0
slip_opening = 0.0

[BOUNDARY]
# Fix displacement on all faces
bc_xmin = DIRICHLET
bc_xmax = DIRICHLET
bc_ymin = DIRICHLET
bc_ymax = DIRICHLET
bc_zmin = DIRICHLET
bc_zmax = DIRICHLET
