# Gasbuggy, New Mexico (1967) -- Project Plowshare Gas Stimulation
# 29 kt device detonated at 1280m depth in Lewis Shale
#
# Purpose: Stimulate natural gas recovery from tight sandstone/shale
# First US nuclear stimulation experiment (Operation Plowshare)
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 1280m depth = z=3720 (within Lewis Shale)
#
# Layer structure (simplified from well logs):
#   Alluvium/sandstone:    0-200m depth   (z=4800 to z=5000)
#   Mesaverde sandstone:  200-800m depth   (z=4200 to z=4800)
#   Lewis Shale:          800-1600m depth  (z=3400 to z=4200)
#   Pictured Cliffs Ss:   1600-5000m depth (z=0 to z=3400)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Alluvium/sandstone: vp=2500, vs=1200, rho=2100 -> lambda=7.07e9, mu=3.02e9
#   Mesaverde Ss:       vp=4000, vs=2300, rho=2450 -> lambda=1.33e10, mu=1.30e10
#   Lewis Shale:        vp=3500, vs=2000, rho=2550 -> lambda=1.12e10, mu=1.02e10
#   Pictured Cliffs:    vp=4500, vs=2600, rho=2500 -> lambda=1.68e10, mu=1.69e10

[SIMULATION]
name = gasbuggy_1967
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 30000.0
Ly = 30000.0
Lz = 5000.0

[ROCK]
# Fallback (Pictured Cliffs Sandstone)
density = 2500.0
youngs_modulus = 42.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Alluvium/sandstone: surface to 200m depth
z_top = 5000.0
z_bottom = 4800.0
lambda = 7.07e9
mu = 3.02e9
rho = 2100.0

[LAYER_2]
# Mesaverde sandstone: 200m to 800m depth
z_top = 4800.0
z_bottom = 4200.0
lambda = 1.33e10
mu = 1.30e10
rho = 2450.0

[LAYER_3]
# Lewis Shale: 800m to 1600m depth (emplacement formation)
z_top = 4200.0
z_bottom = 3400.0
lambda = 1.12e10
mu = 1.02e10
rho = 2550.0

[LAYER_4]
# Pictured Cliffs Sandstone: 1600m to 5000m depth
z_top = 3400.0
z_bottom = 0.0
lambda = 1.68e10
mu = 1.69e10
rho = 2500.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 29.0
depth_of_burial = 1280.0
location_x = 15000.0
location_y = 15000.0
location_z = 3720.0
onset_time = 0.0
rise_time = 0.03
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/gasbuggy_1967
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 15000.0,15000.0,5000.0

[SEISMOMETER_2]
# 5 km to the east at surface
sta = STA05
location_xyz = 20000.0,15000.0,5000.0

[SEISMOMETER_3]
# 10 km to the east at surface
sta = STA10
location_xyz = 25000.0,15000.0,5000.0
