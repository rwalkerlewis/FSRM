# Baneberry, NTS Yucca Flat U-8d (1970-12-18) -- Notable venting event
# 10 kt device detonated at 278 m depth in saturated tuff
# Site: NTS Yucca Flat, NV (~37.07 N, -116.05 E)
#
# Purpose: Routine weapons-effects test. Famously vented radioactive gas
# to the surface within minutes of detonation despite an emplacement
# depth that nominally satisfied the contained-yield scaling. The
# leading-edge analysis attributed the venting to high pore-water
# saturation in the tuff column (Carothers et al. 1995).
#
# Saturation note: the published velocity model uses lower Vs in the
# 100-400 m saturated zone than in dry tuff at the same depth. FSRM
# does not represent saturation explicitly; the lowered Vs/Vp values
# below approximate the saturated mechanical state.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 278 m depth = z=1722 (within saturated tuff)
#
# Layer structure (Carothers et al. 1995; NTS Area 8 well logs):
#   Alluvium:            0-100m    (z=1900 to z=2000)
#   Saturated tuff:      100-400m  (z=1600 to z=1900; emplacement)
#   Welded tuff:         400-1000m (z=1000 to z=1600)
#   Paleozoic basement:  1000-2000m (z=0 to z=1000)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Alluvium:           vp=1500, vs=700,  rho=1800 -> lambda=2.29e9,  mu=8.82e8
#   Saturated tuff:     vp=2200, vs=1100, rho=2100 -> lambda=5.08e9,  mu=2.54e9
#   Welded tuff:        vp=3500, vs=1900, rho=2300 -> lambda=1.16e10, mu=8.30e9
#   Paleozoic basement: vp=5000, vs=2900, rho=2700 -> lambda=2.21e10, mu=2.27e10

[SIMULATION]
name = baneberry_1970
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (Paleozoic basement)
density = 2700.0
youngs_modulus = 65.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Alluvium: 0-100m depth
z_top = 2000.0
z_bottom = 1900.0
lambda = 2.29e9
mu = 8.82e8
rho = 1800.0

[LAYER_2]
# Saturated tuff: 100-400m depth (emplacement formation)
z_top = 1900.0
z_bottom = 1600.0
lambda = 5.08e9
mu = 2.54e9
rho = 2100.0

[LAYER_3]
# Welded tuff: 400-1000m depth
z_top = 1600.0
z_bottom = 1000.0
lambda = 1.16e10
mu = 8.30e9
rho = 2300.0

[LAYER_4]
# Paleozoic basement: 1000-2000m depth
z_top = 1000.0
z_bottom = 0.0
lambda = 2.21e10
mu = 2.27e10
rho = 2700.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 10.0
depth_of_burial = 278.0
location_x = 2000.0
location_y = 2000.0
location_z = 1722.0
onset_time = 0.0
rise_time = 0.11
cavity_overpressure = 1.0e10
medium_type = TUFF

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/baneberry_1970
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
