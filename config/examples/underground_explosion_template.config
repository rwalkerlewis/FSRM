# ============================================================================
# Underground Nuclear Explosion Simulation Template
# ============================================================================
#
# This template provides a fully commented configuration for simulating
# underground nuclear explosions with FSRM. Customize the parameters below
# for your specific test scenario.
#
# Physics: Elastodynamics with point-source moment tensor injection.
# The explosion is modeled as an isotropic source (M_ij = M0(t)/3 * delta_ij)
# using the Mueller-Murphy (1971) source model with cavity mechanics.
#
# Usage:
#   cd build
#   ./fsrm -c ../config/examples/underground_explosion_template.config \
#          -ts_monitor -snes_monitor -pc_type lu
#
# For parallel runs:
#   mpirun -np 4 ./fsrm -c <config> -pc_type gamg
#
# ============================================================================

[SIMULATION]
# Simulation name (used for output file naming)
name = underground_explosion

# Time range in seconds
start_time = 0.0
end_time = 2.0            # Increase for regional propagation (10-30s)

# Timestep control
dt_initial = 0.001        # Initial timestep (seconds)
dt_min = 0.0001           # Minimum timestep
dt_max = 0.01             # Maximum timestep (CFL-limited)
max_timesteps = 2000      # Safety limit on total steps

# Output control
output_frequency = 100    # Write output every N steps
output_format = HDF5

# Physics model selection
# fluid_model: NONE (dry rock), SINGLE_COMPONENT, BLACK_OIL
# solid_model: ELASTIC, POROELASTIC
fluid_model = NONE
solid_model = ELASTIC

# Solver flags
enable_geomechanics = true
enable_faults = false         # Set true for fault slip studies
enable_elastodynamics = true  # REQUIRED for wave propagation

# Nonlinear solver tolerances
rtol = 1.0e-6             # Relative convergence tolerance
atol = 1.0e-8             # Absolute convergence tolerance
max_nonlinear_iterations = 20

# ============================================================================
[GRID]
# ============================================================================
# Domain discretization. The mesh should be fine enough to resolve the
# shortest wavelength of interest: h < v_s / (N * f_max)
# where N ~ 10 points per wavelength.
#
# For a 10 kt test at 300 m depth in tuff:
#   v_s ~ 2500 m/s, f_max ~ 5 Hz -> lambda_min ~ 500 m -> h ~ 50 m
#   For 10 km domain: nx = ny = 200, nz = 100
#
# Coarse meshes (10-20) are acceptable for testing setup and convergence.

nx = 10                   # Grid points in X
ny = 10                   # Grid points in Y
nz = 10                   # Grid points in Z
Lx = 10000.0              # Domain size X (meters)
Ly = 10000.0              # Domain size Y (meters)
Lz = 5000.0               # Domain size Z (meters)

# ============================================================================
[ROCK]
# ============================================================================
# Host rock material properties. Common values:
#
# Material         | density | E (GPa) | nu   | Vs (m/s)
# ---------------  |---------|---------|------|----------
# Hard granite     | 2650    | 60      | 0.25 | 3000
# Soft granite     | 2600    | 40      | 0.27 | 2500
# Tuff (NTS)       | 2100    | 10      | 0.30 | 1400
# Alluvium (NTS)   | 1800    | 2       | 0.35 | 700
# Sandstone        | 2300    | 20      | 0.25 | 1800
# Salt (Azgir)     | 2200    | 30      | 0.25 | 2500

density = 2700.0          # kg/m^3
youngs_modulus = 50.0e9   # Pa (50 GPa)
poissons_ratio = 0.25

# ============================================================================
[EXPLOSION_SOURCE]
# ============================================================================
# Underground nuclear explosion source parameters.
#
# type: UNDERGROUND_NUCLEAR (Mueller-Murphy source model)
#
# yield_kt: Device yield in kilotons of TNT equivalent.
#   - Small tactical:  0.1 - 1 kt
#   - Medium:          1 - 20 kt
#   - Large:           20 - 500 kt
#   - Very large:      > 500 kt
#
# depth_of_burial: Depth below surface in meters.
#   Scaled depth of burial (SDOB): depth / yield^(1/3)
#   Containment rule of thumb: depth > 120 * yield^(1/3) meters
#   (yield in kt)
#
# location_x/y/z: Source position in mesh coordinates (meters).
#   z is measured from the bottom of the domain upward.
#   For a surface at z=Lz and depth d: location_z = Lz - d
#
# onset_time: Time when the explosion occurs (seconds).
#   Set to 0 for immediate detonation, or delay for multiple sources.
#
# rise_time: Source time function duration (seconds).
#   Typical values: 0.01-0.1 s. Scales roughly as yield^(1/3).
#
# cavity_overpressure: Peak cavity pressure (Pa).
#   Typical: 1e9 - 1e11 Pa depending on yield and medium.

type = UNDERGROUND_NUCLEAR
yield_kt = 10.0
depth_of_burial = 300.0
location_x = 5000.0
location_y = 5000.0
location_z = 4700.0       # Lz - depth = 5000 - 300
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10

# ============================================================================
[SEISMOMETERS]
# ============================================================================
# Virtual seismometer network for recording synthetic waveforms.
#
# format: SAC (Seismic Analysis Code) or ASCII
# channels: velocity, acceleration, displacement (comma-separated)
# output_dir: Directory for output files (created if needed)
#
# Station format: station_N = name,x,y,z
#   Coordinates are in mesh coordinates (meters).
#   Place stations at the surface (z = Lz) for surface recordings.
#   Stations outside the domain are projected to the nearest mesh point.
#
# For meaningful results, stations should be within the computational domain.

enabled = true
formats = SAC
output_dir = output/seismograms
default_quantity = VELOCITY
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
sta = near_1km
location_xyz = 6000.0,5000.0,5000.0

[SEISMOMETER_2]
sta = mid_3km
location_xyz = 8000.0,5000.0,5000.0

[SEISMOMETER_3]
sta = far_5km
location_xyz = 10000.0,5000.0,5000.0

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false
