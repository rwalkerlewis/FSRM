# Layered Elastostatics Example
# Demonstrates heterogeneous material properties via auxiliary fields
# 3-layer model: alluvium / weathered granite / competent granite

[SIMULATION]
enable_geomechanics = true
solid_model = ELASTIC
fluid_model = NONE
max_timesteps = 1
dt_initial = 1.0
start_time = 0.0
end_time = 1.0

[GRID]
nx = 8
ny = 8
nz = 16
Lx = 2000.0        # m
Ly = 2000.0        # m
Lz = 5000.0        # m (z from 0 to 5000)
mesh_type = CARTESIAN

[ROCK]
# Default/fallback material (used when no layer matches)
density = 2650.0          # kg/m^3
youngs_modulus = 50.0e9   # Pa
poisson_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0             # m/s^2 (no gravity for pure mechanical test)

# Layer 1: alluvium (top, z = 5000 to 3500)
[LAYER_1]
z_top = 5000.0
z_bottom = 3500.0
lambda = 3.0e9            # Pa
mu = 1.5e9                # Pa
rho = 1800.0              # kg/m^3

# Layer 2: weathered granite (middle, z = 3500 to 1500)
[LAYER_2]
z_top = 3500.0
z_bottom = 1500.0
lambda = 15.0e9           # Pa
mu = 12.0e9               # Pa
rho = 2400.0              # kg/m^3

# Layer 3: competent granite (bottom, z = 1500 to 0)
[LAYER_3]
z_top = 1500.0
z_bottom = 0.0
lambda = 30.0e9           # Pa
mu = 25.0e9               # Pa
rho = 2650.0              # kg/m^3
