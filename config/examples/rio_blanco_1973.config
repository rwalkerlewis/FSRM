# Rio Blanco, Rio Blanco County, CO (1973-05-17) -- Plowshare gas stimulation
# 3 x 33 kt simultaneous devices at 1780, 1990, 2040 m depth in
# Mesaverde / Fort Union sandstone-shale
# Site: Rio Blanco County, CO (~39.59 N, -108.32 E)
#
# Purpose: Multi-stage gas stimulation in the Piceance Basin (final
# Plowshare gas-stimulation test). Three devices were detonated
# simultaneously to create a vertically stacked fracture column in
# tight gas reservoirs.
#
# Multi-source simplification: FSRM's [EXPLOSION_SOURCE] section
# accepts only one source (Simulator.cpp:1162 hasSection check). The
# three Rio Blanco devices are modeled as a single equivalent source
# with summed yield (99 kt) at the geometric centroid (1903 m). This
# loses the vertical-stack moment-tensor structure but preserves total
# moment release; the SAC peak amplitude bound and mb estimate remain
# valid.
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Equivalent source at 1903 m depth = z=3097 (within Williams Fork)
#
# Layer structure (Lombard et al. 1971; Reynolds et al. 1971;
# Piceance Basin):
#   Surface clays / colluvium:  0-100m    (z=4900 to z=5000)
#   Tertiary fluvial sediments: 100-500m  (z=4500 to z=4900)
#   Fort Union Formation:       500-1500m (z=3500 to z=4500)
#   Williams Fork (Mesaverde):  1500-2500m (z=2500 to z=3500; emplacement)
#   Mesaverde Group base:       2500-5000m (z=0 to z=2500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Surface clays:    vp=1700, vs=850,  rho=2000 -> lambda=2.89e9,  mu=1.45e9
#   Tertiary fluvial: vp=2500, vs=1400, rho=2300 -> lambda=5.36e9,  mu=4.51e9
#   Fort Union:       vp=3500, vs=2000, rho=2400 -> lambda=1.02e10, mu=9.60e9
#   Williams Fork:    vp=4500, vs=2500, rho=2500 -> lambda=1.94e10, mu=1.56e10
#   Mesaverde base:   vp=4200, vs=2300, rho=2500 -> lambda=1.77e10, mu=1.32e10

[SIMULATION]
name = rio_blanco_1973
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5500
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 10000.0
Ly = 10000.0
Lz = 5000.0

[ROCK]
# Fallback (Mesaverde base)
density = 2500.0
youngs_modulus = 35.0e9
poissons_ratio = 0.28

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface clays / colluvium: 0-100m depth
z_top = 5000.0
z_bottom = 4900.0
lambda = 2.89e9
mu = 1.45e9
rho = 2000.0

[LAYER_2]
# Tertiary fluvial sediments: 100-500m depth
z_top = 4900.0
z_bottom = 4500.0
lambda = 5.36e9
mu = 4.51e9
rho = 2300.0

[LAYER_3]
# Fort Union Formation: 500-1500m depth
z_top = 4500.0
z_bottom = 3500.0
lambda = 1.02e10
mu = 9.60e9
rho = 2400.0

[LAYER_4]
# Williams Fork (Mesaverde) Sandstone: 1500-2500m depth (emplacement formation)
z_top = 3500.0
z_bottom = 2500.0
lambda = 1.94e10
mu = 1.56e10
rho = 2500.0

[LAYER_5]
# Mesaverde Group base: 2500-5000m depth
z_top = 2500.0
z_bottom = 0.0
lambda = 1.77e10
mu = 1.32e10
rho = 2500.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 99.0
depth_of_burial = 1903.0
location_x = 5000.0
location_y = 5000.0
location_z = 3097.0
onset_time = 0.0
rise_time = 0.23
cavity_overpressure = 1.0e10
medium_type = SHALE

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/rio_blanco_1973
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above (equivalent) explosion (spall check)
sta = SPALL
location_xyz = 5000.0,5000.0,5000.0

[SEISMOMETER_2]
# 2.5 km east at the surface
sta = STA02
location_xyz = 7500.0,5000.0,5000.0

[SEISMOMETER_3]
# 4 km east at the surface
sta = STA04
location_xyz = 9000.0,5000.0,5000.0
