# Long Shot, Amchitka Island, AK (1965-10-29) -- First Amchitka test
# 80 kt device detonated at 716 m depth in an andesite/breccia sequence
# Site: Amchitka Island, Aleutians, AK (~51.44 N, 179.18 E)
#
# Purpose: Investigate seismic discrimination of nuclear tests in an
# Aleutian arc setting. Long Shot is the precursor to Milrow (1969) and
# Cannikin (1971). All three Amchitka shots used the same volcanic
# stratigraphy.
#
# Medium type: GENERIC. The cavity-coefficient table in
# ExplosionImpactPhysics.cpp does not include andesite; the closest
# tabulated medium is GRANITE (11 m/kt^(1/3)) which understates the
# cavity in a vesicular volcanic. GENERIC (12 m/kt^(1/3)) is used as a
# small upward bias acknowledging the volcanic-arc rheology.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 716 m depth = z=1284 (within andesite breccia)
#
# Layer structure (King, Foster, & Bingham 1972, Amchitka):
#   Tundra / weathered overburden:  0-50m   (z=1950 to z=2000)
#   Weathered andesite:             50-300m (z=1700 to z=1950)
#   Andesite breccia:               300-800m (z=1200 to z=1700; emplacement)
#   Competent andesite:             800-2000m (z=0 to z=1200)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Tundra / overburden: vp=1500, vs=750,  rho=1800 -> lambda=2.03e9,  mu=1.01e9
#   Weathered andesite:  vp=2800, vs=1500, rho=2300 -> lambda=7.68e9,  mu=5.18e9
#   Andesite breccia:    vp=4000, vs=2200, rho=2500 -> lambda=1.58e10, mu=1.21e10
#   Competent andesite:  vp=4800, vs=2700, rho=2700 -> lambda=2.28e10, mu=1.97e10

[SIMULATION]
name = long_shot_1965
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (competent andesite)
density = 2700.0
youngs_modulus = 55.0e9
poissons_ratio = 0.27

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Tundra / weathered overburden: 0-50m depth
z_top = 2000.0
z_bottom = 1950.0
lambda = 2.03e9
mu = 1.01e9
rho = 1800.0

[LAYER_2]
# Weathered andesite: 50-300m depth
z_top = 1950.0
z_bottom = 1700.0
lambda = 7.68e9
mu = 5.18e9
rho = 2300.0

[LAYER_3]
# Andesite breccia: 300-800m depth (emplacement formation)
z_top = 1700.0
z_bottom = 1200.0
lambda = 1.58e10
mu = 1.21e10
rho = 2500.0

[LAYER_4]
# Competent andesite: 800-2000m depth
z_top = 1200.0
z_bottom = 0.0
lambda = 2.28e10
mu = 1.97e10
rho = 2700.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 80.0
depth_of_burial = 716.0
location_x = 2000.0
location_y = 2000.0
location_z = 1284.0
onset_time = 0.0
rise_time = 0.22
cavity_overpressure = 1.0e10
medium_type = GENERIC

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/long_shot_1965
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
