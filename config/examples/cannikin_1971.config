# Cannikin, Amchitka Island, AK (1971-11-06) -- Largest US underground test
# Up to 5 Mt (~5000 kt) device detonated at 1860 m depth in andesite
# Site: Amchitka Island, Aleutians, AK (~51.47 N, 179.10 E)
#
# Purpose: Final Spartan ABM warhead test. Triggered an mb 6.97 seismic
# event recorded teleseismically; widely cited in subsequent yield-from-
# seismograph calibration studies (Lay, Wallace, & Helmberger 1984).
#
# Medium type: GENERIC. The cavity-coefficient table does not include
# andesite; see Long Shot 1965 config header for the rationale.
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 1860 m depth = z=3140 (within competent andesite)
#
# Layer structure (King, Foster, & Bingham 1972; Lay et al. 1984):
#   Tundra / weathered overburden:  0-50m    (z=4950 to z=5000)
#   Weathered andesite:             50-300m  (z=4700 to z=4950)
#   Andesite breccia:               300-1200m (z=3800 to z=4700)
#   Competent andesite:             1200-3000m (z=2000 to z=3800; emplacement)
#   Deep andesite:                  3000-5000m (z=0 to z=2000)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Tundra / overburden: vp=1500, vs=750,  rho=1800 -> lambda=2.03e9,  mu=1.01e9
#   Weathered andesite:  vp=2800, vs=1500, rho=2300 -> lambda=7.68e9,  mu=5.18e9
#   Andesite breccia:    vp=4000, vs=2200, rho=2500 -> lambda=1.58e10, mu=1.21e10
#   Competent andesite:  vp=4800, vs=2700, rho=2700 -> lambda=2.28e10, mu=1.97e10
#   Deep andesite:       vp=5500, vs=3100, rho=2800 -> lambda=3.09e10, mu=2.69e10

[SIMULATION]
name = cannikin_1971
start_time = 0.0
end_time = 7.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 7500
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 10000.0
Ly = 10000.0
Lz = 5000.0

[ROCK]
# Fallback (deep andesite)
density = 2800.0
youngs_modulus = 70.0e9
poissons_ratio = 0.27

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Tundra / weathered overburden: 0-50m depth
z_top = 5000.0
z_bottom = 4950.0
lambda = 2.03e9
mu = 1.01e9
rho = 1800.0

[LAYER_2]
# Weathered andesite: 50-300m depth
z_top = 4950.0
z_bottom = 4700.0
lambda = 7.68e9
mu = 5.18e9
rho = 2300.0

[LAYER_3]
# Andesite breccia: 300-1200m depth
z_top = 4700.0
z_bottom = 3800.0
lambda = 1.58e10
mu = 1.21e10
rho = 2500.0

[LAYER_4]
# Competent andesite: 1200-3000m depth (emplacement formation)
z_top = 3800.0
z_bottom = 2000.0
lambda = 2.28e10
mu = 1.97e10
rho = 2700.0

[LAYER_5]
# Deep andesite: 3000-5000m depth
z_top = 2000.0
z_bottom = 0.0
lambda = 3.09e10
mu = 2.69e10
rho = 2800.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 5000.0
depth_of_burial = 1860.0
location_x = 5000.0
location_y = 5000.0
location_z = 3140.0
onset_time = 0.0
rise_time = 0.5
cavity_overpressure = 1.0e10
medium_type = GENERIC

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/cannikin_1971
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 5000.0,5000.0,5000.0

[SEISMOMETER_2]
# 2.5 km east at the surface
sta = STA02
location_xyz = 7500.0,5000.0,5000.0

[SEISMOMETER_3]
# 4 km east at the surface
sta = STA04
location_xyz = 9000.0,5000.0,5000.0
