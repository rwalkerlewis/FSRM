# Terzaghi Consolidation Test
# 1D column: sudden load on top, drained boundary, pressure dissipation over time

[SIMULATION]
name = terzaghi_consolidation
start_time = 0.0
end_time = 10.0
dt_initial = 0.1
dt_min = 0.001
dt_max = 1.0
max_timesteps = 100
output_frequency = 10
fluid_model = SINGLE_COMPONENT
solid_model = POROELASTIC
enable_geomechanics = true
enable_faults = false
rtol = 1.0e-8
atol = 1.0e-10
max_nonlinear_iterations = 20

[GRID]
nx = 2
ny = 2
nz = 20
Lx = 1.0
Ly = 1.0
Lz = 10.0

[ROCK]
density = 2500.0
youngs_modulus = 1.0e9
poissons_ratio = 0.25
porosity = 0.3
permeability_x = 1.0
permeability_y = 1.0
permeability_z = 1.0
biot_coefficient = 1.0

[FLUID]
type = SINGLE_PHASE
density = 1000.0
viscosity = 0.001
compressibility = 4.5e-10
reference_pressure = 0.0
