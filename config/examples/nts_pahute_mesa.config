# Nevada Test Site, Pahute Mesa -- Layered Geology Model
# Typical NTS configuration for large underground nuclear tests (150 kt)
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 600m depth = z=4400 (within welded tuff layer)
#
# Layer structure:
#   Alluvium:         0-300m depth   (z=4700 to z=5000)
#   Welded tuff:    300-800m depth   (z=4200 to z=4700)
#   Zeolitized tuff: 800-1500m depth (z=3500 to z=4200)
#   Rhyolite:       1500-5000m depth (z=0 to z=3500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Alluvium:        vp=1800, vs=1039, rho=1600 -> lambda=1.73e9,  mu=1.73e9
#   Welded tuff:     vp=3200, vs=1848, rho=2100 -> lambda=7.16e9,  mu=7.17e9
#   Zeolitized tuff: vp=4000, vs=2309, rho=2300 -> lambda=1.23e10, mu=1.23e10
#   Rhyolite:        vp=5000, vs=2887, rho=2500 -> lambda=2.08e10, mu=2.08e10

[SIMULATION]
name = nts_pahute_mesa
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 30000.0
Ly = 30000.0
Lz = 5000.0

[ROCK]
# Fallback for homogeneous case (rhyolite)
density = 2500.0
youngs_modulus = 52.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Alluvium: surface to 300m depth
z_top = 5000.0
z_bottom = 4700.0
lambda = 1.73e9
mu = 1.73e9
rho = 1600.0

[LAYER_2]
# Welded tuff: 300m to 800m depth
z_top = 4700.0
z_bottom = 4200.0
lambda = 7.16e9
mu = 7.17e9
rho = 2100.0

[LAYER_3]
# Zeolitized tuff: 800m to 1500m depth
z_top = 4200.0
z_bottom = 3500.0
lambda = 1.23e10
mu = 1.23e10
rho = 2300.0

[LAYER_4]
# Rhyolite: 1500m to 5000m depth
z_top = 3500.0
z_bottom = 0.0
lambda = 2.08e10
mu = 2.08e10
rho = 2500.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 150.0
depth_of_burial = 600.0
location_x = 15000.0
location_y = 15000.0
location_z = 4400.0
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/nts_pahute_mesa
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 15000.0,15000.0,5000.0

[SEISMOMETER_2]
# 5 km to the east at surface
sta = STA05
location_xyz = 20000.0,15000.0,5000.0

[SEISMOMETER_3]
# 10 km to the east at surface
sta = STA10
location_xyz = 25000.0,15000.0,5000.0
