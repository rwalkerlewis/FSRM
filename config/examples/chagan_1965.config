# Chagan ("Atomic Lake"), Semipalatinsk Test Site, Kazakhstan
# (1965-01-15) -- Soviet Plowshare cratering analog to Sedan
# 140 kt device detonated at 178 m depth in sandstone/siltstone with permafrost
# Site: Semipalatinsk Test Site, Kazakh SSR (~49.94 N, 79.01 E)
#
# Purpose: Largest Soviet peaceful-use nuclear cratering experiment.
# Created an apparent crater 408 m diameter, ~100 m deep that
# subsequently filled with water and is locally known as Lake Chagan
# or "Atomic Lake".
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 178 m depth = z=1822 (within sandstone above the
# permafrost / frozen-soil base)
#
# Layer structure (Adushkin & Spivak 2015, Semipalatinsk well log
# summary; Chagan basin sand-siltstone sequence):
#   Permafrost / alluvium:    0-50m    (z=1950 to z=2000)
#   Sandstone:                50-300m  (z=1700 to z=1950; emplacement)
#   Siltstone:                300-1000m (z=1000 to z=1700)
#   Pre-Mesozoic basement:    1000-2000m (z=0 to z=1000)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Permafrost / alluvium:  vp=1700, vs=850,  rho=1900 -> lambda=2.75e9,  mu=1.37e9
#   Sandstone:              vp=2800, vs=1500, rho=2300 -> lambda=7.68e9,  mu=5.18e9
#   Siltstone:              vp=3500, vs=2000, rho=2400 -> lambda=1.02e10, mu=9.60e9
#   Pre-Mesozoic basement:  vp=4500, vs=2600, rho=2600 -> lambda=1.75e10, mu=1.76e10

[SIMULATION]
name = chagan_1965
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (Pre-Mesozoic basement)
density = 2600.0
youngs_modulus = 50.0e9
poissons_ratio = 0.27

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Permafrost / alluvium: 0-50m depth
z_top = 2000.0
z_bottom = 1950.0
lambda = 2.75e9
mu = 1.37e9
rho = 1900.0

[LAYER_2]
# Sandstone: 50-300m depth (emplacement formation)
z_top = 1950.0
z_bottom = 1700.0
lambda = 7.68e9
mu = 5.18e9
rho = 2300.0

[LAYER_3]
# Siltstone: 300-1000m depth
z_top = 1700.0
z_bottom = 1000.0
lambda = 1.02e10
mu = 9.60e9
rho = 2400.0

[LAYER_4]
# Pre-Mesozoic basement: 1000-2000m depth
z_top = 1000.0
z_bottom = 0.0
lambda = 1.75e10
mu = 1.76e10
rho = 2600.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 140.0
depth_of_burial = 178.0
location_x = 2000.0
location_y = 2000.0
location_z = 1822.0
onset_time = 0.0
rise_time = 0.26
cavity_overpressure = 1.0e10
medium_type = ALLUVIUM

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/chagan_1965
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
