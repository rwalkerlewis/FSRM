# Azgir A-1, Astrakhan Oblast, RU (1966-04-22) -- First Soviet salt-cavity test
# 1.1 kt device detonated at 165 m depth in a Caspian-region halite (salt) dome
# Site: Astrakhan Oblast, RU (~47.93 N, 47.92 E)
#
# Purpose: First in the Soviet Azgir series of salt-cavity cratering /
# decoupling tests. Established the basis for subsequent decoupling
# studies (Sultanov et al. 1999; Adushkin & Spivak 2015).
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 165 m depth = z=1835 (within halite of the salt dome)
#
# Layer structure (Sultanov et al. 1999, Caspian salt-dome geology;
# Adushkin & Spivak 2015):
#   Surface alluvium / clays: 0-50m   (z=1950 to z=2000)
#   Anhydrite cap rock:       50-150m (z=1850 to z=1950)
#   Halite (salt dome):       150-2000m (z=0 to z=1850; emplacement)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Surface alluvium:   vp=1900, vs=900,  rho=2000 -> lambda=3.98e9,  mu=1.62e9
#   Anhydrite cap rock: vp=5000, vs=2900, rho=2700 -> lambda=2.21e10, mu=2.27e10
#   Halite:             vp=4500, vs=2500, rho=2200 -> lambda=1.71e10, mu=1.38e10

[SIMULATION]
name = azgir_a1_1966
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (halite)
density = 2200.0
youngs_modulus = 35.0e9
poissons_ratio = 0.28

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface alluvium / clays: 0-50m depth
z_top = 2000.0
z_bottom = 1950.0
lambda = 3.98e9
mu = 1.62e9
rho = 2000.0

[LAYER_2]
# Anhydrite cap rock: 50-150m depth
z_top = 1950.0
z_bottom = 1850.0
lambda = 2.21e10
mu = 2.27e10
rho = 2700.0

[LAYER_3]
# Halite: 150-2000m depth (emplacement formation)
z_top = 1850.0
z_bottom = 0.0
lambda = 1.71e10
mu = 1.38e10
rho = 2200.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 1.1
depth_of_burial = 165.0
location_x = 2000.0
location_y = 2000.0
location_z = 1835.0
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10
medium_type = SALT

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/azgir_a1_1966
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
