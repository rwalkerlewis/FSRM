# Locked fault with quasi-static compression
# Demonstrates cohesive cell insertion and locked-mode fault constraint.
#
# The mesh is split along a vertical fault at x=0.5 (strike=90, dip=90).
# Locked mode enforces displacement continuity (u+ = u-) across the fault.
# Under uniaxial compression, the locked fault should be transparent.
#
# BdResidual works in PETSc 3.25; BdJacobian does not.
# Jacobian assembled manually via addCohesivePenaltyToJacobian.

[SIMULATION]
name = locked_fault_compression
start_time = 0.0
end_time = 1.0
dt_initial = 1.0
dt_min = 0.1
dt_max = 1.0
max_timesteps = 1
output_format = HDF5
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_elastodynamics = false
enable_faults = true
rtol = 1.0e-4
atol = 1.0e-6
max_nonlinear_iterations = 50

[GRID]
nx = 4
ny = 4
nz = 4
Lx = 1.0
Ly = 1.0
Lz = 1.0

[ROCK]
density = 2650.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25

[FAULT]
strike = 90.0
dip = 90.0
center_x = 0.5
center_y = 0.5
center_z = 0.5
length = 2.0
width = 2.0
mode = locked
friction_coefficient = 0.6

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = compression

[ABSORBING_BC]
enabled = false
