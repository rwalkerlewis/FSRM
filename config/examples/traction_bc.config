# Traction Boundary Condition Example
# Applies a downward traction (compressive stress) on the top face,
# fixed bottom, and roller sides. Verifies the per-face BC system.
#
# Analytical solution for uniaxial stress:
#   sigma_zz = -1 MPa (applied traction)
#   u_z(z) = sigma_zz * z / E = -1e6 * z / 10e9 = -1e-4 * z
#   u_z(Lz=100) = -0.01 m
#   u_x = u_y = 0 (roller sides)

[SIMULATION]
name = traction_bc
start_time = 0.0
end_time = 1.0
dt_initial = 1.0
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
rtol = 1.0e-10
atol = 1.0e-12
max_nonlinear_iterations = 5

[GRID]
nx = 4
ny = 4
nz = 8
Lx = 10.0
Ly = 10.0
Lz = 100.0

[ROCK]
density = 2650.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = false
gravity = 0.0

[BOUNDARY_CONDITIONS]
z_min = fixed
x_min = roller
x_max = roller
y_min = roller
y_max = roller
z_max = traction
z_max_traction = 0.0, 0.0, -1.0e6

[OUTPUT]
directory = output
format = HDF5
