# Minimal explosion test for P-wave arrival verification
# 10km domain, 10x10x10 mesh (1000m cells)
# Source at center (5000, 5000, 5000)
# STA1: 2500m away, expected t_P = 2500/5494 = 0.455s
# STA2: 5000m away, expected t_P = 5000/5494 = 0.910s
# Material: lambda=30e9, mu=25e9, rho=2650
#   vp = sqrt((lambda + 2*mu)/rho) = sqrt(80e9/2650) = 5494 m/s
#   vs = sqrt(mu/rho) = sqrt(25e9/2650) = 3071 m/s

[SIMULATION]
name = minimal_explosion
start_time = 0.0
end_time = 0.6
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 600
output_frequency = 200
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 10
ny = 10
nz = 10
Lx = 10000.0
Ly = 10000.0
Lz = 10000.0

[ROCK]
density = 2650.0
youngs_modulus = 60.0e9
poissons_ratio = 0.25

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 10.0
depth_of_burial = 500.0
location_x = 5000.0
location_y = 5000.0
location_z = 5000.0
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/minimal_explosion
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
sta = STA1
location_xyz = 7500.0,5000.0,5000.0

[SEISMOMETER_2]
sta = STA2
location_xyz = 9500.0,5000.0,5000.0
