# Rainier, NTS Area 12 (1957-09-19) -- First fully contained US underground test
# 1.7 kt device detonated at 274 m depth in a tunnel through bedded tuff
# Site: Rainier Mesa, Nevada Test Site (~37.21 N, -116.21 E)
#
# Purpose: Demonstrate full containment of a nuclear test in volcanic tuff.
# Outcome: No visible surface effects; established the basis for the
# subsequent NTS underground campaign.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 274 m depth = z=1726 (within bedded tuff)
#
# Layer structure (Springer & Kinnaman 1971; Carlos 1995, NTS Area 12):
#   Surface alluvium/colluvium: 0-50m   (z=1950 to z=2000)
#   Welded Rainier Mesa Tuff:   50-200m (z=1800 to z=1950)
#   Bedded tunnel-bed tuff:    200-2000m (z=0 to z=1800; emplacement)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Surface alluvium:  vp=1500, vs=750,  rho=1900 -> lambda=2.14e9,  mu=1.07e9
#   Welded tuff:       vp=2700, vs=1500, rho=2200 -> lambda=6.14e9,  mu=4.95e9
#   Bedded tuff:       vp=3300, vs=1800, rho=2300 -> lambda=1.01e10, mu=7.45e9

[SIMULATION]
name = rainier_1957
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (bedded tuff)
density = 2300.0
youngs_modulus = 19.0e9
poissons_ratio = 0.27

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface alluvium/colluvium: 0-50m depth
z_top = 2000.0
z_bottom = 1950.0
lambda = 2.14e9
mu = 1.07e9
rho = 1900.0

[LAYER_2]
# Welded Rainier Mesa Tuff: 50-200m depth
z_top = 1950.0
z_bottom = 1800.0
lambda = 6.14e9
mu = 4.95e9
rho = 2200.0

[LAYER_3]
# Bedded tunnel-bed tuff: 200-2000m depth (emplacement formation)
z_top = 1800.0
z_bottom = 0.0
lambda = 1.01e10
mu = 7.45e9
rho = 2300.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 1.7
depth_of_burial = 274.0
location_x = 2000.0
location_y = 2000.0
location_z = 1726.0
onset_time = 0.0
rise_time = 0.06
cavity_overpressure = 1.0e10
medium_type = TUFF

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/rainier_1957
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
