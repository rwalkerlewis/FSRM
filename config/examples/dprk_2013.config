# DPRK 2013, Punggye-ri, Mt. Mantap, NK (2013-02-12)
# ~10 kt (USGS mb 5.1), detonated at ~600 m depth in Mt. Mantap granite
# Site: Punggye-ri, Kilju County (~41.29 N, 129.08 E)
#
# Purpose: Third DPRK underground nuclear test. Same Mt. Mantap
# emplacement formation as the 2006/2009 shots; deeper and larger.
# Velocity model is shared with the DPRK series.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 600 m depth = z=1400 (within fractured granite)
#
# Layer structure (matches Punggye-ri layered model):
#   Rhyolite / tuff cap:   0-200m   (z=1800 to z=2000)
#   Fractured granite:    200-1000m (z=1000 to z=1800; emplacement)
#   Competent granite:   1000-2000m (z=0 to z=1000)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Rhyolite/tuff cap: vp=3500, vs=2020, rho=2200 -> lambda=9.00e9,  mu=8.98e9
#   Fractured granite: vp=4500, vs=2598, rho=2500 -> lambda=1.69e10, mu=1.69e10
#   Competent granite: vp=5800, vs=3349, rho=2650 -> lambda=2.97e10, mu=2.97e10

[SIMULATION]
name = dprk_2013
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (competent granite)
density = 2650.0
youngs_modulus = 70.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Rhyolite / tuff cap: 0-200m depth
z_top = 2000.0
z_bottom = 1800.0
lambda = 9.00e9
mu = 8.98e9
rho = 2200.0

[LAYER_2]
# Fractured granite: 200-1000m depth (emplacement formation)
z_top = 1800.0
z_bottom = 1000.0
lambda = 1.69e10
mu = 1.69e10
rho = 2500.0

[LAYER_3]
# Competent granite: 1000-2000m depth
z_top = 1000.0
z_bottom = 0.0
lambda = 2.97e10
mu = 2.97e10
rho = 2650.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 10.0
depth_of_burial = 600.0
location_x = 2000.0
location_y = 2000.0
location_z = 1400.0
onset_time = 0.0
rise_time = 0.11
cavity_overpressure = 1.0e10
medium_type = GRANITE

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/dprk_2013
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
