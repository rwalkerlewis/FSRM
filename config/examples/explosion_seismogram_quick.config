# Quick version of explosion seismogram example
# Smaller mesh and shorter time for fast demonstration
# Full version: explosion_seismogram.config (larger mesh, longer time)

[SIMULATION]
name = explosion_seismogram_quick
start_time = 0.0
end_time = 0.5
dt_initial = 0.0025
dt_min = 0.001
dt_max = 0.005
max_timesteps = 200
output_frequency = 100
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 4
ny = 4
nz = 4
Lx = 4000.0
Ly = 4000.0
Lz = 4000.0

[ROCK]
density = 2650.0
youngs_modulus = 60.0e9
poissons_ratio = 0.25

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 10.0
depth_of_burial = 500.0
location_x = 2000.0
location_y = 2000.0
location_z = 2000.0
onset_time = 0.0
rise_time = 0.01
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/seismograms
default_quantity = DISPLACEMENT
default_sample_rate_hz = 200.0

[SEISMOMETER_1]
sta = NEAR
location_xyz = 2100.0,2000.0,2000.0

[SEISMOMETER_2]
sta = FAR
location_xyz = 2500.0,2000.0,2000.0
