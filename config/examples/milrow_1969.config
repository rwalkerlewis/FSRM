# Milrow, Amchitka Island, AK (1969-10-02) -- Cannikin precursor
# ~1000 kt (1 Mt) device detonated at 1218 m depth in andesite
# Site: Amchitka Island, Aleutians, AK (~51.42 N, 179.18 E)
#
# Purpose: Validate the engineering and emplacement methodology for the
# subsequent 5 Mt Cannikin shot. Same Aleutian-arc stratigraphy as
# Long Shot (1965).
#
# Medium type: GENERIC (no andesite coefficient in the cavity table; see
# Long Shot config header for the rationale).
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 1218 m depth = z=3782 (within andesite breccia)
#
# Layer structure (King, Foster, & Bingham 1972, Amchitka):
#   Tundra / weathered overburden:  0-50m    (z=4950 to z=5000)
#   Weathered andesite:             50-300m  (z=4700 to z=4950)
#   Andesite breccia:               300-1500m (z=3500 to z=4700; emplacement)
#   Competent andesite:             1500-5000m (z=0 to z=3500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Tundra / overburden: vp=1500, vs=750,  rho=1800 -> lambda=2.03e9,  mu=1.01e9
#   Weathered andesite:  vp=2800, vs=1500, rho=2300 -> lambda=7.68e9,  mu=5.18e9
#   Andesite breccia:    vp=4000, vs=2200, rho=2500 -> lambda=1.58e10, mu=1.21e10
#   Competent andesite:  vp=4800, vs=2700, rho=2700 -> lambda=2.28e10, mu=1.97e10

[SIMULATION]
name = milrow_1969
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 10000.0
Ly = 10000.0
Lz = 5000.0

[ROCK]
# Fallback (competent andesite)
density = 2700.0
youngs_modulus = 55.0e9
poissons_ratio = 0.27

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Tundra / weathered overburden: 0-50m depth
z_top = 5000.0
z_bottom = 4950.0
lambda = 2.03e9
mu = 1.01e9
rho = 1800.0

[LAYER_2]
# Weathered andesite: 50-300m depth
z_top = 4950.0
z_bottom = 4700.0
lambda = 7.68e9
mu = 5.18e9
rho = 2300.0

[LAYER_3]
# Andesite breccia: 300-1500m depth (emplacement formation)
z_top = 4700.0
z_bottom = 3500.0
lambda = 1.58e10
mu = 1.21e10
rho = 2500.0

[LAYER_4]
# Competent andesite: 1500-5000m depth
z_top = 3500.0
z_bottom = 0.0
lambda = 2.28e10
mu = 1.97e10
rho = 2700.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 1000.0
depth_of_burial = 1218.0
location_x = 5000.0
location_y = 5000.0
location_z = 3782.0
onset_time = 0.0
rise_time = 0.5
cavity_overpressure = 1.0e10
medium_type = GENERIC

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/milrow_1969
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 5000.0,5000.0,5000.0

[SEISMOMETER_2]
# 2.5 km east at the surface
sta = STA02
location_xyz = 7500.0,5000.0,5000.0

[SEISMOMETER_3]
# 4 km east at the surface
sta = STA04
location_xyz = 9000.0,5000.0,5000.0
