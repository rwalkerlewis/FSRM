# =============================================================================
# Lithostatic Column -- Gravitational Pre-Stress
# =============================================================================
#
# Solves for the lithostatic stress state in a vertical column under gravity.
#
# Geometry: 1 x 1 x 1000 m column
# Material: homogeneous granite
#   rho = 2650 kg/m^3
#   E = 10 GPa
#   nu = 0.25
#   lambda = 4 GPa, mu = 4 GPa
#
# BCs:
#   Bottom (z=0): fully fixed (u=0)
#   Sides:        roller (normal displacement = 0)
#   Top (z=H):    free surface (zero traction)
#
# Analytical solution:
#   sigma_zz(z) = -rho * g * (H - z)
#   sigma_xx(z) = sigma_yy(z) = K0 * sigma_zz(z)
#   K0 = nu / (1 - nu) = 0.3333
#   u_z(z) = -rho*g/(lambda+2*mu) * (H*z - z^2/2)
#
# At the base (z=0):
#   sigma_zz = -2650 * 9.81 * 1000 = -25996.5 kPa = -26.0 MPa
#   sigma_xx = sigma_yy = -8665.5 kPa = -8.67 MPa
#
# =============================================================================

[SIMULATION]
name = lithostatic_column
start_time = 0.0
end_time = 1.0
dt_initial = 1.0
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
max_nonlinear_iterations = 20
enable_gravity = true
rtol = 1.0e-10
atol = 1.0e-12

[GRID]
nx = 2
ny = 2
nz = 20
Lx = 1.0
Ly = 1.0
Lz = 1000.0

[ROCK]
density = 2650.0           # kg/m^3
youngs_modulus = 10.0e9    # Pa (10 GPa)
poissons_ratio = 0.25

[MATERIAL]
gravity = 9.81             # m/s^2

[GEOMECHANICS]
enabled = true

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free
