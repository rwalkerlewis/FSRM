# Punggye-ri Nuclear Test Site (DPRK) -- Layered Geology Model
# Based on published geology of Mt. Mantap (2017 test, estimated 250 kt)
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 800m depth = z=4200 (within fractured granite layer)
#
# Layer structure:
#   Rhyolite/tuff cap:   0-200m depth (z=4800 to z=5000)
#   Fractured granite: 200-1000m depth (z=4000 to z=4800)
#   Competent granite: 1000-5000m depth (z=0 to z=4000)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Rhyolite/tuff:     vp=3500, vs=2020, rho=2200 -> lambda=9.00e9, mu=8.98e9
#   Fractured granite: vp=4500, vs=2598, rho=2500 -> lambda=1.69e10, mu=1.69e10
#   Competent granite: vp=5800, vs=3349, rho=2650 -> lambda=2.97e10, mu=2.97e10

[SIMULATION]
name = punggye_ri_layered
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 30000.0
Ly = 30000.0
Lz = 5000.0

[ROCK]
# Fallback for homogeneous case (competent granite)
density = 2650.0
youngs_modulus = 70.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Rhyolite/tuff cap: surface to 200m depth
z_top = 5000.0
z_bottom = 4800.0
lambda = 9.00e9
mu = 8.98e9
rho = 2200.0

[LAYER_2]
# Fractured granite: 200m to 1000m depth
z_top = 4800.0
z_bottom = 4000.0
lambda = 1.69e10
mu = 1.69e10
rho = 2500.0

[LAYER_3]
# Competent granite: 1000m to 5000m depth
z_top = 4000.0
z_bottom = 0.0
lambda = 2.97e10
mu = 2.97e10
rho = 2650.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 250.0
depth_of_burial = 800.0
location_x = 15000.0
location_y = 15000.0
location_z = 4200.0
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[ABSORBING_BC]
enabled = true
faces = x_min, x_max, y_min, y_max, z_min

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/punggye_ri
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 15000.0,15000.0,5000.0

[SEISMOMETER_2]
# 5 km to the east at surface
sta = STA05
location_xyz = 20000.0,15000.0,5000.0

[SEISMOMETER_3]
# 10 km to the east at surface
sta = STA10
location_xyz = 25000.0,15000.0,5000.0
