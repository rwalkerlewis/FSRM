# Lithostatic equilibrium with gravity
# Computes the static stress state for a 3-layer geological column
# under gravitational loading with roller BCs on sides.
#
# Analytical solutions at sample depths:
#   z = -250m  (mid-alluvium):       sigma_zz = 1800*9.81*250 = 4.4145 MPa
#   z = -1250m (mid-weathered):      sigma_zz = 8.829 + 2400*9.81*750 = 26.487 MPa
#   z = -3500m (mid-granite):        sigma_zz = 8.829 + 35.316 + 2650*9.81*1500 = 83.135 MPa

[SIMULATION]
name = lithostatic_equilibrium
dt = 1.0
total_time = 1.0
max_time_steps = 1
max_nonlinear_iterations = 10

[MESH]
type = box
x_extent = 10000.0
y_extent = 10000.0
z_extent = 5000.0
nx = 10
ny = 10
nz = 50

[ROCK]
density = 2650.0
youngs_modulus = 80.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 9.81

[LAYER_1]
z_top = 0.0
z_bottom = -500.0
lambda = 3.0e9
mu = 1.5e9
rho = 1800.0

[LAYER_2]
z_top = -500.0
z_bottom = -2000.0
lambda = 15.0e9
mu = 12.0e9
rho = 2400.0

[LAYER_3]
z_top = -2000.0
z_bottom = -5000.0
lambda = 30.0e9
mu = 25.0e9
rho = 2650.0

[GEOMECHANICS]
enabled = true

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[OUTPUT]
save_solution = lithostatic_state.bin
