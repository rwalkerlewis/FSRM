# Salmon (Project Dribble), Tatum Salt Dome, MS (1964-10-22)
# 5.3 kt device detonated at 828 m depth in halite of the Tatum Salt Dome
# Site: Lamar County, Mississippi (~31.14 N, -89.57 E)
#
# Purpose: Investigate seismic coupling and decoupling of underground
# nuclear explosions in salt. Salmon is the coupled (tamped) shot of the
# Dribble series; Sterling (1966) is the decoupled shot in the
# Salmon-generated cavity.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 828 m depth = z=1172 (within Louann/Tatum salt)
#
# Layer structure (Springer et al. 1968; Patton 1991; Stump et al. 1994):
#   Surface alluvium / cap soils: 0-200m   (z=1800 to z=2000)
#   Tertiary sand-shale sequence: 200-500m (z=1500 to z=1800)
#   Cap rock (anhydrite/gypsum):  500-700m (z=1300 to z=1500)
#   Tatum dome halite:            700-2000m (z=0 to z=1300; emplacement)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Surface alluvium:   vp=1700, vs=900,  rho=2000 -> lambda=2.54e9,  mu=1.62e9
#   Sand-shale:         vp=2700, vs=1500, rho=2400 -> lambda=6.70e9,  mu=5.40e9
#   Anhydrite cap rock: vp=3500, vs=2000, rho=2500 -> lambda=1.06e10, mu=1.00e10
#   Tatum salt:         vp=4500, vs=2500, rho=2200 -> lambda=1.71e10, mu=1.38e10

[SIMULATION]
name = salmon_1964
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (Tatum salt)
density = 2200.0
youngs_modulus = 35.0e9
poissons_ratio = 0.28

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface alluvium / cap soils: 0-200m depth
z_top = 2000.0
z_bottom = 1800.0
lambda = 2.54e9
mu = 1.62e9
rho = 2000.0

[LAYER_2]
# Tertiary sand-shale sequence: 200-500m depth
z_top = 1800.0
z_bottom = 1500.0
lambda = 6.70e9
mu = 5.40e9
rho = 2400.0

[LAYER_3]
# Anhydrite cap rock: 500-700m depth
z_top = 1500.0
z_bottom = 1300.0
lambda = 1.06e10
mu = 1.00e10
rho = 2500.0

[LAYER_4]
# Tatum dome halite: 700-2000m depth (emplacement formation)
z_top = 1300.0
z_bottom = 0.0
lambda = 1.71e10
mu = 1.38e10
rho = 2200.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 5.3
depth_of_burial = 828.0
location_x = 2000.0
location_y = 2000.0
location_z = 1172.0
onset_time = 0.0
rise_time = 0.09
cavity_overpressure = 1.0e10
medium_type = SALT

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/salmon_1964
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
