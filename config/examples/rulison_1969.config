# Rulison, Garfield County, CO (1969-09-10) -- Plowshare gas stimulation
# 40 kt device detonated at 2568 m depth in Williams Fork (Mesaverde) Sandstone
# Site: Garfield County, CO, ~64 km NE of Grand Junction (~39.40 N, -107.95 E)
#
# Purpose: Stimulate natural-gas recovery from the tight Mesaverde
# sandstone of the Piceance Basin. Second of three Plowshare
# gas-stimulation tests (Gasbuggy 1967, Rulison 1969, Rio Blanco 1973).
#
# Coordinate system: z=0 at bottom (5500m depth), z=5500 at surface
# Explosion at 2568 m depth = z=2932 (within Williams Fork Sandstone)
#
# Layer structure (Lombard et al. 1971; Reynolds et al. 1971;
# Piceance Basin):
#   Surface clays / colluvium:  0-100m    (z=5400 to z=5500)
#   Tertiary fluvial sediments: 100-500m  (z=5000 to z=5400)
#   Fort Union Formation:       500-1500m (z=4000 to z=5000)
#   Williams Fork (Mesaverde):  1500-3000m (z=2500 to z=4000; emplacement)
#   Mancos Shale:               3000-5500m (z=0 to z=2500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Surface clays:    vp=1700, vs=850,  rho=2000 -> lambda=2.89e9,  mu=1.45e9
#   Tertiary fluvial: vp=2500, vs=1400, rho=2300 -> lambda=5.36e9,  mu=4.51e9
#   Fort Union:       vp=3500, vs=2000, rho=2400 -> lambda=1.02e10, mu=9.60e9
#   Williams Fork:    vp=4500, vs=2500, rho=2500 -> lambda=1.94e10, mu=1.56e10
#   Mancos Shale:     vp=4200, vs=2300, rho=2500 -> lambda=1.77e10, mu=1.32e10

[SIMULATION]
name = rulison_1969
start_time = 0.0
end_time = 6.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 6500
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 11000.0
Ly = 11000.0
Lz = 5500.0

[ROCK]
# Fallback (Mancos Shale)
density = 2500.0
youngs_modulus = 35.0e9
poissons_ratio = 0.28

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface clays / colluvium: 0-100m depth
z_top = 5500.0
z_bottom = 5400.0
lambda = 2.89e9
mu = 1.45e9
rho = 2000.0

[LAYER_2]
# Tertiary fluvial sediments: 100-500m depth
z_top = 5400.0
z_bottom = 5000.0
lambda = 5.36e9
mu = 4.51e9
rho = 2300.0

[LAYER_3]
# Fort Union Formation: 500-1500m depth
z_top = 5000.0
z_bottom = 4000.0
lambda = 1.02e10
mu = 9.60e9
rho = 2400.0

[LAYER_4]
# Williams Fork (Mesaverde) Sandstone: 1500-3000m depth (emplacement formation)
z_top = 4000.0
z_bottom = 2500.0
lambda = 1.94e10
mu = 1.56e10
rho = 2500.0

[LAYER_5]
# Mancos Shale: 3000-5500m depth
z_top = 2500.0
z_bottom = 0.0
lambda = 1.77e10
mu = 1.32e10
rho = 2500.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 40.0
depth_of_burial = 2568.0
location_x = 5500.0
location_y = 5500.0
location_z = 2932.0
onset_time = 0.0
rise_time = 0.17
cavity_overpressure = 1.0e10
medium_type = SHALE

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/rulison_1969
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 5500.0,5500.0,5500.0

[SEISMOMETER_2]
# 2.5 km east at the surface
sta = STA02
location_xyz = 8000.0,5500.0,5500.0

[SEISMOMETER_3]
# 4.5 km east at the surface
sta = STA04
location_xyz = 10000.0,5500.0,5500.0
