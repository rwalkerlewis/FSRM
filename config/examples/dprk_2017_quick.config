# DPRK 2017 Punggye-ri Nuclear Test (September 3, 2017)
# Estimated yield: ~250 kt, depth ~800 m in granite
# Quick near-field simulation (5 seconds, near-field seismometer only)
#
# Reference: USGS mb 6.3, various estimates 100-370 kt
# Cavity radius ~30-40 m (scaled for granite at this yield/depth)

[SIMULATION]
name = dprk_2017_quick
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 100
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 20
ny = 20
nz = 20
Lx = 20000.0             # 20 km domain
Ly = 20000.0
Lz = 10000.0             # 10 km deep

[ROCK]
# Granite properties for Punggye-ri test site
density = 2650.0          # kg/m^3 (typical granite)
youngs_modulus = 60.0e9   # 60 GPa (granite)
poissons_ratio = 0.25

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 250.0          # ~250 kt estimated yield
depth_of_burial = 800.0   # ~800 m below Mt. Mantap
location_x = 10000.0      # center of domain
location_y = 10000.0
location_z = 9200.0       # 10000 - 800 = 9200 m
onset_time = 0.0
rise_time = 0.1           # ~100 ms for large explosion
cavity_overpressure = 5.0e10  # Pa, high yield in granite

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/dprk_2017
default_quantity = VELOCITY
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
sta = near_5km
location_xyz = 15000.0,10000.0,10000.0

[SEISMOMETER_2]
sta = regional_50km
location_xyz = 20000.0,10000.0,10000.0

[SEISMOMETER_3]
sta = regional_14km
location_xyz = 20000.0,20000.0,10000.0
