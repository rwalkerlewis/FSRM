# Slipping fault under shear loading
# Demonstrates cohesive cell insertion with friction-controlled slip.
#
# The mesh is split along a vertical fault at x=0.5 (strike=90, dip=90).
# Slipping mode enforces Mohr-Coulomb friction constraint: |tau| <= mu * |sigma_n|.
# Pre-stress on the fault has shear traction near the friction limit.
#
# BdResidual works in PETSc 3.25; BdJacobian does not.
# Jacobian assembled manually via addCohesivePenaltyToJacobian.

[SIMULATION]
name = slipping_fault_shear
start_time = 0.0
end_time = 0.001
dt_initial = 0.0001
dt_min = 0.00001
dt_max = 0.001
max_timesteps = 10
output_format = HDF5
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_elastodynamics = true
enable_faults = true
rtol = 1.0e-4
atol = 1.0e-6
max_nonlinear_iterations = 50

[GRID]
nx = 4
ny = 4
nz = 4
Lx = 1.0
Ly = 1.0
Lz = 1.0

[ROCK]
density = 2650.0
youngs_modulus = 10.0e9
poissons_ratio = 0.25

[FAULT]
strike = 90.0
dip = 90.0
center_x = 0.5
center_y = 0.5
center_z = 0.5
length = 2.0
width = 2.0
mode = slipping
friction_coefficient = 0.1
initial_shear_traction = 50.0e6
initial_normal_traction = -100.0e6

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[ABSORBING_BC]
enabled = false
