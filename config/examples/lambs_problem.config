# Lamb's Problem: Point force on elastic half-space surface
# Verifies P-wave, S-wave, and Rayleigh wave propagation
#
# Homogeneous granite: vp=5500 m/s, vs=3175 m/s, rho=2650 kg/m3
#   lambda = rho*(vp^2 - 2*vs^2) = 2650*(30250000 - 20160625) = 26736544 = 2.674e10
#   mu = rho*vs^2 = 2650*10080625 = 2.671e10
#
# Source: Vertical point force at (2000, 2000, 4000) (surface = z_max)
# Receivers: Surface line from source to (4000, 2000, 4000)
# Expected arrivals at 2000m offset:
#   t_P = 2000/5500 = 0.364s
#   t_S = 2000/3175 = 0.630s
#   t_R = 2000/(0.92*3175) = 0.685s

[SIMULATION]
name = lambs_problem
start_time = 0.0
end_time = 1.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.005
max_timesteps = 1000
output_frequency = 500
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 10
ny = 10
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 4000.0

[ROCK]
density = 2650.0
youngs_modulus = 63.4e9
poissons_ratio = 0.25

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = free

[ABSORBING_BC]
enabled = true
faces = x_min, x_max, y_min, y_max, z_min

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 0.001
depth_of_burial = 0.0
location_x = 2000.0
location_y = 2000.0
location_z = 3900.0
onset_time = 0.0
rise_time = 0.01
cavity_overpressure = 1.0e8

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/lambs_problem
default_quantity = DISPLACEMENT
default_sample_rate_hz = 200.0

[SEISMOMETER_1]
sta = R0500
location_xyz = 2500.0,2000.0,4000.0

[SEISMOMETER_2]
sta = R1000
location_xyz = 3000.0,2000.0,4000.0

[SEISMOMETER_3]
sta = R1500
location_xyz = 3500.0,2000.0,4000.0

[SEISMOMETER_4]
sta = R2000
location_xyz = 4000.0,2000.0,3999.0
