# Schooner, NTS Pahute Mesa U-20u (1968-12-08) -- Plowshare cratering shot
# 30 kt device detonated at 111 m depth in basalt/welded tuff
# Site: NTS Pahute Mesa, NV (~37.30 N, -116.57 E)
#
# Purpose: Final Plowshare cratering experiment. Created an apparent
# crater 79 m deep, 257 m across. Scaled depth-of-burial (SDOB) ~ 36
# m/kt^(1/3.4), well into the cratering regime (Knox & Terhune 1965;
# Glasstone & Dolan 1977 ch. 6).
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 111 m depth = z=1889 (within shallow welded tuff,
# straddling the basalt cap typical of Pahute Mesa craters)
#
# Layer structure (Pahute Mesa NW quadrant, Closmann 1969 analog):
#   Surface alluvium / weathered tuff: 0-50m   (z=1950 to z=2000)
#   Welded tuff:                       50-300m (z=1700 to z=1950; emplacement)
#   Basalt:                            300-1000m (z=1000 to z=1700)
#   Bedded tuff:                       1000-2000m (z=0 to z=1000)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Alluvium / weath. tuff: vp=1800, vs=900,  rho=2000 -> lambda=3.24e9,  mu=1.62e9
#   Welded tuff:            vp=3500, vs=2000, rho=2300 -> lambda=9.78e9,  mu=9.20e9
#   Basalt:                 vp=4500, vs=2500, rho=2600 -> lambda=2.02e10, mu=1.63e10
#   Bedded tuff:            vp=3300, vs=1800, rho=2300 -> lambda=1.01e10, mu=7.45e9

[SIMULATION]
name = schooner_1968
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (bedded tuff)
density = 2300.0
youngs_modulus = 19.0e9
poissons_ratio = 0.27

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface alluvium / weathered tuff: 0-50m depth
z_top = 2000.0
z_bottom = 1950.0
lambda = 3.24e9
mu = 1.62e9
rho = 2000.0

[LAYER_2]
# Welded tuff: 50-300m depth (emplacement formation)
z_top = 1950.0
z_bottom = 1700.0
lambda = 9.78e9
mu = 9.20e9
rho = 2300.0

[LAYER_3]
# Basalt: 300-1000m depth
z_top = 1700.0
z_bottom = 1000.0
lambda = 2.02e10
mu = 1.63e10
rho = 2600.0

[LAYER_4]
# Bedded tuff: 1000-2000m depth
z_top = 1000.0
z_bottom = 0.0
lambda = 1.01e10
mu = 7.45e9
rho = 2300.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 30.0
depth_of_burial = 111.0
location_x = 2000.0
location_y = 2000.0
location_z = 1889.0
onset_time = 0.0
rise_time = 0.16
cavity_overpressure = 1.0e10
medium_type = TUFF

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/schooner_1968
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
