# Faultless, Hot Creek Valley, NV (1968-01-19) -- Central Nevada Test Area
# ~1000 kt (1 Mt) device detonated at 975 m depth in Cenozoic volcanics
# Site: Hot Creek Valley, Nye County, NV (~38.63 N, -116.22 E)
#
# Purpose: Evaluate the Central Nevada Test Area as an alternative to
# the NTS for high-yield tests. Triggered visible surface fault offset
# along pre-existing scarps; the result was a single shot rather than a
# campaign (Hamilton & Healy 1969; McKeown & Dickey 1969).
#
# Coordinate system: z=0 at bottom (3000m depth), z=3000 at surface
# Explosion at 975 m depth = z=2025 (within Tertiary volcanics)
#
# Layer structure (Hamilton & Healy 1969; McKeown & Dickey 1969):
#   Quaternary alluvium:           0-300m   (z=2700 to z=3000)
#   Tertiary volcanics (tuff/lava): 300-1500m (z=1500 to z=2700; emplacement)
#   Pre-Tertiary basement:         1500-3000m (z=0 to z=1500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Alluvium:           vp=1800, vs=900,  rho=1900 -> lambda=3.08e9,  mu=1.54e9
#   Tertiary volcanics: vp=4000, vs=2200, rho=2400 -> lambda=1.52e10, mu=1.16e10
#   Pre-Tertiary base:  vp=5500, vs=3100, rho=2700 -> lambda=2.98e10, mu=2.59e10

[SIMULATION]
name = faultless_1968
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 6000.0
Ly = 6000.0
Lz = 3000.0

[ROCK]
# Fallback (Pre-Tertiary basement)
density = 2700.0
youngs_modulus = 70.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Quaternary alluvium: 0-300m depth
z_top = 3000.0
z_bottom = 2700.0
lambda = 3.08e9
mu = 1.54e9
rho = 1900.0

[LAYER_2]
# Tertiary volcanics: 300-1500m depth (emplacement formation)
z_top = 2700.0
z_bottom = 1500.0
lambda = 1.52e10
mu = 1.16e10
rho = 2400.0

[LAYER_3]
# Pre-Tertiary basement: 1500-3000m depth
z_top = 1500.0
z_bottom = 0.0
lambda = 2.98e10
mu = 2.59e10
rho = 2700.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 1000.0
depth_of_burial = 975.0
location_x = 3000.0
location_y = 3000.0
location_z = 2025.0
onset_time = 0.0
rise_time = 0.5
cavity_overpressure = 1.0e10
medium_type = ALLUVIUM

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/faultless_1968
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 3000.0,3000.0,3000.0

[SEISMOMETER_2]
# 1.2 km east at the surface
sta = STA01
location_xyz = 4200.0,3000.0,3000.0

[SEISMOMETER_3]
# 2.4 km east at the surface
sta = STA02
location_xyz = 5400.0,3000.0,3000.0
