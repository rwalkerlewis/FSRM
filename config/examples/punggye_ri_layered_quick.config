# Quick version of Punggye-ri layered example
# Smaller mesh and shorter time for fast demonstration
# Full version: punggye_ri_layered.config (15x15x10 mesh, 5.0s)

[SIMULATION]
name = punggye_ri_quick
start_time = 0.0
end_time = 1.0
dt_initial = 0.005
dt_min = 0.001
dt_max = 0.01
max_timesteps = 200
output_frequency = 50
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 8
ny = 8
nz = 6
Lx = 10000.0
Ly = 10000.0
Lz = 5000.0

[ROCK]
density = 2650.0
youngs_modulus = 70.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
z_top = 5000.0
z_bottom = 4800.0
lambda = 9.00e9
mu = 8.98e9
rho = 2200.0

[LAYER_2]
z_top = 4800.0
z_bottom = 4000.0
lambda = 1.69e10
mu = 1.69e10
rho = 2500.0

[LAYER_3]
z_top = 4000.0
z_bottom = 0.0
lambda = 2.97e10
mu = 2.97e10
rho = 2650.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 250.0
depth_of_burial = 800.0
location_x = 5000.0
location_y = 5000.0
location_z = 4200.0
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/punggye_ri
default_quantity = DISPLACEMENT
default_sample_rate_hz = 200.0

[SEISMOMETER_1]
sta = SPALL
location_xyz = 5000.0,5000.0,5000.0

[SEISMOMETER_2]
sta = STA05
location_xyz = 7000.0,5000.0,5000.0
