[SIMULATION]
name = explosion_seismogram
start_time = 0.0
end_time = 2.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 2000
output_frequency = 100
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 10
ny = 10
nz = 10
Lx = 10000.0
Ly = 10000.0
Lz = 5000.0

[ROCK]
density = 2700.0
youngs_modulus = 50.0e9
poissons_ratio = 0.25

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 10.0
depth_of_burial = 300.0
location_x = 5000.0
location_y = 5000.0
location_z = 4700.0
onset_time = 0.0
rise_time = 0.05
cavity_overpressure = 1.0e10

[SEISMOMETERS]
enabled = true
format = SAC
output_dir = output/seismograms
channels = velocity,acceleration
station_1 = surface_1km,6000.0,5000.0,5000.0
station_2 = surface_3km,8000.0,5000.0,5000.0
station_3 = surface_5km,10000.0,5000.0,5000.0
