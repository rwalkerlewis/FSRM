# Elastoplastic compression of a granite column
# Demonstrates Drucker-Prager plasticity with return mapping
#
# Applies u_z=-0.001 axial compression to a 1x1x2 m granite column.
# With c=5 MPa and phi=30 deg, the DP yield stress under uniaxial
# compression is approximately 17.3 MPa. Under oedometric conditions
# (roller sides), M = lambda+2mu = 60 GPa, sigma = M*eps = 60 MPa,
# which exceeds yield.

[SIMULATION]
name = elastoplastic_compression
start_time = 0.0
end_time = 1.0
dt_initial = 0.1
dt_min = 0.01
dt_max = 1.0
max_timesteps = 20
output_format = HDF5
output_frequency = 1
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_elastodynamics = false
rtol = 1.0e-8
atol = 1.0e-10
max_nonlinear_iterations = 50

[GRID]
nx = 6
ny = 6
nz = 12
Lx = 1.0
Ly = 1.0
Lz = 2.0

[ROCK]
density = 2650.0
youngs_modulus = 50.0e9
poissons_ratio = 0.25

[PLASTICITY]
enabled = true
cohesion = 5.0e6
friction_angle = 30.0
dilation_angle = 0.0
hardening_modulus = 0.0

[BOUNDARY_CONDITIONS]
bottom = fixed
sides = roller
top = compression
