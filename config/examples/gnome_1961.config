# Project Gnome, Carlsbad, New Mexico (1961) -- First US Plowshare Test
# 3.1 kt device detonated at 361m depth in Salado Salt Formation
#
# Purpose: Study possible peaceful uses of nuclear explosions, including
# heat recovery, isotope production, and neutron physics
#
# Coordinate system: z=0 at bottom (5000m depth), z=5000 at surface
# Explosion at 361m depth = z=4639 (within Salado Salt)
#
# Layer structure (simplified from Carlsbad basin geology):
#   Alluvium/Gatuna Fm:   0-50m depth   (z=4950 to z=5000)
#   Rustler Fm (anhydrite): 50-200m depth (z=4800 to z=4950)
#   Salado Salt:          200-600m depth (z=4400 to z=4800)
#   Castile Fm (anhydrite): 600-5000m depth (z=0 to z=4400)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Alluvium:          vp=2000, vs=1000, rho=1800 -> lambda=3.60e9, mu=1.80e9
#   Rustler anhydrite: vp=5000, vs=2900, rho=2800 -> lambda=2.30e10, mu=2.36e10
#   Salado Salt:       vp=4500, vs=2500, rho=2200 -> lambda=1.70e10, mu=1.38e10
#   Castile anhydrite: vp=5500, vs=3200, rho=2900 -> lambda=2.78e10, mu=2.97e10

[SIMULATION]
name = gnome_1961
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 30000.0
Ly = 30000.0
Lz = 5000.0

[ROCK]
# Fallback (Castile anhydrite)
density = 2900.0
youngs_modulus = 75.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Alluvium/Gatuna Fm: surface to 50m depth
z_top = 5000.0
z_bottom = 4950.0
lambda = 3.60e9
mu = 1.80e9
rho = 1800.0

[LAYER_2]
# Rustler Formation anhydrite: 50m to 200m depth
z_top = 4950.0
z_bottom = 4800.0
lambda = 2.30e10
mu = 2.36e10
rho = 2800.0

[LAYER_3]
# Salado Salt: 200m to 600m depth (emplacement formation)
z_top = 4800.0
z_bottom = 4400.0
lambda = 1.70e10
mu = 1.38e10
rho = 2200.0

[LAYER_4]
# Castile Formation anhydrite: 600m to 5000m depth
z_top = 4400.0
z_bottom = 0.0
lambda = 2.78e10
mu = 2.97e10
rho = 2900.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 3.1
depth_of_burial = 361.0
location_x = 15000.0
location_y = 15000.0
location_z = 4639.0
onset_time = 0.0
rise_time = 0.01
cavity_overpressure = 5.0e9

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/gnome_1961
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 15000.0,15000.0,5000.0

[SEISMOMETER_2]
# 5 km to the east at surface
sta = STA05
location_xyz = 20000.0,15000.0,5000.0

[SEISMOMETER_3]
# 10 km to the east at surface
sta = STA10
location_xyz = 25000.0,15000.0,5000.0
