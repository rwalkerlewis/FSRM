# Lop Nor 1976-10-17, Lop Nor Test Site, Xinjiang, CN
# ~4 kt yield, detonated at ~250 m depth in Beishan-equivalent granite
# Site: Lop Nor, Xinjiang Uyghur Autonomous Region (~41.55 N, 88.78 E)
#
# Purpose: First Chinese underground nuclear test (the prior PRC tests
# were atmospheric). Conducted in a tunnel emplacement through the
# Beishan-equivalent granite of the Lop Nor basement.
#
# Coordinate system: z=0 at bottom (2000m depth), z=2000 at surface
# Explosion at 250 m depth = z=1750 (within weathered granite)
#
# Layer structure (Wen et al. 2006; Yang et al. 2003; Lop Nor basement):
#   Surface alluvium / talus: 0-50m    (z=1950 to z=2000)
#   Weathered granite:        50-300m  (z=1700 to z=1950; emplacement)
#   Competent granite:        300-1500m (z=500 to z=1700)
#   Deep granite:             1500-2000m (z=0 to z=500)
#
# Elastic moduli from: lambda = rho*(vp^2 - 2*vs^2), mu = rho*vs^2
#   Surface alluvium:  vp=1500, vs=750,  rho=1900 -> lambda=2.14e9,  mu=1.07e9
#   Weathered granite: vp=3500, vs=1900, rho=2400 -> lambda=1.21e10, mu=8.66e9
#   Competent granite: vp=5500, vs=3100, rho=2700 -> lambda=2.98e10, mu=2.59e10
#   Deep granite:      vp=6000, vs=3400, rho=2750 -> lambda=3.54e10, mu=3.18e10

[SIMULATION]
name = lop_nor_1976
start_time = 0.0
end_time = 5.0
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
max_timesteps = 5000
output_frequency = 500
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 15
ny = 15
nz = 10
Lx = 4000.0
Ly = 4000.0
Lz = 2000.0

[ROCK]
# Fallback (deep granite)
density = 2750.0
youngs_modulus = 75.0e9
poissons_ratio = 0.25

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Surface alluvium / talus: 0-50m depth
z_top = 2000.0
z_bottom = 1950.0
lambda = 2.14e9
mu = 1.07e9
rho = 1900.0

[LAYER_2]
# Weathered granite: 50-300m depth (emplacement formation)
z_top = 1950.0
z_bottom = 1700.0
lambda = 1.21e10
mu = 8.66e9
rho = 2400.0

[LAYER_3]
# Competent granite: 300-1500m depth
z_top = 1700.0
z_bottom = 500.0
lambda = 2.98e10
mu = 2.59e10
rho = 2700.0

[LAYER_4]
# Deep granite: 1500-2000m depth
z_top = 500.0
z_bottom = 0.0
lambda = 3.54e10
mu = 3.18e10
rho = 2750.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 4.0
depth_of_burial = 250.0
location_x = 2000.0
location_y = 2000.0
location_z = 1750.0
onset_time = 0.0
rise_time = 0.08
cavity_overpressure = 1.0e10
medium_type = GRANITE

[BOUNDARY_CONDITIONS]
bottom = free
sides = free
top = free

[ABSORBING_BC]
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/lop_nor_1976
default_quantity = DISPLACEMENT
default_sample_rate_hz = 100.0

[SEISMOMETER_1]
# Surface directly above explosion (spall check)
sta = SPALL
location_xyz = 2000.0,2000.0,2000.0

[SEISMOMETER_2]
# 800 m east at the surface
sta = STA01
location_xyz = 2800.0,2000.0,2000.0

[SEISMOMETER_3]
# 1600 m east at the surface
sta = STA02
location_xyz = 3600.0,2000.0,2000.0
