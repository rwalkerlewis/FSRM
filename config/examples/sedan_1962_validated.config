# Sedan 1962 -- Validated near-field configuration (M1.3 target)
#
# This is the M1.3 (run + receivers) Sedan configuration produced for
# the nuclear-explosion-monitoring (NEM) roadmap.  It is distinct from
# the legacy `config/examples/sedan_1962.config` demo, which uses a
# coarse 15x15x10 structured grid with the opposite z-convention; the
# legacy file is intentionally left in place for backward compatibility.
#
# Mesh
#   File:    meshes/historical/sedan_1962_nearfield.msh (committed)
#   Source:  scripts/meshing/sedan_1962_nearfield.geo
#   Stats:   50,780 tets, min edge 31.6 m, max edge 669.4 m, 154 fine
#            cells whose centroid is within 100 m of the shot point.
#   Convention: z = 0 at the free surface, z = -2000 at the bottom.
#               (Depth-positive-down with z negative.)
#               This DIFFERS from the legacy sedan_1962.config, which
#               uses z = 0 at bottom and z = 5000 at the surface.
#   The depth-evaluation rule in Simulator::populateAuxFieldsByDepth
#   is `z <= z_top && z > z_bottom`, so each LAYER_N block must
#   satisfy z_top > z_bottom even when both values are negative.
#
# Velocity model
#   The single source of truth for the layer parameters is
#   models/sedan_1962.vel (ASCII, three-layer 1-D model with citations
#   to Carlson and Roberts (1963), Vortman (1968), and Murphy (1996)).
#   That ASCII file is documentation; FSRM does not parse it.  The
#   numerical values are mirrored here as LAYER_N blocks consumed by
#   Simulator::loadConfig (around line 743 of src/core/Simulator.cpp).
#
# Layer parameter derivation (Lame parameters from models/sedan_1962.vel):
#   Formulas: mu = rho * vs^2,  lambda = rho * (vp^2 - 2*vs^2)
#
#   Layer 1 -- Yucca Flat alluvium (Vp=1500, Vs=700, rho=1900)
#     mu     = 1900 * 700^2                     = 9.310e+08 Pa
#     lambda = 1900 * (1500^2 - 2*700^2)
#            = 1900 * (2.25e6 - 9.8e5)
#            = 1900 * 1.27e6                    = 2.413e+09 Pa
#
#   Layer 2 -- Welded / bedded tuff (Vp=2500, Vs=1300, rho=2100)
#     mu     = 2100 * 1300^2                    = 3.549e+09 Pa
#     lambda = 2100 * (2500^2 - 2*1300^2)
#            = 2100 * (6.25e6 - 3.38e6)
#            = 2100 * 2.87e6                    = 6.027e+09 Pa
#
#   Layer 3 -- Paleozoic basement (Vp=3500, Vs=1900, rho=2400)
#     mu     = 2400 * 1900^2                    = 8.664e+09 Pa
#     lambda = 2400 * (3500^2 - 2*1900^2)
#            = 2400 * (1.225e7 - 7.22e6)
#            = 2400 * 5.03e6                    = 1.207e+10 Pa
#
# Discrepancies from the session 2 brief
#   The session 2 brief tabulates `[LAYER_1] lambda = 6.51e8`.  Honest
#   re-derivation from models/sedan_1962.vel gives lambda = 2.413e9 Pa
#   (a factor of 3.7 difference, well above the 1% tolerance).  Per the
#   brief's own instruction ("If you find any value differs from a
#   careful re-derivation by more than 1%, use your computed value and
#   note the discrepancy in the file header"), this file uses the
#   recomputed value.  The Layer 1 mu and Layer 2 / Layer 3 values in
#   the brief match the re-derivation to within 0.1 percent.
#
#   The brief also lists `youngs_modulus = 21.5e9` for the basement
#   fallback; recomputation gives E = mu*(3*lambda + 2*mu)/(lambda+mu)
#   = 8.664e9 * (3*1.207e10 + 2*8.664e9) / (1.207e10 + 8.664e9)
#   = 22.37 GPa.  The Poisson ratio rounds to 0.291.  Both recomputed
#   values are used below; the difference from the brief is ~4 percent.
#
# Coupling to the elastodynamic core uses Simulator::addExplosionSourceToResidual
# (moment-tensor injection at the source cell).  The high-resolution
# sphere in the mesh is anchored at the shot point (0, 0, -194) so the
# source cell is small enough to resolve a 5 Hz peak frequency.

[SIMULATION]
name = sedan_1962_validated
start_time = 0.0
end_time = 2.0
# CFL note: at vp = 3500 m/s in basement and a min edge of ~31.6 m, the
# explicit CFL limit is dt_cfl = h / vp ~ 31.6 / 3500 ~ 9 ms.  TSALPHA2
# is implicit so dt is fidelity-limited, not stability-limited; we
# choose dt_max = 5 ms to resolve a 5 Hz target band (~40 samples per
# period at the Nyquist-comfortable end).
dt_initial = 0.0025
dt_min = 0.0005
dt_max = 0.005
max_timesteps = 800
output_frequency = 200
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = true
enable_faults = false
enable_elastodynamics = true
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
mesh_type = GMSH
mesh_file = ../meshes/historical/sedan_1962_nearfield.msh

[ROCK]
# Fallback (basement) values; recomputed from Layer 3 of
# models/sedan_1962.vel.  Used only for cells outside any LAYER_N
# z-range and for kernel default initialization.
density = 2400.0
youngs_modulus = 22.37e9
poissons_ratio = 0.291

[MATERIAL]
heterogeneous = true
gravity = 0.0

[LAYER_1]
# Yucca Flat alluvium (top): surface (z=0) to 100 m depth (z=-100).
z_top = 0.0
z_bottom = -100.0
lambda = 2.413e9
mu = 9.310e8
rho = 1900.0

[LAYER_2]
# Welded / bedded tuff: 100 m to 500 m depth (z=-100 to z=-500).
z_top = -100.0
z_bottom = -500.0
lambda = 6.027e9
mu = 3.549e9
rho = 2100.0

[LAYER_3]
# Paleozoic basement: 500 m to bottom of mesh (z=-500 to z=-2000).
z_top = -500.0
z_bottom = -2000.0
lambda = 1.207e10
mu = 8.664e9
rho = 2400.0

[EXPLOSION_SOURCE]
type = UNDERGROUND_NUCLEAR
yield_kt = 104.0
depth_of_burial = 194.0
location_x = 0.0
location_y = 0.0
location_z = -194.0
onset_time = 0.0
# rise_time ~ 1 / (2*pi*fc) for Sedan-class fc ~ 3 Hz.
rise_time = 0.05
cavity_overpressure = 1.0e10

[BOUNDARY_CONDITIONS]
# Legacy hint; the actual surface vs absorbing behavior is set by the
# [ABSORBING_BC] block below.
bottom = free
sides = free
top = free

[ABSORBING_BC]
# Free surface on z_max (the top, z = 0); Clayton-Engquist on the four
# lateral faces and the bottom.
enabled = true
x_min = true
x_max = true
y_min = true
y_max = true
z_min = true
z_max = false

[SEISMOMETERS]
enabled = true
formats = SAC
output_dir = output/sedan_1962_validated
default_quantity = VELOCITY
# 200 Hz (Nyquist 100 Hz) is well above the ~3 Hz mesh-accurate band.
default_sample_rate_hz = 200.0

# Free-surface receivers (z = 0)
[SEISMOMETER_1]
sta = SUR_R0100
location_xyz = 100.0,0.0,0.0
[SEISMOMETER_2]
sta = SUR_R0500
location_xyz = 500.0,0.0,0.0
[SEISMOMETER_3]
sta = SUR_R1000
location_xyz = 1000.0,0.0,0.0
[SEISMOMETER_4]
sta = SUR_R2000
location_xyz = 2000.0,0.0,0.0

# Source-depth receivers (z = -194)
[SEISMOMETER_5]
sta = DEP_R0100
location_xyz = 100.0,0.0,-194.0
[SEISMOMETER_6]
sta = DEP_R0500
location_xyz = 500.0,0.0,-194.0
[SEISMOMETER_7]
sta = DEP_R1000
location_xyz = 1000.0,0.0,-194.0
[SEISMOMETER_8]
sta = DEP_R2000
location_xyz = 2000.0,0.0,-194.0
