# Gmsh box elastostatics test
# Loads a 10x10x10 m tetrahedral mesh from Gmsh MSH2 format
# and runs a simple uniaxial compression solve.

[SIMULATION]
enable_geomechanics = true
solid_model = ELASTIC
fluid_model = NONE
max_timesteps = 1
dt_initial = 1.0
start_time = 0.0
end_time = 1.0

[GRID]
mesh_type = GMSH
mesh_file = meshes/test_box_gmsh.msh
gmsh_boundaries = xmin, xmax, ymin, ymax, zmin, zmax

[ROCK]
density = 2650.0
youngs_modulus = 50.0e9
poisson_ratio = 0.25
