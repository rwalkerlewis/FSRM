# ==============================================================================
# DPRK 2017-09-03 — Far-Field Synthetic Seismograms via Numerical Wave Equation
# ==============================================================================
#
# Purpose:
#   Solve the elastic wave equation numerically using FSRM's ADER-DG solver
#   to propagate seismic waves from the 2017 DPRK nuclear test source to
#   regional distances (up to 100 km), producing synthetic seismograms
#   at virtual seismometer positions.
#
#   This config uses COUPLED_ANALYTIC mode: the Mueller-Murphy Reduced
#   Displacement Potential (RDP) is applied as the source time function,
#   and the resulting wavefield is then numerically propagated through a
#   1-D layered crustal velocity model using the ADER-DG elastodynamics
#   solver with PML absorbing boundaries.
#
# Why a separate far-field config?
#   The near-field config (dprk_2017_punggye_ri_coupled_granite.config) uses
#   an 80 km domain with elastoplastic material, AMR near the source, and
#   detailed near-field phenomenology (cavity, damage zones, spall, fracture).
#   That is appropriate for the first few km of propagation.  At regional
#   distances (10–100 km), however:
#     • The wavefield is linear-elastic — no plasticity or damage needed
#     • Crustal layering dominates waveform character (Pn, Pg, Sn, Lg, Rg)
#     • A structured grid with uniform 500 m spacing is more efficient
#     • A larger domain (200 km) is required to place far-field receivers
#     • The COUPLED_ANALYTIC mode avoids re-solving the expensive nonlinear
#       near-source problem; it injects the analytical Mueller-Murphy RDP
#       directly as an equivalent-force source at the detonation point
#
# Frequency content:
#   500 m cell spacing with DG order 4 → effective resolution ~125 m per DOF
#   Minimum resolvable wavelength ~1 km (4 points per wavelength)
#   At Vp=5.6 km/s → max frequency ~5.6 Hz
#   At Vs=3.25 km/s → max frequency ~3.25 Hz
#   This is adequate for regional seismology (typical analysis band 0.5–4 Hz)
#
# Travel-time estimates (source at center, receivers on surface):
#   P-wave to 100 km: ~100/8.0 = 12.5 s (Pn) or 100/5.6 = 17.9 s (Pg)
#   S-wave to 100 km: ~100/4.5 = 22.2 s (Sn) or 100/3.25 = 30.8 s (Sg)
#   30 s end_time captures all body-wave arrivals; Rg at 100 km arrives later
#   but has low amplitude — extend to 60 s if surface waves are needed
#
# Event summary (public sources):
#   Date/time : 2017-09-03 03:30:01 UTC
#   Location  : 41.300°N, 129.076°E  (Punggye-ri Nuclear Test Site, DPRK)
#   Depth     : 760 m under Mt. Mantap
#   Yield     : ~250 kt (fully coupled in granite)
#   Character : mb 6.1–6.3, Mw 5.8–6.1
#
# References:
#   Mueller & Murphy (1971) — Seismic source model for underground explosions
#   Patton (1988)           — Corner frequency scaling for nuclear tests
#   Zhao et al. (2017)      — DPRK test yield estimation from body waves
#   Kim & Richards (2007)   — Punggye-ri test site characterization
#   Yao et al. (2018)       — Source characteristics of DPRK nuclear tests
#   Wei (2017)              — InSAR observations of Mt. Mantap collapse
#
# Run:
#   mpirun -np 16 fsrm -c config/dprk_2017_punggye_ri_far_field_seismograms.config
# ==============================================================================

[SIMULATION]
name = dprk_2017_far_field_seismograms
description = Far-field wave propagation from 2017 DPRK 250 kt nuclear test — synthetic seismograms to 100 km

start_time = 0.0
end_time = 30.0                      # 30 s — captures P at 100 km (~13 s) + S (~27 s) + margin

# Timestep control:
#   dt_initial = 1e-4 s resolves the Mueller-Murphy source pulse (rise_time 80 ms)
#   dt_max = 0.005 s keeps CFL < 0.45 for 500 m cells at Vp = 8 km/s
#   max_timesteps = 200000 is conservative (30 s / 5e-3 = 6000 steps if fully at dt_max)
dt_initial = 1.0e-4
dt_min = 1.0e-6
dt_max = 0.005
max_timesteps = 200000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 500
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 50000

# COUPLED_ANALYTIC mode:
#   The Mueller-Murphy RDP is used as the analytical source time function.
#   FSRM converts it to equivalent body forces at the source location and
#   propagates the resulting wavefield numerically through the layered model.
#   No cavity, damage, or plasticity is computed — the near-source nonlinear
#   physics is captured entirely by the RDP.
explosion_solve_mode = COUPLED_ANALYTIC

# Physics: pure linear elastodynamics (no plasticity, fracture, or thermal)
fluid_model = NONE
solid_model = ELASTIC
enable_elastodynamics = true
enable_geomechanics = false
enable_thermal = false
enable_fractures = false
enable_plasticity = false

# High-order DG with ADER time integration and local time stepping
#   DG order 4 → 5 DOFs per direction per element → effective ~100 m resolution
#   LTS rate 2 → coarse (slow-Vp) elements take 2× larger timesteps
use_discontinuous_galerkin = true
dg_order = 4
use_ader_time_integration = true
enable_local_time_stepping = true
lts_rate = 2

# CPU-only (no GPU required for this problem size with structured grid)
use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source — DPRK 2017-09-03 (Coupled 250 kt)
# ==============================================================================
# In COUPLED_ANALYTIC mode the source is represented by the Mueller-Murphy
# reduced displacement potential (RDP), which encapsulates the entire
# near-field nonlinear process into a far-field equivalent source.
# The RDP is convolved with the propagation Green's functions by FSRM's DG solver.

[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 250.0                     # 250 kt — 6th DPRK test (Zhao et al. 2017)
depth_of_burial = 760.0              # m below surface (Wei 2017)

# Source placed at center of the 200 km × 200 km domain
location_x = 100000.0                # m (center of domain along x)
location_y = 100000.0                # m (center of domain along y)
location_z = -760.0                  # m (below free surface)

# Cavity radius from empirical scaling:
#   R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)
#   For W=250 kt, ρ=2700 kg/m³ → R_c ≈ 280 m
# In COUPLED_ANALYTIC mode the cavity is not physically modeled, but the
# radius is used to compute the Mueller-Murphy RDP parameters.
cavity_radius = 280.0
cavity_radius_scaling = OVERRIDE

# Damage zones (used for RDP parameterization only in COUPLED_ANALYTIC mode)
crushed_zone_radius = 700.0          # ~2.5× cavity
fractured_zone_radius = 1400.0       # ~5× cavity
damaged_zone_radius = 2800.0         # ~10× cavity

# Mueller-Murphy source model with Patton corner-frequency scaling
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION

# Rise time and overshoot:
#   For 250 kt coupled shot: rise_time ≈ 80 ms, moderate overshoot
rise_time = 0.08
overshoot_factor = 1.2

# Moment tensor decomposition (Yao et al. 2018):
#   Dominated by isotropic (explosion) with CLVD from Mt. Mantap collapse
#   and small DC from tectonic release
isotropic_fraction = 0.70
clvd_fraction = 0.20
double_couple_fraction = 0.10

# Scalar seismic moment: M0 ≈ 2.5×10^19 N·m for coupled 250 kt
scalar_moment = 2.5e19

# Spall parameters (used in RDP computation)
enable_spall = true
spall_depth = 200.0                  # m
spall_velocity = 5.0                 # m/s

# ==============================================================================
# Grid — Large structured domain for regional wave propagation
# ==============================================================================
# 200 km × 200 km × 60 km domain with 500 m base cell spacing.
# The source is at the center (100 km, 100 km) so receivers can be placed
# at up to 100 km radial distance in any azimuthal direction.
#
# Grid dimensions:
#   400 × 400 × 120 = 19.2 M cells
#   With DG order 4: ~2.4 billion DOFs (3-component displacement)
#   This requires ~16 MPI ranks × ~32 GB RAM each for a 30 s simulation
#
# Depth extent (60 km) includes:
#   0–15 km    : upper crust (source region + shallow phases)
#   15–30 km   : middle/lower crust (Moho reflections, PmP)
#   30–60 km   : upper mantle (Pn head wave, Sn)
#   PML at bottom absorbs downgoing energy without spurious reflections

[GRID]
nx = 400
ny = 400
nz = 120

Lx = 200000.0                       # 200 km
Ly = 200000.0                       # 200 km
Lz = 60000.0                        # 60 km

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic reference for post-processing (DPRK Punggye-ri)
input_crs = EPSG:4326
model_crs = EPSG:32652              # UTM Zone 52N
use_local_coordinates = true
local_origin_x = 129.076             # Event longitude (°E)
local_origin_y = 41.300              # Event latitude  (°N)
local_origin_z = 0.0

# No AMR for far-field — uniform structured grid is optimal for wave propagation
# at these length scales (500 m spacing resolves wavelengths ≥ 2 km everywhere)

# ==============================================================================
# Material Properties — Korean Peninsula 1-D Layered Crustal Model
# ==============================================================================
# A horizontally-layered 1-D velocity model for the Korean Peninsula, derived
# from Kim & Richards (2007) and regional seismic studies.  Six layers span
# from surface to upper mantle.  Each layer is assigned as a separate ROCK
# section; FSRM maps them to depth ranges in the structured grid.
#
# This is a simplified 1-D model — appropriate for far-field propagation where
# lateral heterogeneity averages out and the dominant waveform character comes
# from vertical velocity gradients (Moho bounce, head waves, etc.).
#
# Layer structure:
#   Layer 1:  0–2 km    Weathered granite / regolith        Vp=4.5  Vs=2.6
#   Layer 2:  2–8 km    Upper crust (granite/syenite)       Vp=5.6  Vs=3.25
#   Layer 3:  8–18 km   Mid-crust (granodiorite)            Vp=6.1  Vs=3.55
#   Layer 4:  18–30 km  Lower crust (mafic granulite)       Vp=6.5  Vs=3.75
#   Layer 5:  30–40 km  Lowermost crust / Moho transition   Vp=7.0  Vs=4.05
#   Layer 6:  40–60 km  Upper mantle (peridotite)           Vp=8.05 Vs=4.55

[ROCK_LAYER1]
name = Weathered_Granite_Regolith
constitutive_model = ELASTIC
depth_top = 0.0
depth_bottom = 2000.0
density = 2400.0                     # kg/m³
p_wave_velocity = 4500.0             # m/s
s_wave_velocity = 2600.0             # m/s
youngs_modulus = 24.0e9              # GPa (derived from Vp, Vs, ρ)
poisson_ratio = 0.25
quality_factor_p = 150.0             # moderate attenuation in weathered rock
quality_factor_s = 75.0

[ROCK_LAYER2]
name = Upper_Crust_Granite_Syenite
constitutive_model = ELASTIC
depth_top = 2000.0
depth_bottom = 8000.0
density = 2700.0
p_wave_velocity = 5600.0
s_wave_velocity = 3250.0
youngs_modulus = 52.0e9
poisson_ratio = 0.25
quality_factor_p = 350.0
quality_factor_s = 175.0

[ROCK_LAYER3]
name = Middle_Crust_Granodiorite
constitutive_model = ELASTIC
depth_top = 8000.0
depth_bottom = 18000.0
density = 2800.0
p_wave_velocity = 6100.0
s_wave_velocity = 3550.0
youngs_modulus = 58.0e9
poisson_ratio = 0.26
quality_factor_p = 500.0
quality_factor_s = 250.0

[ROCK_LAYER4]
name = Lower_Crust_Mafic_Granulite
constitutive_model = ELASTIC
depth_top = 18000.0
depth_bottom = 30000.0
density = 2900.0
p_wave_velocity = 6500.0
s_wave_velocity = 3750.0
youngs_modulus = 76.0e9
poisson_ratio = 0.26
quality_factor_p = 600.0
quality_factor_s = 300.0

[ROCK_LAYER5]
name = Lowermost_Crust_Moho_Transition
constitutive_model = ELASTIC
depth_top = 30000.0
depth_bottom = 40000.0
density = 3100.0
p_wave_velocity = 7000.0
s_wave_velocity = 4050.0
youngs_modulus = 105.0e9
poisson_ratio = 0.27
quality_factor_p = 700.0
quality_factor_s = 350.0

[ROCK_LAYER6]
name = Upper_Mantle_Peridotite
constitutive_model = ELASTIC
depth_top = 40000.0
depth_bottom = 60000.0
density = 3350.0
p_wave_velocity = 8050.0
s_wave_velocity = 4550.0
youngs_modulus = 185.0e9
poisson_ratio = 0.28
quality_factor_p = 1000.0
quality_factor_s = 500.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
# Minimal ICs for linear-elastic wave propagation.
# No lithostatic stress needed — COUPLED_ANALYTIC mode injects the source
# as equivalent body forces; the medium starts at rest.

[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

# ==============================================================================
# Boundary Conditions
# ==============================================================================
# Free surface at ZMIN (Earth's surface); PML absorbing on all other faces.
# PML with 20 layers and strength 100 effectively absorbs outgoing waves
# without spurious reflections back into the domain.

[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC3]
type = ABSORBING
location = XMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC4]
type = ABSORBING
location = YMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC5]
type = ABSORBING
location = YMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC6]
type = ABSORBING
location = ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Two arrays of virtual seismometers:
#
# (A) RADIAL ARRAY — 5 stations along the +x axis at 10, 25, 50, 75, 100 km
#     from the source.  These sample the distance-dependent amplitude decay
#     and waveform evolution (geometric spreading, attenuation, phase
#     development as guided waves form in the crustal waveguide).
#
# (B) AZIMUTHAL ARRAY — 4 stations at 75 km radial distance, placed at
#     azimuths matching real seismic stations that recorded the 2017 event.
#     This allows direct comparison of synthetic waveforms against observed
#     data after appropriate scaling for distance.
#
#     Real station azimuths from Punggye-ri:
#       IC.MDJ   — Mudanjiang, China:  az ≈ 350° (nearly due N)
#       KG.INCN  — Incheon, S. Korea:  az ≈ 210° (SSW)
#       IU.MAJO  — Matsushiro, Japan:  az ≈ 135° (SE)
#       RU.YSS   — Yuzhno-Sakhalinsk: az ≈ 52°  (NE)
#
# Coordinate system:
#   Source at (100000, 100000, -760).  Surface seismometers at z=0.
#   Azimuth 0° = +y (north), 90° = +x (east) — geographic convention.
#   Position = source + R×(sin(az), cos(az), 0)

[SEISMOMETERS]
enabled = true
output_dir = output/dprk_2017_far_field/seismograms
formats = SAC,MSEED
start_time_utc = 2017-09-03T03:30:01Z
default_sample_rate_hz = 50.0
default_quantity = VELOCITY

# ── Radial Array (along +x from source, i.e. due east, az=90°) ──────────────

[SEISMOMETER_R010]
net = SY
sta = R010
loc = 00
channels = BHN,BHE,BHZ
# 10 km east of source: (100000+10000, 100000, 0) = (110000, 100000, 0)
location_xyz = 110000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R025]
net = SY
sta = R025
loc = 00
channels = BHN,BHE,BHZ
# 25 km east of source
location_xyz = 125000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R050]
net = SY
sta = R050
loc = 00
channels = BHN,BHE,BHZ
# 50 km east of source
location_xyz = 150000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R075]
net = SY
sta = R075
loc = 00
channels = BHN,BHE,BHZ
# 75 km east of source
location_xyz = 175000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_R100]
net = SY
sta = R100
loc = 00
channels = BHN,BHE,BHZ
# 100 km east of source (near domain edge, ~1 km from PML boundary)
location_xyz = 199000.0, 100000.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ── Azimuthal Array at 75 km (matching real station azimuths) ────────────────
# Positions computed as: (100000 + 75000*sin(az), 100000 + 75000*cos(az), 0)

[SEISMOMETER_MDJ_AZ]
net = SY
sta = MDJA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward IC.MDJ: 350° (nearly due north)
# x = 100000 + 75000*sin(350°) = 100000 + 75000*(-0.1736) = 86979
# y = 100000 + 75000*cos(350°) = 100000 + 75000*(0.9848)  = 173863
location_xyz = 86979.0, 173863.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_INCN_AZ]
net = SY
sta = INCA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward KG.INCN: 210° (SSW)
# x = 100000 + 75000*sin(210°) = 100000 + 75000*(-0.5000) = 62500
# y = 100000 + 75000*cos(210°) = 100000 + 75000*(-0.8660) = 35048
location_xyz = 62500.0, 35048.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_MAJO_AZ]
net = SY
sta = MAJA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward IU.MAJO: 135° (SE)
# x = 100000 + 75000*sin(135°) = 100000 + 75000*(0.7071)  = 153033
# y = 100000 + 75000*cos(135°) = 100000 + 75000*(-0.7071) = 46967
location_xyz = 153033.0, 46967.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

[SEISMOMETER_YSS_AZ]
net = SY
sta = YSSA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward RU.YSS: 52° (NE)
# x = 100000 + 75000*sin(52°)  = 100000 + 75000*(0.7880)  = 159101
# y = 100000 + 75000*cos(52°)  = 100000 + 75000*(0.6157)  = 146178
location_xyz = 159101.0, 146178.0, 0.0
lowpass_corner_hz = 5.0
noise_std = 0.0

# ==============================================================================
# Receivers — Radial line array for dense waveform sampling
# ==============================================================================
# 20 evenly-spaced receivers along the +x axis from the source to 95 km.
# These provide a dense gather for moveout analysis, phase identification,
# and validation against analytical/semi-analytical solutions.

[RECEIVERS]
output_format = HDF5
sampling_rate = 100.0
output_velocity = true
output_displacement = true
output_acceleration = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 105000.0, 100000.0, 0.0     # 5 km east of source (avoid near-field)
end = 195000.0, 100000.0, 0.0       # 95 km east of source (inside PML margin)
num_stations = 20
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/dprk_2017_far_field

save_displacement = true
save_velocity = true
save_stress = true
save_damage = false                  # no damage in linear-elastic far-field
save_temperature = false             # no thermal effects

volume_output_frequency = 2000       # coarse volume snapshots (large domain)
surface_output = true
surface_output_frequency = 500       # surface wavefield snapshots

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
compute_damage_volume = false
