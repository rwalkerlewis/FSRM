# ==============================================================================
# Degelen Mountain 1988-10-18 — Coupled Underground Nuclear Tunnel Test
# ==============================================================================
#
# Purpose:
#   Model a ~16 kt underground nuclear test at the Degelen Mountain tunnel
#   complex within the Semipalatinsk Test Site (STS), NE Kazakhstan.
#   Degelen Mountain hosted over 200 tunnel tests between 1961 and 1989.
#
# Event summary (CSS3.0 catalog):
#   Date/time : 1988-10-18 03:40:09.16 UTC
#   Location  : 49.780°N, 78.017°E  (Degelen Mountain, STS)
#   Depth     : 0 km (tunnel test, shallow emplacement)
#   Yield     : ~16 kt (estimated from mb = 4.0 + 0.75*log10(W))
#   mb        : 4.90
#   Ms        : 4.80
#   Stations  : 27 Pn arrivals (KazIS + KyrgIS networks)
#
# Coupled-test characteristics:
#   • Device fired in horizontal tunnel within Degelen Mountain granite
#   • Cavity radius ~33 m (empirical: 55 × W^0.295 × (ρ/2650)^(-1/3.4))
#   • Full coupling to Palaeozoic granodiorite host rock
#   • Short-period recordings at 40 Hz sampling on Soviet seismographs
#
# Geology (Ryaboy 1989, Priestley et al. 1988):
#   Degelen Mountain complex: Palaeozoic granitiods and metamorphics
#   Kazakh Platform: stable continental crust, Moho ~43 km
#   Regional Pn velocity ~8.1 km/s (north Tien Shan refraction profiles)
#   Irtysh–Zaisan fold belt transitions south into Tien Shan orogen
#
# References:
#   Mueller & Murphy (1971) — Seismic source model for underground explosions
#   Patton (1988)           — Corner frequency scaling for nuclear tests
#   Ryaboy (1989)           — Deep crustal structure of Kazakhstan
#   Priestley et al. (1988) — STS regional velocity structure
#   Ringdal et al. (1992)   — Seismicity of the Semipalatinsk Test Site
# ==============================================================================

[SIMULATION]
name = degelen_1988_nuclear_test
description = Coupled ~16 kt underground nuclear test at Degelen Mountain (1988-10-18)

start_time = 0.0
end_time = 30.0                      # 30 s — moderate yield, captures near-field

dt_initial = 2.0e-6
dt_min = 1.0e-8
dt_max = 0.01
max_timesteps = 600000

adaptive_dt = true
cfl_number = 0.4

output_frequency = 200
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 20000

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = true
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = true
gpu_mode = CPU_FALLBACK
gpu_device_id = 0
gpu_verbose = true

# ==============================================================================
# Explosion Source (coupled in granite tunnel)
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

# Yield estimated from mb: 4.90 = 4.0 + 0.75*log10(W), W ≈ 16 kt
yield_kt = 16.0

# Depth of burial — horizontal tunnel in Degelen Mountain
depth_of_burial = 200.0              # m (estimated for tunnel test)
location_x = 20000.0                  # centre of domain (40 km × 40 km)
location_y = 20000.0
location_z = -200.0

# ── Cavity radius (empirical scaling) ──
# R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)  for coupled shot in granite
# For 16 kt, ρ=2700:  R_c ≈ 33 m
cavity_radius = 33.0
cavity_radius_scaling = OVERRIDE

# Damage zones
crushed_zone_radius = 83.0            # ~2.5× cavity
fractured_zone_radius = 165.0         # ~5× cavity
damaged_zone_radius = 330.0           # ~10× cavity

# ── Mueller-Murphy seismic source ──
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
# Corner frequency: fc ≈ 2.5 × W^(-1/3) ≈ 0.99 Hz for 16 kt
rise_time = 0.03                      # 30 ms — appropriate for 16 kt
overshoot_factor = 1.1

# ── Moment tensor ──
# Tunnel test: primarily isotropic with small tectonic release
isotropic_fraction = 0.85
clvd_fraction = 0.10
double_couple_fraction = 0.05

# Scalar moment: 10^(17 + log10(16)) ≈ 1.6×10^18 N·m
scalar_moment = 1.6e18

# No significant spall expected for tunnel test
enable_spall = false

# ==============================================================================
# Grid
# ==============================================================================
[GRID]
nx = 200
ny = 200
nz = 80

Lx = 40000.0                         # 40 km × 40 km × 20 km domain
Ly = 40000.0
Lz = 20000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# ── Geographic context ──
input_crs = EPSG:4326
model_crs = EPSG:32643               # UTM Zone 43N (covers STS)
use_local_coordinates = true
local_origin_x = 78.017               # Event longitude (°E)
local_origin_y = 49.780               # Event latitude  (°N)
local_origin_z = 0.0

# ── Adaptive mesh refinement around source ──
[amr]
enabled = true
method = plex_refine

[amr.criterion]
type = feature
feature_type = explosion_source

[amr.limits]
max_refinement_level = 3
max_cells = 3000000
min_cell_size = 5.0                   # fine cells near source

[amr.features.explosion_source]
x = 20000.0
y = 20000.0
z = 200.0
radius = 500.0
level = 3

# ==============================================================================
# Material Properties — Degelen Mountain Granite
# ==============================================================================
# Palaeozoic granodiorite and metamorphic complex (Ryaboy 1989).
# Dense, low-porosity crystalline rock typical of the Kazakh Platform.

[ROCK]
name = DEGELEN_GRANITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 50.0e9               # 50 GPa  (granodiorite)
poisson_ratio = 0.25
density = 2700.0                      # kg/m³

p_wave_velocity = 5700.0              # m/s  (granodiorite, measured)
s_wave_velocity = 3300.0              # m/s

# Attenuation — high Q for competent crystalline basement
quality_factor_p = 400.0
quality_factor_s = 200.0

# Drucker-Prager plasticity for near-source damage
failure_criterion = DRUCKER_PRAGER
cohesion = 25.0e6                     # 25 MPa  (granodiorite)
friction_angle = 33.0
dilation_angle = 10.0

# Tensile strength (for spall and fracture modelling)
tensile_strength = 12.0e6            # 12 MPa

# ── 1-D velocity profile (Degelen / Kazakh Platform) ──
# Based on Ryaboy (1989) regional refraction profiles
velocity_model = LAYERED
number_of_layers = 6

# ztop(m)   Vp(m/s)  Vs(m/s)  rho(kg/m3)
layer_1 =      0.0, 3800.0, 2200.0, 2150.0    # Weathered granite
layer_2 =    100.0, 5700.0, 3300.0, 2700.0    # Upper granite (tunnel level)
layer_3 =   4000.0, 6150.0, 3550.0, 2800.0    # Upper crust
layer_4 =  16000.0, 6500.0, 3750.0, 2900.0    # Middle crust
layer_5 =  30000.0, 7000.0, 4050.0, 3100.0    # Lower crust
layer_6 =  43000.0, 8100.0, 4550.0, 3350.0    # Upper mantle

# ==============================================================================
# Receivers — Soviet-Era Seismic Networks (KazIS + KyrgIS)
# ==============================================================================
# Station coordinates from CSS3.0 .site file.
# Primary recording: SPZ channels at 40 Hz, short-period vertical.

[RECEIVERS]
format = INLINE
number_of_receivers = 27

# name        x(lon)     y(lat)     z(elev_km)
receiver_1 =  80.2500,  50.4000,   2.090    # SEM  — Semey (Semipalatinsk)
receiver_2 =  77.0290,  43.8530,   0.540    # ILI  — Ili
receiver_3 =  76.3390,  43.8930,   0.550    # KUU  — Kurty
receiver_4 =  78.5170,  43.3670,   1.100    # BRTG — Bartogai
receiver_5 =  79.4900,  43.3290,   1.400    # PDG  — Podgornoye
receiver_6 =  77.6370,  43.3070,   1.510    # TRG  — Turgen
receiver_7 =  77.2250,  43.2330,   1.120    # TLG  — Talgar
receiver_8 =  77.0100,  43.1670,   1.600    # MDO  — Medeo
receiver_9 =  78.4070,  43.0570,   1.500    # SATY — Saty
receiver_10 = 76.9430,  43.0430,   3.130    # TSN  — Tien-Shan
receiver_11 = 76.4300,  43.1300,   1.190    # MTB  — Maytyube
receiver_12 = 75.9630,  43.0430,   1.415    # KST  — Kastek
receiver_13 = 75.0500,  42.6889,   1.175    # URVKG — Urevka
receiver_14 = 75.9422,  42.4817,   1.800    # BOM  — Boom
receiver_15 = 74.2361,  42.6250,   1.450    # BGK  — Belogorka
receiver_16 = 73.7864,  42.6683,   1.180    # EKS  — Erkin-Sai
receiver_17 = 79.2439,  42.3244,   3.018    # KNSKG — Ken-Suu
receiver_18 = 77.9061,  41.5750,   3.360    # KRSKG — Kara-Sai
receiver_19 = 74.3236,  41.8458,   1.640    # ARLS — Aral
receiver_20 = 74.7539,  42.9917,   0.655    # CHMS — Chumysh
receiver_21 = 72.5042,  42.4870,   1.515    # MNAS — Manas
receiver_22 = 71.9667,  41.7995,   1.280    # ARK  — Arkit
receiver_23 = 73.8042,  40.8708,  -999.000  # SALK — Salom-Alik
receiver_24 = 73.5030,  40.0128,   2.160    # SUFI — Sufi-Kurgan
receiver_25 = 72.7847,  40.5244,   0.980    # OHH  — Osh
receiver_26 = 72.2106,  40.1447,   2.120    # CHVKG — Chauvai
receiver_27 = 71.8050,  39.4808,   2.320    # DRKKG — Daraut-Kurgan

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
output_dir = output/degelen_1988
prefix = degelen_1988

# Fields to save
output_displacement = true
output_velocity = true
output_acceleration = true
output_stress = true
output_strain = true
output_plastic_strain = true

# Seismogram output
seismogram_format = SAC
seismogram_sampling_rate = 40.0       # match original recordings
