# ==============================================================================
# Nuclear Airburst Effects — Berkeley 100 kT Example
# ==============================================================================
# Reproduces the Berkeley 100 kT airburst scenario (50 m HOB) using the
# generalised NuclearAirburstEffects C++ calculator.
#
# All parameters below are editable.  Change any value to model a different
# scenario — no recompilation required.
#
# Usage:
#   ./nuclear_airburst_effects -c config/nuclear_airburst_berkeley_100kt.config
# ==============================================================================

[AIRBURST]
yield_kt          = 100.0       # Weapon yield (kt TNT)
burst_height_m    = 50.0        # Height of burst AGL (m)
fission_fraction  = 0.50        # Fraction of yield from fission
latitude          = 37.8716     # Ground zero latitude (deg N)
longitude         = -122.2727   # Ground zero longitude (deg E, negative = W)
location_name     = UC Berkeley campus
thermal_attenuation_length_m = 18000  # 1/e atmospheric absorption length (m)

[WIND]
speed_surface_mps  = 5.0        # Surface wind speed (m/s)
speed_altitude_mps = 15.0       # Wind speed at cloud stabilisation height (m/s)
direction_deg      = 315.0      # Direction wind blows FROM (meteorological, deg)

[GROUND]
density_kgm3      = 2700        # Near-surface rock density (kg/m^3)
vs_mps            = 3000        # Near-surface shear-wave speed (m/s)
seismic_coupling  = 0.001       # Air-to-ground seismic coupling efficiency

[POPULATION]
density_urban     = 4000        # Urban population density (people / km^2)
density_suburban  = 2000        # Suburban population density (people / km^2)

[RADIATION]
prompt_dose_ref_gy    = 10.0    # Reference dose (Gy) at 1 km for 1 kt
prompt_atten_length_m = 2500    # 1/e attenuation length for prompt radiation (m)

[EMP]
e0_vm           = 25000         # Reference E1 peak field at 100 kt (V/m)
decay_length_m  = 30000         # E1 spatial decay length (m)
tau_rise_s      = 2.5e-9        # E1 rise time (s)
tau_decay_s     = 1.0e-6        # E1 decay time (s)

# ==============================================================================
# Output control (read by the driver executable)
# ==============================================================================
[OUTPUT]
radial_profile      = true      # Write 1-D radial profile CSV
radial_profile_file = berkeley_100kt_radial.csv
radial_r_min_m      = 100       # Start range (m)
radial_r_max_m      = 50000     # End range (m)
radial_n_points     = 500       # Number of sampling points

grid_csv            = true      # Write 2-D grid CSV
grid_csv_file       = berkeley_100kt_grid.csv
grid_half_extent_m  = 25000     # Half-width of grid (m)
grid_n_points       = 200       # Grid resolution per side

print_summary       = true      # Print scenario summary to stdout
