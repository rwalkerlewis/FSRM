; ===========================================================================
; Injection-to-Seismogram Dynamic Rupture Chain Configuration
; ===========================================================================
;
; End-to-end simulation: CO2 injection -> pore pressure diffusion ->
; Biot effective stress -> Coulomb failure -> IMEX transition ->
; split-mesh dynamic rupture -> seismic waves -> seismograms -> return
;
; Reference: Segall & Lu (2015), Reviews of Geophysics
; ===========================================================================

[SIMULATION]
physics_type = POROELASTODYNAMICS
end_time = 864000             ; 10 days
dt_initial = 3600             ; 1 hour initial timestep
output_frequency = 10         ; Output every 10 steps
output_format = HDF5
output_directory = output_injection_rupture

[GRID]
type = BOX_3D
nx = 40
ny = 4
nz = 30
Lx = 4000.0                  ; 4 km domain width
Ly = 400.0                   ; 400 m domain thickness (quasi-2D)
Lz = 3000.0                  ; 3 km domain depth

[MATERIAL]
; Elastic properties (typical sandstone/granite interface)
youngs_modulus = 50.0e9       ; 50 GPa
poissons_ratio = 0.25
density = 2500.0              ; kg/m³
biot_coefficient = 0.8

; Reservoir properties
porosity = 0.15
permeability = 1.0e-13        ; 100 mD
permeability_x = 1.0e-13
permeability_y = 1.0e-13
permeability_z = 1.0e-14      ; 10x anisotropy

[FLUID]
; Injection fluid (water/brine)
viscosity = 1.0e-3            ; Pa·s
compressibility = 4.5e-10     ; 1/Pa
density = 1000.0              ; kg/m³
co2_viscosity = 5.0e-5        ; Pa·s (if CO2 injection)
co2_density = 700.0           ; kg/m³ (supercritical CO2)

[WELLS]
num_wells = 1
well_1_name = INJ-1
well_1_type = INJECTOR
well_1_x = 2000.0            ; Center of domain
well_1_y = 200.0
well_1_z = 2000.0            ; 2 km depth
well_1_control = RATE
well_1_rate = 0.01            ; 0.01 m³/s (~864 m³/day)

[INITIAL_CONDITIONS]
pressure = 20.0e6             ; 20 MPa (hydrostatic at ~2 km)
saturation = 0.2              ; 20% water saturation
temperature = 350.0           ; K

[BOUNDARY_CONDITIONS]
; Roller BCs on all sides, free surface on top
type = ROLLER
top = FREE
bottom = FIXED

[FAULT]
enable = true
type = DYNAMIC                ; Spontaneous rupture (FaultCohesiveDyn)
gmsh_label =                  ; Empty: use geometric definition
strike = 0.0                  ; N-S striking fault (radians)
dip = 1.5708                  ; 90° = vertical fault
center_x = 2500.0            ; Fault center: 500m east of injector
center_y = 200.0
center_z = 2000.0            ; Same depth as injector
length = 2000.0               ; 2 km fault length
width = 1500.0                ; 1.5 km fault width (down-dip)
tolerance = 50.0              ; Face selection tolerance (m)

; Friction model: rate-state aging (velocity weakening)
friction_model = rate_state_aging
a = 0.010                     ; Direct effect
b = 0.015                     ; Evolution effect (b > a → VW)
dc = 0.01                     ; Critical slip distance (m)
f0 = 0.6                      ; Reference friction
v0 = 1.0e-6                   ; Reference slip rate (m/s)

; Initial stress state (critically stressed)
initial_traction_ll = 30.0e6  ; 30 MPa shear traction (left-lateral)
initial_traction_ud = 0.0     ; No up-dip traction
initial_traction_normal = -50.0e6  ; 50 MPa normal stress (compressive)

; Shear modulus for moment computation
shear_modulus = 30.0e9        ; 30 GPa

[IMEX]
enabled = true
trigger_type = COULOMB_FAILURE
coulomb_threshold = 0.0       ; Trigger when CFS >= 0
settling_type = COMBINED
min_dynamic_duration = 1.0    ; Minimum 1 s in explicit mode
max_dynamic_duration = 60.0   ; Maximum 60 s
settling_velocity = 1.0e-6    ; m/s velocity settling threshold
settling_energy_ratio = 0.01  ; 1% of peak kinetic energy
settling_slip_rate = 1.0e-9   ; m/s slip rate settling threshold

implicit_dt_initial = 3600.0  ; 1 hour
implicit_dt_min = 1.0
implicit_dt_max = 86400.0     ; 1 day
implicit_method = BEULER

explicit_dt_initial = 1.0e-4  ; 0.1 ms
explicit_dt_min = 1.0e-8
explicit_dt_max = 1.0e-2
explicit_method = EULER
cfl_factor = 0.5

smooth_transition = true
log_transitions = true
transition_log_file = imex_transitions.log

[SEISMOMETERS]
num_stations = 4
output_format = SAC
output_directory = output_injection_rupture/seismograms

; Surface stations at 1 km intervals
station_1_name = ST01
station_1_x = 1000.0
station_1_y = 200.0
station_1_z = 0.0

station_2_name = ST02
station_2_x = 2000.0
station_2_y = 200.0
station_2_z = 0.0

station_3_name = ST03
station_3_x = 3000.0
station_3_y = 200.0
station_3_z = 0.0

station_4_name = ST04
station_4_x = 2500.0
station_4_y = 200.0
station_4_z = 500.0

[SEISMICITY]
; Seismicity tracking and catalog output
track_events = true
slip_rate_threshold = 1.0e-3  ; m/s for event detection
min_magnitude = -2.0
catalog_file = output_injection_rupture/seismic_catalog.txt
