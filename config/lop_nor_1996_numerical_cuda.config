# ==============================================================================
# Lop Nor 1996-07-29 — Numerical Elastic Wave Propagation (CUDA Workstation)
# ==============================================================================
#
# Purpose:
#   Workstation-adapted version of the numerical wave propagation config.
#   Uses CUDA GPU_ONLY mode with unified memory for the ADER-DG solver.
#
#   This is a scaled-down version optimized for a single Quadro RTX 4000
#   (8 GB VRAM) with unified memory paging to ~112 GB system RAM.
#
#   Domain: 200 km × 200 km × 60 km  (source at center)
#   Grid:   200 × 200 × 60 cells  (Δx = Δy = 1000 m, Δz = 1000 m)
#   Solver: ADER-DG order 3, local time stepping, PML absorbing boundaries
#
#   DG order 3 with 1000 m cells → 4 DOFs per direction → ~250 m resolution
#   At Vp=5.8 km/s → f_max ≈ 5.8/1.0 ≈ 5.8 Hz (conservative: ~2.5 Hz)
#   At Vs=3.4 km/s → f_max ≈ 3.4/1.0 ≈ 3.4 Hz (conservative: ~1.5 Hz)
#   Analysis band: 0.5–2 Hz (adequate for regional body wave comparison)
#
# Travel-time estimates at domain edge (100 km from source):
#   Pn:  100/7.9 = 12.7 s        Pg:  100/5.8 = 17.2 s
#   Sn:  100/4.5 = 22.2 s        Lg:  100/3.5 = 28.6 s
#   → 45 s end_time captures all body waves + Lg onset at 100 km
#
# Memory estimate:
#   200 × 200 × 60 = 2.4 M cells
#   With DG3 (64 DOFs/cell × 9 fields × 8 bytes) ≈ 1.1 GB (fields only)
#   With ghost layers + buffers: ~4 GB total
#   Fits in 8 GB VRAM; unified memory provides headroom
#
# Event:
#   Date/time : 1996-07-29  01:48:57.170 UTC
#   Location  : 41.7163°N, 88.3748°E  (Lop Nor test site, Kuruktag)
#   Depth     : ~400 m  (horizontal tunnel)
#   Yield     : ~5 kt   (fully coupled in Paleozoic granite)
#   mb        : 4.90 (ISC)
#
# Run:
#   build/fsrm -c config/lop_nor_1996_numerical_cuda.config
#
# Post-processing:
#   python scripts/run_lop_nor_1996_numerical.py
# ==============================================================================

[SIMULATION]
name = lop_nor_1996_numerical_cuda
description = CUDA numerical elastic wave propagation — 1996-07-29 Lop Nor final Chinese nuclear test (~5 kt coupled)

start_time = 0.0
end_time = 45.0                      # Captures Lg at 100 km (~28.6 s) with margin

# Timestep control
#   dt_max_cfl = 0.45 × 1000 / 7900 ≈ 0.057 s
#   Use dt_max = 0.04 s for safety margin
#   dt_initial = 1e-4 s resolves the Mueller-Murphy source pulse (rise_time 20 ms)
dt_initial = 1.0e-4
dt_min = 1.0e-6
dt_max = 0.04
max_timesteps = 500000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 500
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 25000

# COUPLED_ANALYTIC mode: Mueller-Murphy RDP → equivalent body forces
# → numerical propagation through layered model
explosion_solve_mode = COUPLED_ANALYTIC

# Physics: pure linear elastodynamics (no plasticity, fracture, or thermal)
fluid_model = NONE
solid_model = ELASTIC
enable_elastodynamics = true
enable_geomechanics = false
enable_thermal = false
enable_fractures = false
enable_plasticity = false

# ADER-DG order 3 with local time stepping
use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true
lts_rate = 2

# ── CUDA GPU Configuration ──
use_gpu = true
gpu_mode = GPU_ONLY
gpu_device_id = 0
gpu_verbose = true
gpu_memory_fraction = 0.85
use_unified_memory = true
use_gpu_preconditioner = true
use_gpu_matrix_assembly = true
pin_host_memory = true

# ==============================================================================
# Explosion Source — Lop Nor 1996-07-29 (Coupled ~5 kt)
# ==============================================================================

[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 5.0                       # ~5 kt from mb-yield scaling (Ringdal 1992)
depth_of_burial = 400.0               # m (horizontal tunnel, Kuruktag mountains)

# Source at center of 200 km × 200 km domain
location_x = 100000.0                # m (center)
location_y = 100000.0                # m (center)
location_z = -400.0                  # m (below free surface)

# Cavity radius: R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)
# For W=5 kt, ρ=2650 → R_c ≈ 89 m
cavity_radius = 89.0
cavity_radius_scaling = OVERRIDE

# Damage zones (RDP parameterization only)
crushed_zone_radius = 222.0
fractured_zone_radius = 445.0
damaged_zone_radius = 890.0

# Mueller-Murphy source
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION

# Rise time for 5 kt: ~20 ms
rise_time = 0.02
overshoot_factor = 1.15

# Moment tensor — coupled granite, dominantly isotropic
isotropic_fraction = 0.85
clvd_fraction = 0.10
double_couple_fraction = 0.05

# Scalar seismic moment: M0 ≈ 7.0 × 10^16 N·m (Murphy 1996)
scalar_moment = 7.0e16

# Spall parameters
enable_spall = true
spall_depth = 100.0
spall_velocity = 2.5

# ==============================================================================
# Grid — 200 km × 200 km × 60 km structured domain
# ==============================================================================
# 200 × 200 × 60 = 2.4 M cells
# With DG order 3 → ~153.6 M DOFs (3-component displacement)

[GRID]
nx = 200
ny = 200
nz = 60

Lx = 200000.0                        # 200 km
Ly = 200000.0                        # 200 km
Lz = 60000.0                         # 60 km

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic reference (Lop Nor 1996)
input_crs = EPSG:4326
model_crs = EPSG:32646               # UTM Zone 46N
use_local_coordinates = true
local_origin_x = 88.3748             # Event longitude (°E)
local_origin_y = 41.7163             # Event latitude  (°N)
local_origin_z = 0.0

# ==============================================================================
# Material Properties — Lop Nor 1-D Layered Crustal Model
# ==============================================================================

[ROCK_LAYER1]
name = Upper_Granite_Kuruktag
constitutive_model = ELASTIC
depth_top = 0.0
depth_bottom = 3000.0
density = 2650.0
p_wave_velocity = 5800.0
s_wave_velocity = 3400.0
youngs_modulus = 50.0e9
poisson_ratio = 0.24
quality_factor_p = 400.0
quality_factor_s = 200.0

[ROCK_LAYER2]
name = Upper_Crust_Metasediments
constitutive_model = ELASTIC
depth_top = 3000.0
depth_bottom = 15000.0
density = 2750.0
p_wave_velocity = 6100.0
s_wave_velocity = 3550.0
youngs_modulus = 56.0e9
poisson_ratio = 0.26
quality_factor_p = 500.0
quality_factor_s = 250.0

[ROCK_LAYER3]
name = Middle_Crust_Metamorphic
constitutive_model = ELASTIC
depth_top = 15000.0
depth_bottom = 30000.0
density = 2850.0
p_wave_velocity = 6450.0
s_wave_velocity = 3700.0
youngs_modulus = 72.0e9
poisson_ratio = 0.26
quality_factor_p = 600.0
quality_factor_s = 300.0

[ROCK_LAYER4]
name = Lower_Crust_Mafic_Granulite
constitutive_model = ELASTIC
depth_top = 30000.0
depth_bottom = 48000.0
density = 3050.0
p_wave_velocity = 6950.0
s_wave_velocity = 4000.0
youngs_modulus = 98.0e9
poisson_ratio = 0.27
quality_factor_p = 700.0
quality_factor_s = 350.0

[ROCK_LAYER5]
name = Upper_Mantle_Peridotite
constitutive_model = ELASTIC
depth_top = 48000.0
depth_bottom = 60000.0
density = 3300.0
p_wave_velocity = 7900.0
s_wave_velocity = 4500.0
youngs_modulus = 170.0e9
poisson_ratio = 0.28
quality_factor_p = 1000.0
quality_factor_s = 500.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

# ==============================================================================
# Boundary Conditions
# ==============================================================================
# Free surface at z=0 (top), PML absorbing on all other faces.

[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 15
pml_strength = 100.0

[BC3]
type = ABSORBING
location = XMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 15
pml_strength = 100.0

[BC4]
type = ABSORBING
location = YMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 15
pml_strength = 100.0

[BC5]
type = ABSORBING
location = YMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 15
pml_strength = 100.0

[BC6]
type = ABSORBING
location = ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 15
pml_strength = 100.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Scaled for the 200 km × 200 km domain (source at 100 km, 100 km).
# Max receiver distance: ~100 km from source.
#
# (A) RADIAL ARRAY — 5 stations along +x at 20, 40, 60, 80, 100 km
# (B) AZIMUTHAL ARRAY — 4 stations at 75 km matching KNDC azimuths
# (C) CROSS ARRAY — 4 stations at 40 km in cardinal directions

[SEISMOMETERS]
enabled = true
output_dir = output/lop_nor_1996_numerical/seismograms
formats = SAC,MSEED
start_time_utc = 1996-07-29T01:48:57Z
default_sample_rate_hz = 50.0
default_quantity = VELOCITY

# ── Radial Array (along +x from source, due east) ───────────────────────────

[SEISMOMETER_R020]
net = SY
sta = R020
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 120000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_R040]
net = SY
sta = R040
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 140000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_R060]
net = SY
sta = R060
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 160000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_R080]
net = SY
sta = R080
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 180000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_R100]
net = SY
sta = R100
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 200000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

# ── Azimuthal Array (75 km radius, matching KNDC station azimuths) ──────────
# Source at (100000, 100000). r = 75 km = 75000 m.

[SEISMOMETER_AZ_DZHR]
net = SY
sta = DZHR
loc = 00
channels = BHN,BHE,BHZ
# az = 315°: dx = 75*sin(315°) = -53.03 km, dy = 75*cos(315°) = +53.03 km
location_xyz = 46966.0, 153033.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_AZ_PRZ]
net = SY
sta = PRZ
loc = 00
channels = BHN,BHE,BHZ
# az = 285°: dx = 75*sin(285°) = -72.44 km, dy = 75*cos(285°) = +19.41 km
location_xyz = 27559.0, 119411.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_AZ_KUU]
net = SY
sta = KUU
loc = 00
channels = BHN,BHE,BHZ
# az = 323°: dx = 75*sin(323°) = -45.14 km, dy = 75*cos(323°) = +59.89 km
location_xyz = 54865.0, 159896.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_AZ_TRG]
net = SY
sta = TRG
loc = 00
channels = BHN,BHE,BHZ
# az = 307°: dx = 75*sin(307°) = -59.90 km, dy = 75*cos(307°) = +45.14 km
location_xyz = 40105.0, 145135.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

# ── Cross Array (40 km radius in 4 cardinal directions) ─────────────────────

[SEISMOMETER_N040]
net = SY
sta = N040
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 100000.0, 140000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_E040]
net = SY
sta = E040
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 140000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_S040]
net = SY
sta = S040
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 100000.0, 60000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

[SEISMOMETER_W040]
net = SY
sta = W040
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 60000.0, 100000.0, 0.0
lowpass_corner_hz = 3.0
noise_std = 0.0

# ==============================================================================
# Receiver Line (for wavefield snapshot analysis)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 100.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 100000.0, 100000.0, 0.0
end = 200000.0, 100000.0, 0.0
num_stations = 20
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/lop_nor_1996_numerical

save_displacement = true
save_velocity = true
save_stress = true
save_damage = false
save_temperature = false

volume_output_frequency = 1000
surface_output = true
surface_output_frequency = 250

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
