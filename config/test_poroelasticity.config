# Poroelasticity Test Configuration
# Terzaghi consolidation problem: 1D column with top load and drainage

[SIMULATION]
name = terzaghi_consolidation
fluid_model = SINGLE_COMPONENT
solid_model = POROELASTIC
enable_geomechanics = true
enable_thermal = false
enable_fractures = false
enable_faults = false
max_timesteps = 50
dt_initial = 0.001
dt_min = 0.0001
dt_max = 0.01
end_time = 0.05
rtol = 1.0e-8
atol = 1.0e-10
max_nonlinear_iterations = 20
output_frequency = 5
output_format = HDF5

[GRID]
# 1D column: thin in x-y, tall in z
nx = 1
ny = 1
nz = 20
Lx = 1.0                          # 1 m (thin)
Ly = 1.0                          # 1 m (thin)
Lz = 10.0                         # 10 m height

[ROCK]
# Poroelastic material properties
density = 2500.0                  # kg/m³
youngs_modulus = 1.0e9            # 1 GPa (Pa)
poissons_ratio = 0.25             # dimensionless
porosity = 0.3                    # 30%
permeability_x = 1e-12            # m²
permeability_y = 1e-12            # m²
permeability_z = 1e-12            # m²
biot_coefficient = 1.0            # fully coupled

[FLUID]
type = SINGLE_PHASE
density = 1000.0                  # kg/m³
viscosity = 0.001                 # Pa·s (water)
compressibility = 4.5e-10         # 1/Pa
reference_pressure = 1.0e5        # 100 kPa (atmospheric)

[BOUNDARY_CONDITIONS]
# Bottom boundary (z=0): fixed displacement, impermeable
bc_z_min_type = DIRICHLET
bc_z_min_displacement_x = 0.0
bc_z_min_displacement_y = 0.0
bc_z_min_displacement_z = 0.0
bc_z_min_flow_type = NEUMANN
bc_z_min_flux = 0.0               # No flow (impermeable)

# Top boundary (z=Lz): applied load, drained
bc_z_max_type = NEUMANN
bc_z_max_traction_z = -1.0e6      # -1 MPa (compression)
bc_z_max_flow_type = DIRICHLET
bc_z_max_pressure = 1.0e5         # Atmospheric (drained)

# Lateral boundaries: free displacement (1D problem)
bc_x_min_type = FREE
bc_x_max_type = FREE
bc_y_min_type = FREE
bc_y_max_type = FREE

# Lateral flow: impermeable (1D problem)
bc_x_min_flow_type = NEUMANN
bc_x_max_flow_type = NEUMANN
bc_y_min_flow_type = NEUMANN
bc_y_max_flow_type = NEUMANN
bc_x_min_flux = 0.0
bc_x_max_flux = 0.0
bc_y_min_flux = 0.0
bc_y_max_flux = 0.0

[INITIAL_CONDITIONS]
initial_pressure = 1.0e5          # Atmospheric pressure (100 kPa)
initial_temperature = 300.0       # 300 K
initial_displacement_x = 0.0
initial_displacement_y = 0.0
initial_displacement_z = 0.0
initial_stress_xx = 0.0
initial_stress_yy = 0.0
initial_stress_zz = 0.0

[OUTPUT]
output_displacement = true
output_pressure = true
output_stress = true
output_strain = true
output_porosity = true
