# ==============================================================================
# DPRK 2017-09-03 Punggye-ri — Quick-Run Variant for Workstation Testing
# ==============================================================================
# Reduced-resolution version of dprk_2017_punggye_ri_coupled_granite.config
# designed to run on a workstation in ~10–15 minutes.
#
# Changes from full config:
#   - Grid:     100×100×50  (500K cells vs 4M)
#   - Domain:   40 km × 40 km × 15 km  (reduced from 80×80×30)
#   - Source:   at center (20000, 20000, -760)
#   - End time: 5.0 s  (near-field wavefield only)
#   - dt_initial = 0.005, dt_max = 0.015, max_timesteps = 5000
#   - DG order: 2  (from 3)
#   - AMR:      disabled
#   - Receivers only (no seismometers)
#   - Thermal:  disabled
#   - enable_checkpointing = false
# ==============================================================================

[SIMULATION]
name = dprk_2017_punggye_ri_coupled_granite_quick
description = Quick-run: coupled 250 kt nuclear test, Punggye-ri granite/syenite, near-field wavefield

start_time = 0.0
end_time = 5.0

# CFL-stable dt ≈ 0.45 * 400m / 5600 m/s ≈ 0.032 s
dt_initial = 0.005
dt_min = 1.0e-5
dt_max = 0.015
max_timesteps = 5000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 100
output_format = HDF5
enable_checkpointing = false

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = false
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 2
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = true
gpu_mode = CPU_FALLBACK
gpu_device_id = 0
gpu_verbose = true

# ==============================================================================
# Explosion Source (250 kt coupled, depth 760 m)
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 250.0
depth_of_burial = 760.0
location_x = 20000.0
location_y = 20000.0
location_z = -760.0

# Cavity radius ~ 55 * W^0.295 for granite; 250 kt → ~242 m
cavity_radius = 242.0
cavity_radius_scaling = OVERRIDE

crushed_zone_radius = 484.0
fractured_zone_radius = 1210.0
damaged_zone_radius = 2420.0

source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
rise_time = 0.02
overshoot_factor = 1.1

isotropic_fraction = 0.75
clvd_fraction = 0.20
double_couple_fraction = 0.05

# log(M0) ≈ 17 + log10(250) → M0 ≈ 2.5e19 N·m
scalar_moment = 2.5e19

enable_spall = false

# ==============================================================================
# Grid (reduced)
# ==============================================================================
[GRID]
nx = 100
ny = 100
nz = 50

Lx = 40000.0
Ly = 40000.0
Lz = 15000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

[amr]
enabled = false

# ==============================================================================
# Material — Korean Peninsula Granite/Syenite (Punggye-ri)
# ==============================================================================
[ROCK]
name = KOREAN_PENINSULA_GRANITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 52.0e9
poisson_ratio = 0.25
density = 2650.0

p_wave_velocity = 5600.0
s_wave_velocity = 3300.0

quality_factor_p = 400.0
quality_factor_s = 200.0

failure_criterion = DRUCKER_PRAGER
cohesion = 28.0e6
friction_angle = 35.0
dilation_angle = 10.0
tensile_strength = 11.0e6

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.008
compressibility = 4.0e-11

permeability_x = 1.0e-19
permeability_y = 1.0e-19
permeability_z = 1.0e-19

thermal_conductivity = 2.8
specific_heat = 790.0
thermal_expansion = 7.5e-6

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

[IC3]
field = STRESS
distribution = LITHOSTATIC
surface_stress = 0.0
density = 2650.0
gravity = 9.81

# ==============================================================================
# Boundary Conditions
# ==============================================================================
[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN, XMAX, YMIN, YMAX, ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 10
pml_strength = 80.0

# ==============================================================================
# Receivers (two radial lines from source: X-axis and diagonal)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 200.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 20000.0, 20000.0, 0.0
end = 39500.0, 20000.0, 0.0
num_stations = 20
fields = displacement, velocity, acceleration

[RECEIVER_ARRAY_DIAGONAL]
type = LINE
start = 20000.0, 20000.0, 0.0
end = 34142.0, 34142.0, 0.0
num_stations = 10
fields = displacement, velocity

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/dprk_2017_quick

save_displacement = true
save_velocity = true
save_stress = true
save_damage = true

volume_output_frequency = 200
surface_output = true
surface_output_frequency = 100

save_cross_sections = true
cross_section_planes = XZ_Y20000, YZ_X20000
cross_section_frequency = 100

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_damage_volume = true
damage_threshold = 0.1
