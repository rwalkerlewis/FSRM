# ==============================================================================
# US Divider (1992-09-23) — Far-Field Synthetic Seismograms via Numerical Wave Equation
# ==============================================================================
#
# Purpose:
#   Solve the elastic wave equation numerically using FSRM's ADER-DG solver
#   to propagate seismic waves from the 1992 Divider nuclear test source to
#   regional distances (up to 75 km), producing synthetic seismograms at
#   virtual seismometer positions.
#
#   This config uses COUPLED_ANALYTIC mode: the Mueller-Murphy Reduced
#   Displacement Potential (RDP) is applied as the source time function,
#   and the resulting wavefield is then numerically propagated through a
#   1-D layered crustal velocity model using the ADER-DG elastodynamics
#   solver with PML absorbing boundaries.
#
# Why a separate far-field config?
#   The near-field configs for Divider (us_divider_1992_complex_geology_gmsh.config
#   and the seismometer variant) use a detailed Gmsh unstructured mesh with
#   complex NTS geology: multiple tuff units, fault cores, intrusive bodies,
#   damage halos, etc.  That level of geologic detail is critical within the
#   first few km of the source, where wavefield interactions with heterogeneity
#   and the Divider fault produce observable effects.
#
#   At regional distances (10–75 km), however:
#     • The wavefield is linear-elastic — no plasticity or fault interaction
#     • A 1-D layered model captures the dominant propagation effects
#       (Pn, Pg, Sn, Lg head waves and guided crustal phases)
#     • A structured grid with 500 m spacing is more efficient than an
#       unstructured mesh at these scales
#     • COUPLED_ANALYTIC mode injects the Mueller-Murphy RDP directly,
#       avoiding re-solving the expensive nonlinear near-source problem
#
# Event summary (public sources):
#   Date/time : 1992-09-23 15:04:00 UTC
#   Location  : 37.021°N, 115.988°W  (Nevada Test Site, Area 3)
#   Depth     : ~800 m below surface
#   Yield     : <20 kt (announced); likely ~1 kt (educational estimate)
#   Character : Last US underground nuclear test before moratorium
#   Note      : Part of Operation Julin; precursor to CTBT negotiations
#
# NTS regional geology (simplified 1-D model):
#   The Nevada Test Site sits in the Basin and Range province.  The shallow
#   section (0–1 km) consists of alluvium and volcanic tuffs overlying
#   Paleozoic carbonates and Precambrian basement.  The Moho is at ~30 km
#   depth.  This simplified 1-D model captures the essential velocity
#   structure for regional wave propagation.
#
# Frequency content:
#   500 m spacing with DG order 3 → effective resolution ~167 m per DOF
#   Minimum resolvable wavelength ~1.3 km (3 points/wavelength for DG 3)
#   At Vp=5.0 km/s → max frequency ~3.8 Hz
#   At Vs=2.9 km/s → max frequency ~2.2 Hz
#   Adequate for regional seismology band (0.5–2 Hz)
#
# Travel-time estimates (source at center, receivers at surface):
#   P-wave to 75 km:  ~75/7.8 = 9.6 s (Pn) or 75/5.0 = 15.0 s (Pg)
#   S-wave to 75 km:  ~75/4.4 = 17.0 s (Sn) or 75/2.9 = 25.9 s (Sg)
#   Rg at 75 km:      ~75/2.5 = 30.0 s
#   40 s end_time captures all body-wave and surface-wave arrivals
#
# References:
#   Mueller & Murphy (1971) — Seismic source model for underground explosions
#   Patton (1988)           — Corner frequency scaling
#   Werth & Herbst (1963)   — NTS seismic velocity structure
#   Priestley et al. (1988) — Crustal structure beneath NTS
#   Springer (1966)         — NTS near-surface velocity profiles
#
# Run:
#   mpirun -np 8 fsrm -c config/us_divider_1992_far_field_seismograms.config
# ==============================================================================

[SIMULATION]
name = us_divider_1992_far_field_seismograms
description = Far-field wave propagation from 1992 US Divider ~1 kt nuclear test — synthetic seismograms to 75 km

start_time = 0.0
end_time = 40.0                      # 40 s — captures all phases including Rg at 75 km

# Timestep control:
#   dt_initial = 5e-5 s resolves the sharp Mueller-Murphy pulse for 1 kt (rise_time 10 ms)
#   dt_max = 0.005 s keeps CFL < 0.45 for 500 m cells at Vp = 7.8 km/s
dt_initial = 5.0e-5
dt_min = 1.0e-6
dt_max = 0.005
max_timesteps = 200000

adaptive_dt = true
cfl_number = 0.45

output_frequency = 500
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 50000

# COUPLED_ANALYTIC mode — Mueller-Murphy RDP as analytical source,
# numerical wave propagation through layered model
explosion_solve_mode = COUPLED_ANALYTIC

# Pure linear elastodynamics — far-field propagation only
fluid_model = NONE
solid_model = ELASTIC
enable_elastodynamics = true
enable_geomechanics = false
enable_thermal = false
enable_fractures = false
enable_plasticity = false

# DG order 3 with ADER time integration and local time stepping
#   Lower order than DPRK config because the smaller yield produces lower
#   frequency content; DG 3 is sufficient and reduces computational cost
use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true
lts_rate = 2

use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source — Divider (1992-09-23)
# ==============================================================================
# The Divider test was a small (~1 kt) contained underground nuclear
# detonation at the Nevada Test Site.  In COUPLED_ANALYTIC mode, the
# source is represented by the Mueller-Murphy RDP.

[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 1.0                      # ~1 kt (educational estimate)
depth_of_burial = 800.0              # m below surface

# Source placed at center of 150 km × 150 km domain
location_x = 75000.0
location_y = 75000.0
location_z = -800.0

# Cavity radius from empirical scaling:
#   R_c = 55 × W^0.295 × (ρ/2650)^(-1/3.4)
#   For W=1 kt, ρ=2300 kg/m³ (tuff) → R_c ≈ 55 × 1.0 × 1.05 ≈ 58 m
cavity_radius = 55.0
cavity_radius_scaling = OVERRIDE

# Damage zones
crushed_zone_radius = 260.0          # from near-field config
fractured_zone_radius = 650.0
damaged_zone_radius = 1300.0

source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION

# Rise time for 1 kt shot: much shorter than 250 kt DPRK
rise_time = 0.01                     # 10 ms
overshoot_factor = 1.1

# Moment tensor: small test, predominantly isotropic
isotropic_fraction = 0.80
clvd_fraction = 0.18
double_couple_fraction = 0.02

# Scalar moment: ~10^15 N·m for 1 kt
scalar_moment = 1.0e15

enable_spall = true
spall_depth = 80.0                   # m (shallower spall for smaller test)
spall_velocity = 1.5                 # m/s

# ==============================================================================
# Grid — Large structured domain for regional wave propagation
# ==============================================================================
# 150 km × 150 km × 40 km domain with 500 m base cell spacing.
# Smaller domain than DPRK config because:
#   • 1 kt yield → much lower signal amplitude; receivers beyond 75 km
#     would have very low SNR even in the absence of noise
#   • NTS crustal structure has higher attenuation (volcanic tuffs, alluvium)
#     than Korean Peninsula granite → faster amplitude decay
#
# Grid dimensions:
#   300 × 300 × 80 = 7.2 M cells
#   With DG order 3: ~0.58 billion DOFs (3-component displacement)
#   Requires ~8 MPI ranks × ~16 GB RAM each
#
# Depth extent (40 km) includes:
#   0–1 km     : alluvium + tuff (NTS near-surface)
#   1–5 km     : volcanic tuffs and welded tuffs
#   5–15 km    : Paleozoic carbonates / upper crust
#   15–30 km   : middle/lower crust
#   30–40 km   : upper mantle (captures Pn head wave)

[GRID]
nx = 300
ny = 300
nz = 80

Lx = 150000.0                       # 150 km
Ly = 150000.0                       # 150 km
Lz = 40000.0                        # 40 km

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic reference for post-processing (NTS Area 3)
input_crs = EPSG:4326
model_crs = EPSG:32611              # UTM Zone 11N (covers NTS)
use_local_coordinates = true
local_origin_x = -115.988            # Event longitude (°W, negative for W)
local_origin_y = 37.021              # Event latitude  (°N)
local_origin_z = 0.0

# ==============================================================================
# Material Properties — NTS 1-D Layered Crustal Model
# ==============================================================================
# A simplified 1-D velocity model for the Nevada Test Site and surrounding
# Basin and Range province.  Eight layers from alluvium to upper mantle.
#
# The NTS shallow section is dominated by Tertiary volcanic tuffs and
# Quaternary alluvium, which have much lower velocities and higher
# attenuation than the Korean Peninsula granites.  This produces
# characteristically different waveforms: more dispersion, higher
# attenuation of high frequencies, and prominent Rg surface waves.
#
# Layer structure:
#   Layer 1:  0.0–0.3 km   Alluvium / desert fill           Vp=1.8  Vs=0.8
#   Layer 2:  0.3–1.0 km   Volcanic tuff (nonwelded)        Vp=2.8  Vs=1.5
#   Layer 3:  1.0–2.5 km   Welded tuff / vitric tuff        Vp=3.8  Vs=2.2
#   Layer 4:  2.5–5.0 km   Dense welded tuff / zeolitized   Vp=4.5  Vs=2.6
#   Layer 5:  5.0–15.0 km  Paleozoic carbonates / upper crust Vp=5.8 Vs=3.35
#   Layer 6:  15.0–25.0 km Middle crust                      Vp=6.3  Vs=3.65
#   Layer 7:  25.0–30.0 km Lower crust / Moho transition     Vp=6.8  Vs=3.95
#   Layer 8:  30.0–40.0 km Upper mantle                      Vp=7.8  Vs=4.40
#
# References:
#   Werth & Herbst (1963) — NTS velocity profiles from nuclear tests
#   Priestley et al. (1988) — Basin and Range crustal structure
#   Springer (1966) — Near-surface P-wave velocities at NTS

[ROCK_LAYER1]
name = Alluvium_Desert_Fill
constitutive_model = ELASTIC
depth_top = 0.0
depth_bottom = 300.0
density = 1900.0                     # kg/m³ — loose alluvium
p_wave_velocity = 1800.0             # m/s
s_wave_velocity = 800.0              # m/s
youngs_modulus = 1.6e9
poisson_ratio = 0.38                 # high Poisson ratio for unconsolidated fill
quality_factor_p = 40.0              # very high attenuation
quality_factor_s = 20.0

[ROCK_LAYER2]
name = Volcanic_Tuff_Nonwelded
constitutive_model = ELASTIC
depth_top = 300.0
depth_bottom = 1000.0
density = 2100.0
p_wave_velocity = 2800.0
s_wave_velocity = 1500.0
youngs_modulus = 6.5e9
poisson_ratio = 0.30
quality_factor_p = 80.0              # moderate attenuation in porous tuff
quality_factor_s = 40.0

[ROCK_LAYER3]
name = Welded_Tuff_Vitric
constitutive_model = ELASTIC
depth_top = 1000.0
depth_bottom = 2500.0
density = 2350.0
p_wave_velocity = 3800.0
s_wave_velocity = 2200.0
youngs_modulus = 16.0e9
poisson_ratio = 0.25
quality_factor_p = 180.0
quality_factor_s = 90.0

[ROCK_LAYER4]
name = Dense_Welded_Tuff_Zeolitized
constitutive_model = ELASTIC
depth_top = 2500.0
depth_bottom = 5000.0
density = 2500.0
p_wave_velocity = 4500.0
s_wave_velocity = 2600.0
youngs_modulus = 24.0e9
poisson_ratio = 0.25
quality_factor_p = 250.0
quality_factor_s = 125.0

[ROCK_LAYER5]
name = Paleozoic_Carbonates_Upper_Crust
constitutive_model = ELASTIC
depth_top = 5000.0
depth_bottom = 15000.0
density = 2700.0
p_wave_velocity = 5800.0
s_wave_velocity = 3350.0
youngs_modulus = 50.0e9
poisson_ratio = 0.25
quality_factor_p = 400.0
quality_factor_s = 200.0

[ROCK_LAYER6]
name = Middle_Crust
constitutive_model = ELASTIC
depth_top = 15000.0
depth_bottom = 25000.0
density = 2850.0
p_wave_velocity = 6300.0
s_wave_velocity = 3650.0
youngs_modulus = 65.0e9
poisson_ratio = 0.25
quality_factor_p = 550.0
quality_factor_s = 275.0

[ROCK_LAYER7]
name = Lower_Crust_Moho_Transition
constitutive_model = ELASTIC
depth_top = 25000.0
depth_bottom = 30000.0
density = 3050.0
p_wave_velocity = 6800.0
s_wave_velocity = 3950.0
youngs_modulus = 90.0e9
poisson_ratio = 0.25
quality_factor_p = 650.0
quality_factor_s = 325.0

[ROCK_LAYER8]
name = Upper_Mantle
constitutive_model = ELASTIC
depth_top = 30000.0
depth_bottom = 40000.0
density = 3300.0
p_wave_velocity = 7800.0
s_wave_velocity = 4400.0
youngs_modulus = 170.0e9
poisson_ratio = 0.27
quality_factor_p = 900.0
quality_factor_s = 450.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

# ==============================================================================
# Boundary Conditions
# ==============================================================================
# Free surface at ZMIN; PML absorbing on all other faces.
# PML with 20 layers and strength 100 — same as DPRK far-field config.

[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC3]
type = ABSORBING
location = XMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC4]
type = ABSORBING
location = YMIN
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC5]
type = ABSORBING
location = YMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

[BC6]
type = ABSORBING
location = ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 20
pml_strength = 100.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Two arrays of virtual seismometers:
#
# (A) RADIAL ARRAY — 4 stations along the +x axis at 10, 25, 50, 75 km
#     from the source.  Shorter maximum distance than DPRK config because
#     the 1 kt source has much lower amplitude at regional distances.
#
# (B) AZIMUTHAL ARRAY — 4 stations at 50 km radial distance, placed at
#     azimuths matching real seismic stations that were operating during
#     the Divider test era in the western US.
#
#     Real station azimuths from NTS (37.021°N, 115.988°W):
#       CI.PAS  — Pasadena, CA:      az ≈ 215° (SSW, ~370 km)
#       CI.GSC  — Goldstone, CA:     az ≈ 198° (S, ~260 km)
#       BK.SAO  — San Andreas Obs:   az ≈ 265° (W, ~480 km)
#       US.ELK  — Elko, NV:          az ≈ 10°  (N, ~300 km)
#
# Coordinate system:
#   Source at (75000, 75000, -800).  Surface seismometers at z=0.
#   Azimuth 0° = +y (north), 90° = +x (east).
#   Position = source + R×(sin(az), cos(az), 0)

[SEISMOMETERS]
enabled = true
output_dir = output/us_divider_1992_far_field/seismograms
formats = SAC,MSEED
start_time_utc = 1992-09-23T15:04:00Z
default_sample_rate_hz = 50.0
default_quantity = VELOCITY

# ── Radial Array (along +x from source, i.e. due east, az=90°) ──────────────

[SEISMOMETER_R010]
net = SY
sta = R010
loc = 00
channels = BHN,BHE,BHZ
# 10 km east of source: (75000+10000, 75000, 0) = (85000, 75000, 0)
location_xyz = 85000.0, 75000.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

[SEISMOMETER_R025]
net = SY
sta = R025
loc = 00
channels = BHN,BHE,BHZ
# 25 km east of source
location_xyz = 100000.0, 75000.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

[SEISMOMETER_R050]
net = SY
sta = R050
loc = 00
channels = BHN,BHE,BHZ
# 50 km east of source
location_xyz = 125000.0, 75000.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

[SEISMOMETER_R075]
net = SY
sta = R075
loc = 00
channels = BHN,BHE,BHZ
# 75 km east of source (maximum distance for 1 kt source)
location_xyz = 149000.0, 75000.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

# ── Azimuthal Array at 50 km (matching real station azimuths) ────────────────
# Positions computed as: (75000 + 50000*sin(az), 75000 + 50000*cos(az), 0)
# 50 km chosen (rather than 75 km) to keep all stations well inside PML boundary

[SEISMOMETER_PAS_AZ]
net = SY
sta = PASA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward CI.PAS: 215° (SSW)
# x = 75000 + 50000*sin(215°) = 75000 + 50000*(-0.5736) = 46321
# y = 75000 + 50000*cos(215°) = 75000 + 50000*(-0.8192) = 34043
location_xyz = 46321.0, 34043.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

[SEISMOMETER_GSC_AZ]
net = SY
sta = GSCA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward CI.GSC: 198° (S, slightly west)
# x = 75000 + 50000*sin(198°) = 75000 + 50000*(-0.3090) = 59549
# y = 75000 + 50000*cos(198°) = 75000 + 50000*(-0.9511) = 27447
location_xyz = 59549.0, 27447.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

[SEISMOMETER_SAO_AZ]
net = SY
sta = SAOA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward BK.SAO: 265° (W, nearly due west)
# x = 75000 + 50000*sin(265°) = 75000 + 50000*(-0.9962) = 25192
# y = 75000 + 50000*cos(265°) = 75000 + 50000*(-0.0872) = 70642
location_xyz = 25192.0, 70642.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

[SEISMOMETER_ELK_AZ]
net = SY
sta = ELKA
loc = 00
channels = BHN,BHE,BHZ
# Azimuth toward US.ELK: 10° (N, slightly east)
# x = 75000 + 50000*sin(10°) = 75000 + 50000*(0.1736) = 83681
# y = 75000 + 50000*cos(10°) = 75000 + 50000*(0.9848) = 124240
location_xyz = 83681.0, 124240.0, 0.0
lowpass_corner_hz = 4.0
noise_std = 0.0

# ==============================================================================
# Receivers — Radial line array for dense waveform sampling
# ==============================================================================
# 20 evenly-spaced receivers along the +x axis from 5 km to 70 km from source.
# Provides a dense gather for moveout analysis and phase identification.

[RECEIVERS]
output_format = HDF5
sampling_rate = 100.0
output_velocity = true
output_displacement = true
output_acceleration = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 80000.0, 75000.0, 0.0       # 5 km east of source
end = 145000.0, 75000.0, 0.0        # 70 km east of source (inside PML margin)
num_stations = 20
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/us_divider_1992_far_field

save_displacement = true
save_velocity = true
save_stress = true
save_damage = false
save_temperature = false

volume_output_frequency = 2000
surface_output = true
surface_output_frequency = 500

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
compute_damage_volume = false
