# Elastodynamics Test
# Tests wave propagation in elastic medium using TSALPHA2 (generalized-alpha)

[SIMULATION]
name = elastodynamics_test
start_time = 0.0
end_time = 0.01                     # 10 ms simulation
dt_initial = 1.0e-4                 # 100 microsecond timestep
dt_min = 1.0e-5
dt_max = 1.0e-3
output_frequency = 10
output_format = HDF5
fluid_model = NONE
solid_model = ELASTIC
enable_geomechanics = false
enable_elastodynamics = true        # Enable wave equation solver
enable_thermal = false
enable_fractures = false
enable_faults = false
rtol = 1.0e-6
atol = 1.0e-8
max_nonlinear_iterations = 20

[GRID]
nx = 10
ny = 10
nz = 10
Lx = 1.0                            # 1 m cube
Ly = 1.0
Lz = 1.0

[ROCK]
# Granite properties for wave propagation
density = 2700.0                    # kg/m³ (typical granite)
youngs_modulus = 50.0e9             # 50 GPa (Pa)
poissons_ratio = 0.25               # dimensionless
# Expected P-wave velocity: ~4700 m/s
# Expected S-wave velocity: ~2700 m/s

porosity = 0.01                     # Low porosity for competent granite
permeability_x = 0.001              # mD (essentially impermeable)
permeability_y = 0.001
permeability_z = 0.001

[BOUNDARY_CONDITIONS]
# Fixed boundaries on all faces (to reflect waves)
bc_x_min_type = DIRICHLET
bc_x_min_displacement = 0.0
bc_x_max_type = DIRICHLET
bc_x_max_displacement = 0.0

bc_y_min_type = DIRICHLET
bc_y_min_displacement = 0.0
bc_y_max_type = DIRICHLET
bc_y_max_displacement = 0.0

bc_z_min_type = DIRICHLET
bc_z_min_displacement = 0.0
bc_z_max_type = DIRICHLET
bc_z_max_displacement = 0.0

[INITIAL_CONDITIONS]
# Point source impulse at center
# Will be implemented via initial displacement perturbation
initial_displacement_x = 0.0
initial_displacement_y = 0.0
initial_displacement_z = 0.0
initial_stress_xx = 0.0
initial_stress_yy = 0.0
initial_stress_zz = 0.0

# Note: For proper point source, we would need to add
# a source term in the PDE or initial velocity perturbation.
# For now, this tests that the wave equation solver runs correctly.
