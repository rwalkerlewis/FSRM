# ==============================================================================
# Historical: Cannikin (1971) -- Largest US Underground Nuclear Test
# ==============================================================================
#
# Purpose:
#   Model the Cannikin underground nuclear test, the largest underground
#   detonation ever conducted by the United States. Cannikin was part of
#   the Spartan antiballistic missile warhead development program and was
#   fired on Amchitka Island, Alaska, on November 6, 1971.
#
# Event summary (public sources):
#   Date/time : 1971-11-06 22:00:00 UTC
#   Location  : 51.464N, 179.110E (Amchitka Island, Alaska, Aleutian Islands)
#   Depth     : 1860 m (6100 ft) -- deepest US underground nuclear test
#   Yield     : less than 5 Mt (declassified; commonly cited as approximately
#               4.7--5.0 Mt)
#   mb        : 6.97 (USGS/ISC)
#   Ms        : 5.65
#
# Historical significance:
#   Cannikin was the centerpiece of the Spartan ABM warhead program. It was
#   also the most controversial underground nuclear test in US history. The
#   Atomic Energy Commission faced lawsuits and protests over potential
#   tsunami and earthquake hazards. The Supreme Court ruled 4-3 to allow the
#   test. Cannikin caused a massive surface collapse chimney (approximately
#   1.6 km diameter, 18 m deep) and triggered a rockslide into the Bering
#   Sea. The test also contributed to the eventual closure of the Amchitka
#   test site and the creation of the Alaska Maritime National Wildlife
#   Refuge.
#
# Geology:
#   Amchitka Island is a volcanic island in the Aleutian arc. The emplacement
#   hole (UA-1) penetrated Tertiary volcanic breccia, pillow lavas, and
#   andesite flows. The deep test point was in dense andesitic rocks. The
#   island is approximately 65 km long and 2--6 km wide, with the Bering Sea
#   to the north and the Pacific Ocean to the south.
#
# Physics exercised:
#   - Very large cavity formation in volcanic host rock (Rc ~ 240 m)
#   - Massive surface collapse chimney formation
#   - Deep burial effects on seismic radiation pattern
#   - Spall at 1860 m depth in layered volcanic sequence
#   - Regional seismic wave propagation (mb 6.97 recorded worldwide)
#   - Potential tsunami excitation (Ms 5.65 surface waves)
#
# References:
#   DOE/NV-209 (Rev. 16) -- United States Nuclear Tests, 1945-1992
#   King et al. (1972) -- Cannikin: seismic results from an underground test
#   Bowers & Walter (2002) -- Discriminating nuclear from chemical explosions
#   Lay et al. (1984) -- Analysis of seismic data from Amchitka tests
# ==============================================================================

[SIMULATION]
name = historical_cannikin_1971_amchitka_5mt
description = Largest US underground nuclear test, Amchitka Island (1971-11-06)

start_time = 0.0
end_time = 120.0                      # 120 s for far-field regional phases

dt_initial = 5.0e-5
dt_min = 1.0e-7
dt_max = 0.05
max_timesteps = 2000000

adaptive_dt = true
cfl_number = 0.35

output_frequency = 200
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 20000

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = true                 # thermal effects significant at 5 Mt
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

yield_kt = 5000.0                    # ~5 Mt = 5000 kt

# Deepest US underground detonation: 1860 m (6100 ft)
depth_of_burial = 1860.0             # m
location_x = 30000.0                 # centre of 60 km x 60 km domain
location_y = 30000.0
location_z = -1860.0

# Cavity radius (empirical scaling)
# R_c = 55 * W^0.295 * (rho/2650)^(-1/3.4)
# For 5000 kt, rho=2400: ~240 m
cavity_radius = 240.0
cavity_radius_scaling = OVERRIDE

# Damage zones (enormous cavity leads to very large damage)
crushed_zone_radius = 600.0          # ~2.5x cavity
fractured_zone_radius = 1200.0       # ~5x cavity
damaged_zone_radius = 2400.0         # ~10x cavity

# Mueller-Murphy source model
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
# Corner frequency: fc ~ 2.5 * 5000^(-1/3) ~ 0.146 Hz
rise_time = 0.5                      # 500 ms for 5 Mt
overshoot_factor = 1.15              # larger overshoot at megaton yields

# Moment tensor -- large explosion with moderate tectonic release
# Cannikin showed some non-isotropic radiation attributable to tectonic
# release along pre-existing faults on Amchitka
isotropic_fraction = 0.85
clvd_fraction = 0.07
double_couple_fraction = 0.08

# Scalar moment (very large): approximately 10^(17 + log10(5000)) ~ 3.7e20 N*m
scalar_moment = 3.7e20

# Spall effects (deep burial reduces surface spall amplitude)
enable_spall = true
spall_depth = 600.0                  # m (deeper spall layer due to burial depth)
spall_velocity = 1.5                 # m/s (reduced by depth)

# Surface collapse chimney -- approximately 1.6 km diameter, 18 m subsidence
enable_chimney_collapse = true
chimney_diameter = 1600.0            # m (observed)
chimney_subsidence = 18.0            # m (observed)

# ==============================================================================
# Grid
# ==============================================================================
[GRID]
nx = 150
ny = 150
nz = 80

Lx = 60000.0                        # 60 km x 60 km x 20 km domain
Ly = 60000.0
Lz = 20000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# Geographic context (Amchitka Island, Alaska, Aleutian arc)
input_crs = EPSG:4326
model_crs = EPSG:32601              # UTM Zone 1N (western Aleutians)
use_local_coordinates = true
local_origin_x = 179.110            # Approximate longitude
local_origin_y = 51.464             # Approximate latitude
local_origin_z = 0.0

# Adaptive mesh refinement
[amr]
enabled = true
method = plex_refine

[amr.criterion]
type = feature
feature_type = explosion_source

[amr.limits]
max_refinement_level = 3             # deeper AMR for very large event
max_cells = 5000000
min_cell_size = 30.0

[amr.features.explosion_source]
x = 30000.0
y = 30000.0
z = 1860.0
radius = 4000.0                      # large refinement volume for 5 Mt
level = 3

# ==============================================================================
# Material Properties -- Amchitka Volcanic Breccia and Andesite
# ==============================================================================
# Amchitka Island is composed of Tertiary volcanic rocks: primarily volcanic
# breccia, pillow lavas, and andesite flows. The deep test point (1860 m) is
# in relatively dense andesitic rock. Values from King et al. (1972) and
# Amchitka site characterization studies.

[ROCK]
name = AMCHITKA_ANDESITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 35.0e9              # 35 GPa (moderately competent volcanic)
poisson_ratio = 0.28
density = 2400.0                     # kg/m3 (volcanic breccia/andesite)

p_wave_velocity = 4500.0             # m/s
s_wave_velocity = 2600.0             # m/s

quality_factor_p = 200.0
quality_factor_s = 100.0

# Drucker-Prager plasticity
failure_criterion = DRUCKER_PRAGER
cohesion = 15.0e6                    # 15 MPa (volcanic breccia)
friction_angle = 30.0
dilation_angle = 8.0
tensile_strength = 5.0e6             # 5 MPa

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.08                      # higher porosity in volcanic breccia
compressibility = 5.0e-11

permeability_x = 1.0e-16             # m2 (fractured volcanic)
permeability_y = 1.0e-16
permeability_z = 1.0e-16

thermal_conductivity = 2.0           # W/m*K
specific_heat = 900.0                # J/kg*K
thermal_expansion = 8.0e-6           # 1/K

# ==============================================================================
# Shallow Volcanic Layer (upper 500 m -- weathered, lower velocity)
# ==============================================================================
[ROCK_SHALLOW_VOLCANIC]
name = AMCHITKA_Weathered_Volcanic
constitutive_model = ELASTIC
youngs_modulus = 12.0e9              # 12 GPa (weathered)
poisson_ratio = 0.30
density = 2100.0                     # kg/m3
p_wave_velocity = 3200.0             # m/s
s_wave_velocity = 1800.0             # m/s
quality_factor_p = 80.0
quality_factor_s = 40.0

# ==============================================================================
# Thermal (significant for 5 Mt yield)
# ==============================================================================
[THERMAL]
initial_temperature_surface = 5.0    # deg C (Amchitka surface temperature)
geothermal_gradient = 0.030          # 30 deg C/km (volcanic arc setting)
enable_thermal_stress = true

# Temperature in cavity: millions of degrees initially, decays rapidly
source_temperature = 1.0e6           # peak cavity temperature (K)
source_thermal_decay_time = 0.01     # s (rapid radiative cooling)

# ==============================================================================
# Fluid -- not primary for this configuration
# ==============================================================================
[FLUID]
type = SINGLE_PHASE
density = 1020.0                     # kg/m3 (seawater infiltration at depth)
viscosity = 1.0                      # cP
compressibility = 4.5e-10            # 1/Pa

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/historical_cannikin_1971
frequency = 200
pressure = true
displacement = true
velocity = true
stress = true
damage = true
temperature = true

# Synthetic seismogram stations
[OUTPUT.SEISMOGRAMS]
enabled = true
format = MSEED

# Nearby Aleutian stations (approximate distances)
station_1 = ADAK    51.88  -176.68  0.0   # Adak, Alaska (~360 km)
station_2 = ATKA    52.22  -174.20  0.0   # Atka, Alaska (~550 km)
station_3 = NIL     51.90  178.00   0.0   # Near-island (~100 km)
