# ==============================================================================
# Lop Nor 2020-06-22 — Decoupled Underground Nuclear Test in Granite
# ==============================================================================
#
# Purpose:
#   Model the alleged Chinese low-yield nuclear test at Lop Nor on June 22, 2020,
#   assuming a fully decoupled detonation in a pre-existing cavity excavated in
#   Paleozoic granite of the Kuruktag mountains.
#
# Event summary (public sources):
#   Date/time : 2020-06-22  ~09:18 UTC
#   Location  : ~41.735°N, 88.730°E  (underground tunnel area, Lop Nor)
#   Detection : PS23 Makanchi array, Kazakhstan (~760 km), mb ≈ 2.75
#   Character : Strong P / weak S  → consistent with explosive source
#   CTBTO note: Two very small events separated by ~12 s recorded at PS23
#
# Decoupled-test hypothesis:
#   • Device fired inside a pre-excavated cavity in granite
#   • Full decoupling factor DF ≈ 70 in hard rock
#   • True yield ~ 0.5–1.0 kt  →  apparent coupled yield ~ 7–14 tonnes
#   • Expected mb (coupled 1 kt) ≈ 4.0,  reduced by ~1.3 units  →  mb ≈ 2.7
#
# Geology (Charlie & Veyera 1994; Xia et al. 2017):
#   Paleozoic granitic / metasedimentary host rock
#   Dense, low porosity;  horizontal tunnels above water table
#   Upper 50 m weathered and fractured
#   Regional crustal Vp = 6.0–7.0 km/s;  Pn ≈ 7.9 km/s
#
# References:
#   Mueller & Murphy (1971) — Seismic source model
#   Patton (1988)           — Corner frequency scaling
#   Charlie & Veyera (1994) — Lop Nor site geology
#   Xia et al. (2017)       — NCCrust velocity model
#   NORSAR (2026)           — Detection report
# ==============================================================================

[SIMULATION]
name = lop_nor_2020_decoupled_granite
description = Decoupled ~1 kt underground nuclear test in Lop Nor granite (2020-06-22)

start_time = 0.0
end_time = 60.0                      # 60 s — captures regional phases to ~500 km

dt_initial = 2.0e-6
dt_min = 1.0e-8
dt_max = 0.02
max_timesteps = 600000

adaptive_dt = true
cfl_number = 0.4

output_frequency = 200
output_format = HDF5
enable_checkpointing = true
checkpoint_frequency = 20000

fluid_model = NONE
solid_model = ELASTOPLASTIC_DP
enable_geomechanics = true
enable_elastodynamics = true
enable_thermal = true
enable_fractures = true
enable_plasticity = true

use_discontinuous_galerkin = true
dg_order = 3
use_ader_time_integration = true
enable_local_time_stepping = true

use_gpu = false
gpu_mode = CPU_FALLBACK

# ==============================================================================
# Explosion Source (decoupled in granite cavity)
# ==============================================================================
[EXPLOSION_SOURCE]
type = NUCLEAR_UNDERGROUND

# Hypothesised device yield
yield_kt = 1.0

# Depth of burial — horizontal tunnel in the Kuruktag mountains
depth_of_burial = 300.0               # m
location_x = 20000.0                  # centre of domain
location_y = 20000.0
location_z = -300.0

# ── Decoupling cavity ──
# Full decoupling in granite requires R_c > 20–25 m per kt^(1/3).
# For 1 kt:  R_c ≈ 25 m  is sufficient for a decoupling factor of ~70.
cavity_radius = 25.0
cavity_radius_scaling = OVERRIDE      # explicit override for decoupled scenario

# Damage zones — reduced because cavity absorbs most energy
crushed_zone_radius = 50.0            # ~2× cavity (energy contained by cavity)
fractured_zone_radius = 120.0         # ~5× cavity
damaged_zone_radius = 250.0           # ~10× cavity

# ── Mueller-Murphy seismic source ──
source_model = MUELLER_MURPHY
corner_frequency_scaling = PATTON
source_time_function = NUCLEAR_EXPLOSION
rise_time = 0.01                      # 10 ms — fast source for 1 kt
overshoot_factor = 1.08               # small overshoot, damped by cavity

# ── Moment tensor ──
# Decoupled shot is highly isotropic; minimal spall, negligible tectonic release
isotropic_fraction = 0.92
clvd_fraction = 0.06
double_couple_fraction = 0.02

# Effective scalar moment (reduced by decoupling factor ≈ 70)
# Coupled 1 kt M0 ≈ 1.0e16 N·m  →  decoupled M0 ≈ 1.4e14 N·m
scalar_moment = 1.4e14

enable_spall = false                  # fully contained in tunnel at depth

# ==============================================================================
# Grid
# ==============================================================================
[GRID]
nx = 200
ny = 200
nz = 100

Lx = 40000.0                         # 40 km × 40 km × 20 km domain
Ly = 40000.0
Lz = 20000.0

origin_x = 0.0
origin_y = 0.0
origin_z = 0.0

use_unstructured = false

# ── Geographic context (for coordinate-aware post-processing) ──
input_crs = EPSG:4326
model_crs = EPSG:32646               # UTM Zone 46N (covers Lop Nor)
use_local_coordinates = true
local_origin_x = 88.730              # Event longitude (°E)
local_origin_y = 41.735              # Event latitude  (°N)
local_origin_z = 0.0

# ── Adaptive mesh refinement around source ──
[amr]
enabled = true
method = plex_refine

[amr.criterion]
type = feature
feature_type = explosion_source

[amr.limits]
max_refinement_level = 3
max_cells = 4000000
min_cell_size = 8.0                   # fine cells near source

[amr.features.decoupled_shot]
x = 20000.0
y = 20000.0
z = 300.0
radius = 1500.0
level = 3

# ==============================================================================
# Material Properties — Lop Nor Paleozoic Granite
# ==============================================================================
# Values from Charlie & Veyera (1994) and regional crustal studies.
# Paleozoic granite / metasediments: dense, low porosity, quartz-rich.

[ROCK]
name = LOP_NOR_GRANITE
constitutive_model = ELASTOPLASTIC_DP

youngs_modulus = 50.0e9               # 50 GPa  (typical Paleozoic granite)
poisson_ratio = 0.25
density = 2650.0                      # kg/m³

p_wave_velocity = 5800.0              # m/s  (granite, measured)
s_wave_velocity = 3400.0              # m/s

# Attenuation — moderate Q for stable continental shield-edge granite
quality_factor_p = 400.0
quality_factor_s = 200.0

# Drucker-Prager plasticity for near-source damage
failure_criterion = DRUCKER_PRAGER
cohesion = 30.0e6                     # 30 MPa  (strong Paleozoic granite)
friction_angle = 35.0
dilation_angle = 10.0
tensile_strength = 12.0e6            # 12 MPa

damage_model = SCALAR_DAMAGE
initial_damage = 0.0
max_damage = 0.99
damage_evolution = STRAIN_BASED

porosity = 0.008                      # very low
compressibility = 4.0e-11

permeability_x = 1.0e-19             # m²  (very tight intact granite)
permeability_y = 1.0e-19
permeability_z = 1.0e-19

thermal_conductivity = 2.8           # W/m·K  (granite)
specific_heat = 790.0                # J/kg·K
thermal_expansion = 7.5e-6           # 1/K

# ==============================================================================
# Additional Crustal Layers
# ==============================================================================
# These provide context for the regional velocity model used in post-processing
# synthetic-seismogram generation.  The FSRM near-field solver uses the primary
# [ROCK] section; layers here are for reference / future multi-layer runs.

[ROCK_UPPER_CRUST]
name = Upper_Crust
constitutive_model = ELASTIC
youngs_modulus = 56.0e9
poisson_ratio = 0.26
density = 2750.0
p_wave_velocity = 6100.0
s_wave_velocity = 3550.0
quality_factor_p = 500.0
quality_factor_s = 250.0

[ROCK_MIDDLE_CRUST]
name = Middle_Crust
constitutive_model = ELASTIC
youngs_modulus = 72.0e9
poisson_ratio = 0.26
density = 2850.0
p_wave_velocity = 6450.0
s_wave_velocity = 3700.0
quality_factor_p = 600.0
quality_factor_s = 300.0

[ROCK_LOWER_CRUST]
name = Lower_Crust
constitutive_model = ELASTIC
youngs_modulus = 98.0e9
poisson_ratio = 0.27
density = 3050.0
p_wave_velocity = 6950.0
s_wave_velocity = 4000.0
quality_factor_p = 700.0
quality_factor_s = 350.0

[ROCK_UPPER_MANTLE]
name = Upper_Mantle
constitutive_model = ELASTIC
youngs_modulus = 170.0e9
poisson_ratio = 0.28
density = 3300.0
p_wave_velocity = 7900.0
s_wave_velocity = 4500.0
quality_factor_p = 1000.0
quality_factor_s = 500.0

# ==============================================================================
# Initial Conditions
# ==============================================================================
[IC1]
field = DISPLACEMENT
distribution = UNIFORM
value = 0.0

[IC2]
field = VELOCITY
distribution = UNIFORM
value = 0.0

[IC3]
field = STRESS
distribution = LITHOSTATIC
surface_stress = 0.0
density = 2650.0
gravity = 9.81

[IC4]
field = TEMPERATURE
distribution = GRADIENT
value = 288.15                        # 15 °C surface (continental arid)
gradient = 0.0, 0.0, 0.022           # 22 K/km — typical cratonic geotherm

# ==============================================================================
# Boundary Conditions
# ==============================================================================
[BC1]
type = FREE_SURFACE
location = ZMIN
field = DISPLACEMENT

[BC2]
type = ABSORBING
location = XMIN, XMAX, YMIN, YMAX, ZMAX
field = DISPLACEMENT
absorbing_type = PML
pml_layers = 16
pml_strength = 90.0

# ==============================================================================
# Virtual Seismometers
# ==============================================================================
# Placed at azimuths / scaled distances matching real IMS / IRIS stations.
# The near-field domain (40 km) cannot hold the true 246–1965 km offsets,
# so stations are placed at model-edge distances preserving azimuth.

[SEISMOMETERS]
enabled = true
output_dir = output/lop_nor_2020_decoupled_granite/seismograms
formats = SAC,MSEED
start_time_utc = 2020-06-22T09:18:00Z
default_sample_rate_hz = 100.0
default_quantity = VELOCITY

# IC.WMQ  — Urumqi, China (246 km, az 340°)
[SEISMOMETER_WMQ]
net = IC
sta = WMQ
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 16570.0, 38800.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# IU.MAKZ — Makanchi / PS23, Kazakhstan (780 km, az 319°)
[SEISMOMETER_MAKZ]
net = IU
sta = MAKZ
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 7200.0, 35500.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# II.KURK — Kurchatov, Kazakhstan (1264 km, az 326°)
[SEISMOMETER_KURK]
net = II
sta = KURK
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 8900.0, 36600.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# II.AAK — Ala Archa, Kyrgyzstan (1179 km, az 280°)
[SEISMOMETER_AAK]
net = II
sta = AAK
loc = 00
channels = BHN,BHE,BHZ
location_xyz = 3500.0, 23500.0, 0.0
lowpass_corner_hz = 10.0
noise_std = 0.0

# ==============================================================================
# Receivers (radial line for near-field analysis)
# ==============================================================================
[RECEIVERS]
output_format = HDF5
sampling_rate = 200.0
output_velocity = true
output_displacement = true

[RECEIVER_ARRAY_RADIAL]
type = LINE
start = 20000.0, 20000.0, 0.0
end = 39000.0, 20000.0, 0.0
num_stations = 20
fields = displacement, velocity, acceleration

# ==============================================================================
# Output
# ==============================================================================
[OUTPUT]
format = HDF5
path = output/lop_nor_2020_decoupled_granite

save_displacement = true
save_velocity = true
save_stress = true
save_damage = true
save_temperature = true

volume_output_frequency = 1000
surface_output = true
surface_output_frequency = 200

# ==============================================================================
# Analysis
# ==============================================================================
[ANALYSIS]
compute_seismic_moment = true
compute_magnitude = true
magnitude_type = mb, Mw
compute_ms_mb_ratio = true
compute_damage_volume = true
damage_threshold = 0.1
